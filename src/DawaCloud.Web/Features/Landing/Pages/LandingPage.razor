@page "/"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@layout DawaCloud.Web.Shared.Layout.LandingLayout
@attribute [AllowAnonymous]

<!-- ═══════════════════════════════════════════════════
     NAVIGATION BAR — transparent, becomes frosted on scroll
     ═══════════════════════════════════════════════════ -->
<nav class="landing-nav" id="landing-nav">
    <div class="landing-nav-inner">
        <a href="/" class="landing-logo">
            <svg viewBox="0 0 36 36" fill="none" class="landing-logo-icon">
                <rect x="13" y="3" width="10" height="30" rx="3" fill="url(#lCross)"/>
                <rect x="3" y="13" width="30" height="10" rx="3" fill="url(#lCross)"/>
                <defs><linearGradient id="lCross" x1="0" y1="0" x2="36" y2="36"><stop offset="0%" stop-color="#0C8599"/><stop offset="100%" stop-color="#10B981"/></linearGradient></defs>
            </svg>
            <span class="landing-logo-text">DawaCloud</span>
        </a>

        <div class="landing-nav-links">
            <a href="#features" class="landing-nav-link">Features</a>
            <a href="#pricing" class="landing-nav-link">Pricing</a>
            <a href="#about" class="landing-nav-link">About</a>
        </div>

        <div class="landing-nav-actions">
            <a href="/auth/login" class="landing-btn-ghost" data-enhance-nav="false">Log In</a>
            <a href="/auth/register" class="landing-btn-primary" data-enhance-nav="false">Start Free Trial</a>
        </div>

        <!-- Mobile menu button -->
        <button class="landing-mobile-menu" onclick="document.querySelector('.landing-nav-links').classList.toggle('show'); document.querySelector('.landing-nav-actions').classList.toggle('show');">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
    </div>
</nav>

<!-- ═══════════════════════════════════════════════════
     HERO SECTION — full viewport, dark atmospheric
     ═══════════════════════════════════════════════════ -->
<section class="landing-hero">
    <!-- Background layers -->
    <div class="landing-hero-bg">
        <div class="landing-hero-gradient"></div>
        <div class="landing-hero-grain"></div>
        <div class="landing-hero-orb landing-hero-orb--1"></div>
        <div class="landing-hero-orb landing-hero-orb--2"></div>
        <div class="landing-hero-orb landing-hero-orb--3"></div>
    </div>

    <!-- Floating pharmaceutical elements -->
    <div class="landing-pharma landing-pharma--1">
        <svg viewBox="0 0 60 28" fill="none"><rect width="30" height="28" rx="14" fill="rgba(12,133,153,0.18)"/><rect x="30" width="30" height="28" rx="14" fill="rgba(16,185,129,0.22)"/><line x1="30" y1="2" x2="30" y2="26" stroke="rgba(255,255,255,0.08)" stroke-width="0.5"/></svg>
    </div>
    <div class="landing-pharma landing-pharma--2">
        <svg viewBox="0 0 60 28" fill="none"><rect width="30" height="28" rx="14" fill="rgba(12,133,153,0.14)"/><rect x="30" width="30" height="28" rx="14" fill="rgba(16,185,129,0.18)"/><line x1="30" y1="2" x2="30" y2="26" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/></svg>
    </div>
    <div class="landing-pharma landing-pharma--3">
        <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="11" fill="rgba(12,133,153,0.1)" stroke="rgba(12,133,153,0.15)" stroke-width="0.5"/><circle cx="12" cy="12" r="4" fill="rgba(12,133,153,0.3)"/></svg>
    </div>
    <div class="landing-pharma landing-pharma--4">
        <svg viewBox="0 0 60 28" fill="none"><rect width="30" height="28" rx="14" fill="rgba(20,184,166,0.12)"/><rect x="30" width="30" height="28" rx="14" fill="rgba(52,211,153,0.16)"/><line x1="30" y1="2" x2="30" y2="26" stroke="rgba(255,255,255,0.05)" stroke-width="0.5"/></svg>
    </div>

    <!-- DNA Helix -->
    <svg class="landing-helix" viewBox="0 0 120 800" fill="none">
        <path d="M60 0 C20 50 100 100 60 150 C20 200 100 250 60 300 C20 350 100 400 60 450 C20 500 100 550 60 600 C20 650 100 700 60 750 C20 800 100 850 60 900" stroke="rgba(12,133,153,0.12)" stroke-width="1.5" fill="none"/>
        <path d="M60 0 C100 50 20 100 60 150 C100 200 20 250 60 300 C100 350 20 400 60 450 C100 500 20 550 60 600 C100 650 20 700 60 750 C100 800 20 850 60 900" stroke="rgba(16,185,129,0.08)" stroke-width="1.5" fill="none"/>
    </svg>

    <!-- Hero content -->
    <div class="landing-hero-content">
        <div class="landing-hero-badge">
            <span class="landing-hero-badge-dot"></span>
            Now available in South Sudan
        </div>

        <h1 class="landing-hero-title">
            Pharmacy management,<br/><span class="landing-gradient-text">reimagined.</span>
        </h1>

        <p class="landing-hero-subtitle">
            Streamline inventory, accelerate sales, and stay compliant — all from one intelligent platform built for modern pharmacies.
        </p>

        <div class="landing-hero-cta">
            <a href="/auth/register" class="landing-btn-primary landing-btn-primary--lg" data-enhance-nav="false">
                Start Free Trial
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#features" class="landing-btn-ghost landing-btn-ghost--lg">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                See How It Works
            </a>
        </div>

        <!-- Floating dashboard preview -->
        <div class="landing-hero-visual">
            <div class="landing-preview-card">
                <div class="landing-preview-bar">
                    <div class="landing-preview-dot" style="background:#EF4444;"></div>
                    <div class="landing-preview-dot" style="background:#F59E0B;"></div>
                    <div class="landing-preview-dot" style="background:#10B981;"></div>
                    <span style="color:rgba(255,255,255,0.3);font-size:11px;margin-left:12px;">DawaCloud Dashboard</span>
                </div>
                <div class="landing-preview-body">
                    <div class="landing-preview-kpi">
                        <div class="landing-preview-kpi-item">
                            <div style="font-size:10px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Today's Sales</div>
                            <div style="font-size:20px;font-weight:700;color:#14B8A6;font-family:'Instrument Serif',serif;">SSP 125,450</div>
                            <div style="font-size:10px;color:#34D399;">+12.5%</div>
                        </div>
                        <div class="landing-preview-kpi-item">
                            <div style="font-size:10px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Stock Value</div>
                            <div style="font-size:20px;font-weight:700;color:#FAFAF9;font-family:'Instrument Serif',serif;">SSP 2.4M</div>
                            <div style="font-size:10px;color:rgba(255,255,255,0.4);">758 items</div>
                        </div>
                        <div class="landing-preview-kpi-item">
                            <div style="font-size:10px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Low Stock</div>
                            <div style="font-size:20px;font-weight:700;color:#FB923C;font-family:'Instrument Serif',serif;">12</div>
                            <div style="font-size:10px;color:#FB923C;">Needs attention</div>
                        </div>
                    </div>
                    <div class="landing-preview-chart">
                        <svg viewBox="0 0 300 60" fill="none" style="width:100%;height:60px;">
                            <defs>
                                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                                    <stop offset="0%" stop-color="#14B8A6" stop-opacity="0.3"/>
                                    <stop offset="100%" stop-color="#14B8A6" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                            <path d="M0 50 L30 42 L60 45 L90 30 L120 35 L150 20 L180 25 L210 15 L240 18 L270 8 L300 12 L300 60 L0 60Z" fill="url(#chartGrad)"/>
                            <path d="M0 50 L30 42 L60 45 L90 30 L120 35 L150 20 L180 25 L210 15 L240 18 L270 8 L300 12" stroke="#14B8A6" stroke-width="2" fill="none"/>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="landing-scroll-hint">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     SOCIAL PROOF
     ═══════════════════════════════════════════════════ -->
<section class="landing-section landing-proof">
    <div class="landing-container">
        <p class="landing-proof-text">Trusted by <span style="color:#14B8A6;font-weight:700;">50+</span> pharmacies across South Sudan</p>
        <div class="landing-proof-logos">
            <div class="landing-proof-logo">Juba Central Pharmacy</div>
            <div class="landing-proof-logo">Grace Medical</div>
            <div class="landing-proof-logo">Unity Health</div>
            <div class="landing-proof-logo">Nile Pharma</div>
            <div class="landing-proof-logo">Hope Clinic</div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     FEATURES GRID
     ═══════════════════════════════════════════════════ -->
<section class="landing-section" id="features">
    <div class="landing-container">
        <div class="landing-section-header">
            <span class="landing-section-tag">Features</span>
            <h2 class="landing-section-title">Everything your pharmacy needs</h2>
            <p class="landing-section-subtitle">One platform to manage inventory, sales, procurement, and compliance — so you can focus on what matters: patient care.</p>
        </div>

        <div class="landing-features-grid">
            <!-- Feature 1 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <h3 class="landing-feature-title">Inventory Tracking</h3>
                <p class="landing-feature-desc">Real-time stock levels with batch tracking, expiry alerts, and automated reorder points. Never run out of critical medications.</p>
            </div>

            <!-- Feature 2 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 10h20M6 16h4M14 16h4"/></svg>
                </div>
                <h3 class="landing-feature-title">Point of Sale</h3>
                <p class="landing-feature-desc">Lightning-fast POS with barcode scanning, receipt printing, and customer management. Process sales in seconds.</p>
            </div>

            <!-- Feature 3 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
                </div>
                <h3 class="landing-feature-title">Procurement</h3>
                <p class="landing-feature-desc">Manage suppliers, create purchase orders, compare prices, and track deliveries — all in one unified workflow.</p>
            </div>

            <!-- Feature 4 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
                </div>
                <h3 class="landing-feature-title">Wholesale</h3>
                <p class="landing-feature-desc">Bulk sales management with customer credit tracking, order fulfillment, and wholesale pricing tiers.</p>
            </div>

            <!-- Feature 5 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
                </div>
                <h3 class="landing-feature-title">Analytics & Reports</h3>
                <p class="landing-feature-desc">Sales trends, profit margins, expiry forecasts, and compliance reports. Data-driven decisions made simple.</p>
            </div>

            <!-- Feature 6 -->
            <div class="landing-feature-card">
                <div class="landing-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a7 7 0 017 7c0 5-7 13-7 13S5 14 5 9a7 7 0 017-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                </div>
                <h3 class="landing-feature-title">AI Assistant</h3>
                <p class="landing-feature-desc">Intelligent drug interaction checks, demand forecasting, and natural language queries powered by Claude AI.</p>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════════════════════
     HOW IT WORKS
     ═══════════════════════════════════════════════════ -->
<section class="landing-section landing-section--dark" id="about">
    <div class="landing-container">
        <div class="landing-section-header">
            <span class="landing-section-tag">How It Works</span>
            <h2 class="landing-section-title">Get started in minutes</h2>
            <p class="landing-section-subtitle">No complex setup. No training required. Just sign up and start managing your pharmacy smarter.</p>
        </div>

        <div class="landing-steps">
            <div class="landing-step">
                <div class="landing-step-number">1</div>
                <div class="landing-step-line"></div>
                <h3 class="landing-step-title">Sign Up</h3>
                <p class="landing-step-desc">Create your free account in 30 seconds. No credit card required.</p>
            </div>
            <div class="landing-step">
                <div class="landing-step-number">2</div>
                <div class="landing-step-line"></div>
                <h3 class="landing-step-title">Add Inventory</h3>
                <p class="landing-step-desc">Import your drug catalog or add items one by one with batch and expiry tracking.</p>
            </div>
            <div class="landing-step">
                <div class="landing-step-number">3</div>
                <h3 class="landing-step-title">Start Selling</h3>
                <p class="landing-step-desc">Use the POS, manage wholesale orders, and let DawaCloud handle the rest automatically.</p>
            </div>
        </div>
    </div>
</section>

