@page "/reports"
@using MudBlazor
@using Microsoft.JSInterop
@using DawaCloud.Web.Features.Reports.Models
@using DawaCloud.Web.Features.Reports.Services
@using DawaCloud.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IReportService ReportService
@inject IReportExportService ReportExportService
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<PageTitle>Reports - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Reports & Analytics</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Generate insights from your pharmacy operations</p>
        </div>
    </div>
</div>

<!-- Report Categories -->
<MudGrid Class="mt-4">
