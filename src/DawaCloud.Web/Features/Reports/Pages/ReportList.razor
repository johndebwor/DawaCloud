                    <div class="dc-icon-box tw:bg-primary-50">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Style="color: var(--tw-color-primary-600);" />
                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:font-display">Inventory Reports</span>
                </div>
            </div>
            <div>
                <MudList T="string" Dense="true" Class="report-list">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("stock-levels"))">
                        <div class="report-item">
                            <span>Stock Levels Report</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                        </div>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("stock-valuation"))">
                        <div class="report-item">
                            <span>Stock Valuation Report</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                        </div>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("stock-movements"))">
                        <div class="report-item">
                            <span>Stock Movements Report</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
