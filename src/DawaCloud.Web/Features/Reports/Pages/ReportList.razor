                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:font-display">Supplier Reports</span>
                </div>
            </div>
            <div>
                <MudList T="string" Dense="true" Class="report-list">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("purchase-summary"))">
                        <div class="report-item">
                            <span>Purchase Summary</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                        </div>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("supplier-performance"))">
                        <div class="report-item">
                            <span>Supplier Performance</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                        </div>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("goods-received"))">
                        <div class="report-item">
                            <span>Goods Received Notes</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
