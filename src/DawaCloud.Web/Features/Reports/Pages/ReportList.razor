    private async Task GenerateReport()
    {
        try
        {
            _isGenerating = true;
            StateHasChanged();

            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            _companySettings = await dbContext.CompanySettings.FirstOrDefaultAsync();

            _reportResult = await ReportService.GenerateReportAsync(_selectedReportType, _startDate, _endDate);
            _showReportDialog = false;

            Snackbar.Add($"Report generated: {_reportResult.Rows.Count} rows", Severity.Success);

            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("scrollToElement", "report-results");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating report: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task ExportExcel()
    {
        if (_reportResult == null) return;
        try
        {
            var bytes = ReportExportService.ExportToExcel(_reportResult);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"{_selectedReportType}-{DateTime.UtcNow:yyyyMMdd-HHmmss}.xlsx";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            Snackbar.Add("Excel file exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting Excel: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportPdf()
    {
        if (_reportResult == null) return;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var companySettings = await dbContext.CompanySettings.FirstOrDefaultAsync();

            var bytes = ReportExportService.ExportToPdf(_reportResult, companySettings);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"{_selectedReportType}-{DateTime.UtcNow:yyyyMMdd-HHmmss}.pdf";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
            Snackbar.Add("PDF file exported successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            var msg = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error exporting PDF: {msg}", Severity.Error);
        }
    }

    private static string FormatCellValue(object? value, ColumnFormat format)
    {
        if (value == null) return "";
        return format switch
        {
            ColumnFormat.Currency => value is decimal d ? $"SSP {d:N2}" : value.ToString() ?? "",
            ColumnFormat.Number => value is int i ? i.ToString("N0") : value is long l ? l.ToString("N0") : value is double db ? db.ToString("N1") : value.ToString() ?? "",
            ColumnFormat.Percent => value is decimal p ? $"{p:N2}%" : value is double pd ? $"{pd:N1}%" : value.ToString() ?? "",
            ColumnFormat.Date => value is DateTime dt ? dt.ToString("dd/MM/yyyy") : value.ToString() ?? "",
            ColumnFormat.DateTime => value is DateTime dtm ? dtm.ToString("dd/MM/yyyy HH:mm") : value.ToString() ?? "",
            _ => value.ToString() ?? ""
        };
    }

    private static string FormatSummaryValue(object? value)
    {
        if (value == null) return "0";
        if (value is decimal d) return $"SSP {d:N2}";
        return value.ToString() ?? "0";
    }

    private static string GetHeaderStyle(ReportColumn col)
    {
        if (col.Format == ColumnFormat.Currency || col.Format == ColumnFormat.Number || col.Format == ColumnFormat.Percent)
            return "text-align: right;";
        return "";
    }

    private static string GetCellStyle(ReportColumn col)
    {
        if (col.Format == ColumnFormat.Currency || col.Format == ColumnFormat.Number || col.Format == ColumnFormat.Percent)
            return "text-align: right;";
        return "";
    }
