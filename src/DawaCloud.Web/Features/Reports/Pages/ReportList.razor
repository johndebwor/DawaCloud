<!-- Report Viewer Dialog -->
<MudDialog @bind-Visible="_showReportDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Assessment" />
            <MudText Typo="Typo.h6">@_selectedReportTitle</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_startDate" Label="Start Date" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_endDate" Label="End Date" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showReportDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="GenerateReport" Disabled="_isGenerating">
            @if (_isGenerating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Generate
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Report Results Section -->
@if (_reportResult != null)
{
    <div class="mt-6 animate-fade-in-up" id="report-results">
        <!-- Company Profile Header -->
        @if (_companySettings != null)
        {
            <MudPaper Elevation="0" Class="pa-4 mb-4" Style="border: 1px solid #e0e0e0; border-radius: 8px;">
                <div class="d-flex align-center gap-4">
                    @if (!string.IsNullOrEmpty(_companySettings.LogoUrl))
                    {
                        <MudImage Src="@_companySettings.LogoUrl" Alt="Logo" Height="60" ObjectFit="ObjectFit.Contain" />
                    }
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 600;">@(_companySettings.CompanyName ?? "DawaCloud")</MudText>
                        @if (!string.IsNullOrEmpty(_companySettings.Address))
                        {
                            <MudText Typo="Typo.body2" Color="Color.Default">@_companySettings.Address@(string.IsNullOrEmpty(_companySettings.City) ? "" : $", {_companySettings.City}")@(string.IsNullOrEmpty(_companySettings.Country) ? "" : $", {_companySettings.Country}")</MudText>
                        }
                        @if (!string.IsNullOrEmpty(_companySettings.Phone))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Default">Tel: @_companySettings.Phone</MudText>
                        }
                    </div>
                </div>
            </MudPaper>
        }

        <!-- Report Header -->
        <div class="dc-card">
            <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
                <div class="tw:flex tw:items-center tw:gap-3">
                    <div class="dc-icon-box tw:bg-primary-50">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" Style="color: var(--tw-color-primary-600);" />
                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:font-display">@_reportResult.Title</span>
                </div>
                <div class="d-flex gap-2">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.TableChart" OnClick="ExportExcel">
                        Excel
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="ExportPdf">
                        PDF
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Close" OnClick="@(() => _reportResult = null)">
                        Close
                    </MudButton>
                </div>
            </div>
            <div>
                @if (!string.IsNullOrEmpty(_reportResult.SubTitle))
                {
                    <MudText Typo="Typo.body2" Class="mb-2" Color="Color.Default">@_reportResult.SubTitle</MudText>
                }
                <MudText Typo="Typo.caption" Color="Color.Default">
                    @if (_reportResult.StartDate.HasValue && _reportResult.EndDate.HasValue)
                    {
                        <span>Period: @_reportResult.StartDate.Value.ToString("dd/MM/yyyy") - @_reportResult.EndDate.Value.ToString("dd/MM/yyyy") | </span>
                    }
                    Generated: @_reportResult.GeneratedAt.ToString("dd/MM/yyyy HH:mm") | @_reportResult.Rows.Count rows
                </MudText>

                <!-- Summary KPIs -->
                @if (_reportResult.Summary.Count > 0)
                {
                    <MudGrid Class="mt-3 mb-3">
                        @foreach (var kpi in _reportResult.Summary)
                        {
                            <MudItem xs="6" sm="4" md="3" lg="2">
                                <MudPaper Class="pa-3" Elevation="0" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
                                    <MudText Typo="Typo.caption" Color="Color.Default">@kpi.Key</MudText>
                                    <MudText Typo="Typo.h6" Style="font-size: 1.1rem;">
                                        @FormatSummaryValue(kpi.Value)
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }

                <!-- Data Table -->
                @if (_reportResult.Rows.Count > 0)
                {
                    <MudTable T="Dictionary<string, object?>" Items="@_reportResult.Rows" Dense="true" Hover="true"
                              Striped="true" Breakpoint="Breakpoint.Sm" FixedHeader="true" Height="500px">
                        <HeaderContent>
                            @foreach (var col in _reportResult.Columns)
                            {
                                <MudTh Style="@GetHeaderStyle(col)">@col.Label</MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate>
                            @foreach (var col in _reportResult.Columns)
                            {
                                <MudTd DataLabel="@col.Label" Style="@GetCellStyle(col)">
                                    @FormatCellValue(context.GetValueOrDefault(col.Key), col.Format)
                                </MudTd>
                            }
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100, 500 }" />
                        </PagerContent>
                    </MudTable>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Class="mt-3">No data found for the selected criteria.</MudAlert>
                }
            </div>
        </div>
    </div>
}

<style>
    .report-list .mud-list-item {
        border-radius: 8px;
        margin-bottom: 4px;
    }

    .report-list .mud-list-item:hover {
        background: var(--tw-color-primary-50);
    }

    .report-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }
</style>

@code {
    private bool _showReportDialog = false;
    private bool _isGenerating = false;
    private string _selectedReportTitle = string.Empty;
    private string _selectedReportType = string.Empty;
    private DateTime? _startDate = DateTime.Today.AddMonths(-1);
    private DateTime? _endDate = DateTime.Today;
    private ReportResult? _reportResult;
    private Data.Entities.CompanySettings? _companySettings;

