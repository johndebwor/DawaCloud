                            <span>Controlled Drugs Log</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                        </div>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Assessment" OnClick="@(() => OpenReport("prescription-log"))">
                        <div class="report-item">
                            <span>Prescription Log</span>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
