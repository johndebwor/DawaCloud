@page "/drugs/new"
@page "/drugs/{id:int}/edit"
@using MudBlazor
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@using DawaCloud.Web.Data
@using DawaCloud.Web.Data.Entities
@using DawaCloud.Web.Features.Drugs.Commands
@using Microsoft.EntityFrameworkCore
@inject IMediator Mediator
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>@(_isEditMode ? "Edit Drug" : "New Drug") - DawaCloud</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="mb-4" />

    <div class="dc-hero tw:mb-6 animate-fade-in-up">
        <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:mb-1 tw:font-display">@(_isEditMode ? "Edit Drug" : "Add New Drug")</h1>
        <p class="tw:text-sm tw:text-text-secondary tw:m-0">
            @(_isEditMode ? "Update drug information" : "Add a new pharmaceutical product")
        </p>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <div class="dc-card">
                    <MudForm @ref="_form" @bind-IsValid="@_isValid">
                        <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Basic Information</h3>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.Code"
                                              Label="Drug Code"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              RequiredError="Code is required"
                                              HelperText="Unique identifier for the drug" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.Name"
                                              Label="Drug Name"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              RequiredError="Name is required"
                                              HelperText="Generic or brand name" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.Description"
                                              Label="Description"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              HelperText="Brief description of the drug" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int" @bind-Value="_model.CategoryId"
                                           Label="Category"
                                           Variant="Variant.Outlined"
                                           Required="true"
                                           RequiredError="Category is required"
                                           AnchorOrigin="Origin.BottomCenter">
                                    @foreach (var category in _categories)
                                    {
                                        <MudSelectItem T="int" Value="@category.Id">@category.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.Manufacturer"
                                              Label="Manufacturer"
                                              Variant="Variant.Outlined"
                                              HelperText="Drug manufacturer name" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField @bind-Value="_model.DosageForm"
                                              Label="Dosage Form"
                                              Variant="Variant.Outlined"
                                              HelperText="e.g., Tablet, Capsule, Syrup" />
                            </MudItem>
                        </MudGrid>

                        <MudDivider Class="my-6" />
                        <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Pricing Information</h3>

                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudNumericField @bind-Value="_model.CostPrice"
                                                 Label="Cost Price (SSP)"
                                                 Variant="Variant.Outlined"
                                                 Min="0m"
                                                 Step="0.01m"
                                                 Required="true"
                                                 HelperText="Purchase cost per unit" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField @bind-Value="_model.WholesalePrice"
                                                 Label="Wholesale Price (SSP)"
                                                 Variant="Variant.Outlined"
                                                 Min="0m"
                                                 Step="0.01m"
                                                 HelperText="Price for bulk buyers" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField @bind-Value="_model.RetailPrice"
                                                 Label="Retail Price (SSP)"
                                                 Variant="Variant.Outlined"
                                                 Min="0m"
                                                 Step="0.01m"
                                                 Required="true"
                                                 HelperText="Selling price per unit" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField @bind-Value="_model.TaxRate"
                                                 Label="Tax Rate (%)"
                                                 Variant="Variant.Outlined"
                                                 Min="0m"
                                                 Max="100m"
                                                 Step="0.1m"
                                                 HelperText="VAT or tax percentage" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <div class="tw:p-5 tw:bg-success/5 tw:rounded-xl tw:border tw:border-success/20">
                                    <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:mb-2">Profit Margin</div>
                                    <div class="tw:text-2xl tw:font-bold tw:text-success tw:font-display">
                                        @CalculateProfitMargin()%
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>

                        <MudDivider Class="my-6" />
                        <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Stock Management</h3>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudNumericField @bind-Value="_model.ReorderLevel"
                                                 Label="Reorder Level"
                                                 Variant="Variant.Outlined"
                                                 Min="0"
                                                 Required="true"
                                                 HelperText="Minimum stock before reordering" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudCheckBox @bind-Value="_model.RequiresPrescription"
                                             Color="Color.Primary">
                                    Requires Prescription
                                </MudCheckBox>
                            </MudItem>
                        </MudGrid>

                        <MudDivider Class="my-6" />

                        <div class="d-flex justify-space-between">
                            <a href="/drugs" class="dc-btn-secondary">
                                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
                                <span>Cancel</span>
                            </a>
                            <button class="dc-btn-primary"
                                    disabled="@(!_isValid || _isSaving)"
                                    @onclick="HandleSubmit">
                                @if (_isSaving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                    <span class="ml-2">Saving...</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" />
                                    <span>@(_isEditMode ? "Update Drug" : "Save Drug")</span>
                                }
                            </button>
                        </div>
                    </MudForm>
                </div>
            </MudItem>

            <MudItem xs="12" md="4">
                <div class="dc-card tw:mb-4">
                    <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-4">Quick Stats</h3>
                    <div class="tw:mb-3">
                        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:mb-1">Profit Per Unit</div>
                        <div class="tw:text-2xl tw:font-bold tw:text-success tw:font-display">
                            SSP @((_model.RetailPrice - _model.CostPrice).ToString("N2"))
                        </div>
                    </div>
                    <div class="tw:mb-3">
                        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:mb-1">Price with Tax</div>
                        <div class="tw:text-2xl tw:font-bold tw:text-primary-600 tw:font-display">
                            SSP @((_model.RetailPrice * (1 + _model.TaxRate / 100)).ToString("N2"))
                        </div>
                    </div>
                </div>

                <div class="dc-card">
                    <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-4">Guidelines</h3>
                    <div class="tw:flex tw:flex-col tw:gap-3">
                        <div class="tw:flex tw:items-start tw:gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            <span class="tw:text-sm tw:text-text-secondary">Use unique drug codes</span>
                        </div>
                        <div class="tw:flex tw:items-start tw:gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            <span class="tw:text-sm tw:text-text-secondary">Set appropriate reorder levels</span>
                        </div>
                        <div class="tw:flex tw:items-start tw:gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            <span class="tw:text-sm tw:text-text-secondary">Verify pricing before saving</span>
                        </div>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _isSaving;
    private bool _isLoading = true;
    private bool _isEditMode => Id.HasValue;

    private DrugFormModel _model = new();
    private List<DrugCategory> _categories = new();

    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Drugs", href: "/drugs"),
            new BreadcrumbItem(_isEditMode ? "Edit" : "New", href: null, disabled: true)
        };

        await LoadCategoriesAsync();

        if (_isEditMode)
        {
            await LoadDrugAsync(Id!.Value);
        }

        _isLoading = false;
    }

    private async Task LoadCategoriesAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        _categories = await db.DrugCategories
            .Where(c => !c.IsDeleted)
            .OrderBy(c => c.Name)
            .ToListAsync();

        // Set default category if available
        if (_categories.Any() && _model.CategoryId == 0)
        {
            _model.CategoryId = _categories.First().Id;
        }
    }

    private async Task LoadDrugAsync(int id)
    {
        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var drug = await db.Drugs
            .AsNoTracking()
            .FirstOrDefaultAsync(d => d.Id == id);

        if (drug == null)
        {
            Snackbar.Add("Drug not found", Severity.Error);
            NavigationManager.NavigateTo("/drugs");
            return;
        }

        _model = new DrugFormModel
        {
            Code = drug.Code,
            Name = drug.Name,
            Description = drug.Description ?? string.Empty,
            CategoryId = drug.CategoryId,
            Manufacturer = drug.Manufacturer ?? string.Empty,
            DosageForm = drug.DosageForm ?? string.Empty,
            CostPrice = drug.CostPrice,
            WholesalePrice = drug.WholesalePrice,
            RetailPrice = drug.RetailPrice,
            TaxRate = drug.TaxRate,
            ReorderLevel = drug.ReorderLevel,
            RequiresPrescription = drug.RequiresPrescription
        };
    }

    private async Task HandleSubmit()
    {
        if (_form == null) return;

        await _form.Validate();
        if (!_isValid) return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (_isEditMode)
            {
                var command = new UpdateDrugCommand(
                    Id!.Value,
                    _model.Code,
                    _model.Name,
                    _model.Description,
                    _model.CategoryId,
                    _model.Manufacturer,
                    _model.CostPrice,
                    _model.WholesalePrice,
                    _model.RetailPrice,
                    _model.TaxRate,
                    _model.ReorderLevel,
                    _model.DosageForm,
                    _model.RequiresPrescription
                );

                var result = await Mediator.Send(command);

                if (result.Success)
                {
                    Snackbar.Add(result.Message, Severity.Success);
                    NavigationManager.NavigateTo("/drugs");
                }
                else
                {
                    Snackbar.Add(result.Message, Severity.Error);
                }
            }
            else
            {
                var command = new CreateDrugCommand(
                    _model.Code,
                    _model.Name,
                    _model.Description,
                    _model.CategoryId,
                    _model.Manufacturer,
                    _model.CostPrice,
                    _model.WholesalePrice,
                    _model.RetailPrice,
                    _model.TaxRate,
                    _model.ReorderLevel,
                    _model.DosageForm,
                    _model.RequiresPrescription
                );

                var result = await Mediator.Send(command);

                if (result.Success)
                {
                    Snackbar.Add(result.Message, Severity.Success);
                    NavigationManager.NavigateTo("/drugs");
                }
                else
                {
                    Snackbar.Add(result.Message, Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving drug: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private string CalculateProfitMargin()
    {
        if (_model.CostPrice == 0) return "0.00";
        var margin = ((_model.RetailPrice - _model.CostPrice) / _model.CostPrice) * 100;
        return margin.ToString("N2");
    }

    private class DrugFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public int CategoryId { get; set; }
        public string Manufacturer { get; set; } = string.Empty;
        public string DosageForm { get; set; } = string.Empty;
        public decimal CostPrice { get; set; }
        public decimal WholesalePrice { get; set; }
        public decimal RetailPrice { get; set; }
        public decimal TaxRate { get; set; } = 16m;
        public int ReorderLevel { get; set; } = 50;
        public bool RequiresPrescription { get; set; }
    }
}
