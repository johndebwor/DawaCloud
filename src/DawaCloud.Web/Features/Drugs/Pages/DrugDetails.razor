@page "/drugs/{id:int}"
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@inject NavigationManager Navigation

<PageTitle>Drug Details - DawaCloud</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="mb-4" />

    <div class="dc-hero tw:mb-6 animate-fade-in-up">
        <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
            <div>
                <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:mb-1 tw:font-display">@_drug.Name</h1>
                <p class="tw:text-sm tw:text-text-secondary tw:m-0">@_drug.Code</p>
            </div>
            <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3 tw:mt-5">
                <a href="/drugs" class="dc-btn-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
                    <span>Back to List</span>
                </a>
                <a href="@($"/drugs/{Id}/edit")" class="dc-btn-primary">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    <span>Edit Drug</span>
                </a>
            </div>
        </div>
    </div>

    <MudGrid>
        <!-- Basic Information -->
        <MudItem xs="12" md="8">
            <div class="dc-card">
                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Basic Information</h3>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Drug Name</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.Name</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Generic Name</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.GenericName</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Category</MudText>
                        <div class="mb-4">
                            <span class="dc-badge tw:bg-info/10 tw:text-info">@_drug.Category</span>
                        </div>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Manufacturer</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.Manufacturer</MudText>
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Description</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@(_drug.Description ?? "No description available")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Dosage Form</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.DosageForm</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Strength</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.Strength</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pack Size</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.PackSize</MudText>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Pricing</h3>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Retail Price</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">SSP @_drug.RetailPrice.ToString("N2")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Wholesale Price</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Info">SSP @_drug.WholesalePrice.ToString("N2")</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Cost Price</MudText>
                        <MudText Typo="Typo.h6">SSP @_drug.CostPrice.ToString("N2")</MudText>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-6">Stock Settings</h3>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Reorder Level</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.ReorderLevel units</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Max Stock Level</MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">@_drug.MaxStockLevel units</MudText>
                    </MudItem>
                </MudGrid>
            </div>
        </MudItem>

        <!-- Side Panel -->
        <MudItem xs="12" md="4">
            <!-- Status Card -->
            <div class="dc-card tw:mb-4">
                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-4">Status</h3>
                <div class="tw:flex tw:flex-col tw:gap-2">
                    <div class="tw:flex tw:justify-between tw:items-center">
                        <span class="tw:text-sm tw:text-text-secondary">Active</span>
                        <span class="dc-badge @(_drug.IsActive ? "tw:bg-success/10 tw:text-success" : "")">
                            @(_drug.IsActive ? "Yes" : "No")
                        </span>
                    </div>
                    <div class="tw:flex tw:justify-between tw:items-center">
                        <span class="tw:text-sm tw:text-text-secondary">Requires Prescription</span>
                        <span class="dc-badge @(_drug.RequiresPrescription ? "tw:bg-warning/10 tw:text-warning" : "")">
                            @(_drug.RequiresPrescription ? "Yes" : "No")
                        </span>
                    </div>
                    <div class="tw:flex tw:justify-between tw:items-center">
                        <span class="tw:text-sm tw:text-text-secondary">Controlled Substance</span>
                        <span class="dc-badge @(_drug.IsControlled ? "tw:bg-danger/10 tw:text-danger" : "")">
                            @(_drug.IsControlled ? "Yes" : "No")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Stock Summary Card -->
            <div class="dc-card tw:mb-4">
                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-4">Current Stock</h3>
                <div class="tw:text-center tw:p-4">
                    <div class="tw:text-5xl tw:font-bold tw:font-display @(_currentStock <= _drug.ReorderLevel ? "tw:text-warning" : "tw:text-success")">@_currentStock</div>
                    <div class="tw:text-sm tw:text-text-secondary tw:mt-2">units in stock</div>
                </div>
                @if (_currentStock <= _drug.ReorderLevel)
                {
                    <div class="tw:bg-warning/5 tw:border tw:border-warning/20 tw:rounded-xl tw:p-4 tw:flex tw:items-start tw:gap-3 tw:mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                        <span>Stock below reorder level</span>
                    </div>
                }
            </div>

            <!-- Quick Actions -->
            <div class="dc-card">
                <h3 class="tw:text-lg tw:font-semibold tw:text-text tw:font-display tw:mb-4">Quick Actions</h3>
                <div class="tw:flex tw:flex-col tw:gap-2">
                    <a href="@($"/batches?drugId={Id}")" class="dc-btn-secondary tw:w-full tw:justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                        <span>View Batches</span>
                    </a>
                    <a href="@($"/inventory/movements?drugId={Id}")" class="dc-btn-secondary tw:w-full tw:justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" />
                        <span>View Stock History</span>
                    </a>
                    <a href="@($"/inventory/adjustments/new?drugId={Id}")" class="dc-btn-secondary tw:w-full tw:justify-center">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                        <span>Adjust Stock</span>
                    </a>
                </div>
            </div>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private DrugDetailsDto _drug = new();
    private int _currentStock = 0;
    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override void OnInitialized()
    {
        LoadDrug();
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new("Home", href: "/"),
            new("Drugs", href: "/drugs"),
            new(_drug.Name, href: null, disabled: true)
        };
    }

    private void LoadDrug()
    {
        // Sample data - would come from database in real app
        _drug = new DrugDetailsDto
        {
            Id = Id,
            Code = "PARA500",
            Name = "Paracetamol 500mg",
            GenericName = "Paracetamol",
            Description = "Pain reliever and fever reducer",
            Category = "Analgesics",
            Manufacturer = "GSK",
            DosageForm = "Tablet",
            Strength = "500mg",
            PackSize = "Pack of 10",
            RetailPrice = 5.00m,
            WholesalePrice = 3.50m,
            CostPrice = 2.50m,
            ReorderLevel = 100,
            MaxStockLevel = 1000,
            RequiresPrescription = false,
            IsControlled = false,
            IsActive = true
        };
        _currentStock = 450;
    }

    private Color GetStockColor()
    {
        if (_currentStock == 0) return Color.Error;
        if (_currentStock <= _drug.ReorderLevel) return Color.Warning;
        return Color.Success;
    }

    private class DrugDetailsDto
    {
        public int Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? GenericName { get; set; }
        public string? Description { get; set; }
        public string Category { get; set; } = string.Empty;
        public string? Manufacturer { get; set; }
        public string? DosageForm { get; set; }
        public string? Strength { get; set; }
        public string? PackSize { get; set; }
        public decimal RetailPrice { get; set; }
        public decimal WholesalePrice { get; set; }
        public decimal CostPrice { get; set; }
        public int ReorderLevel { get; set; }
        public int MaxStockLevel { get; set; }
        public bool RequiresPrescription { get; set; }
        public bool IsControlled { get; set; }
        public bool IsActive { get; set; }
    }
}
