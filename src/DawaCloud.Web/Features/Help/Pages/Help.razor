@page "/help"
@using MudBlazor

<PageTitle>Help & Support - DawaCloud</PageTitle>

<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Help & Support</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Frequently asked questions and user guides</p>
        </div>
    </div>
</div>

<MudGrid Class="mt-4" Spacing="6">
    <MudItem xs="12" md="8">
        <div class="dc-card animate-fade-in-up animate-delay-1">
        <MudText Typo="Typo.h6" Class="mb-3">Getting Started</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How do I add a new drug to the system?">
                <MudText>
                    Go to <strong>Drugs &rarr; New Drug</strong> or use the quick action on the dashboard.
                    Fill in the drug name, generic name, category, pricing and stock information, then click Save.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I receive stock from a supplier?">
                <MudText>
                    Navigate to <strong>Procurement &rarr; Goods Receipt &rarr; New Receipt</strong>.
                    Select the supplier, enter the GRN number, and add the drugs received with batch numbers and expiry dates.
                    Click "Post to Inventory" to update stock levels.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I create a drug request?">
                <MudText>
                    Go to <strong>Procurement &rarr; Drug Requests &rarr; New Request</strong>.
                    Select a supplier, add the drugs you need, and submit for approval.
                    The system will notify the supplier via Email or WhatsApp once approved.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Inventory Management</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How does batch tracking work?">
                <MudText>
                    Every drug is tracked by batch with a batch number, manufacture date, and expiry date.
                    The system enforces <strong>FEFO (First Expiry, First Out)</strong> — batches expiring soonest are sold first.
                    You can view all batches under <strong>Drugs &rarr; Batches</strong>.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I do a stock adjustment?">
                <MudText>
                    Go to <strong>Inventory &rarr; Stock Adjustment</strong>, select the drug and batch,
                    choose Add or Remove, enter the quantity and reason, then save.
                    All adjustments are logged in the audit trail.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="What are expiry alerts?">
                <MudText>
                    The system automatically alerts you when drugs are approaching expiry:
                    <ul>
                        <li>90 days — first warning</li>
                        <li>60 days — email notification</li>
                        <li>30 days — urgent alert (Email + WhatsApp)</li>
                    </ul>
                    You can customize these thresholds in <strong>Settings &rarr; Alert Thresholds</strong>.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Point of Sale (POS)</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How do I process a retail sale?">
                <MudText>
                    Open the <strong>POS</strong> module, search or scan the drug barcode to add it to the cart.
                    When done, click <strong>PAY</strong>, select the payment method (Cash / MoMo / Card), and complete the sale.
                    A receipt is generated automatically.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I apply a discount?">
                <MudText>
                    In the POS cart, click the <strong>Discount</strong> button.
                    You can enter a percentage (e.g., 10%) or a fixed amount (e.g., SSP 50).
                    The discount is applied to the subtotal before tax.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Can I put a sale on hold?">
                <MudText>
                    Yes — click the <strong>Hold (F4)</strong> button to save the current cart.
                    Use <strong>Recall (F5)</strong> to retrieve it later. This is useful when serving multiple customers.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Wholesale</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How do I create a wholesale sale?">
                <MudText>
                    Go to <strong>Wholesale &rarr; New Sale</strong>, select the customer, add drugs with quantities,
                    apply any discounts, and save. An invoice is automatically generated.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do credit limits work?">
                <MudText>
                    Each wholesale customer has a credit limit set in their profile.
                    The system warns you if a sale would exceed their credit limit.
                    You can record payments under the customer's outstanding invoices.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Reports</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="What reports are available?">
                <MudText>
                    DawaCloud includes: Stock Reports, Expiry Reports, Sales Reports (daily/weekly/monthly),
                    Supplier Reports, Expense Reports, Financial Reports (P&amp;L, receivables), and Compliance Reports.
                    All reports can be exported to Excel or PDF.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I export reports?">
                <MudText>
                    After generating any report, click the <strong>Export to Excel</strong> or <strong>Export to PDF</strong> button
                    at the top of the report. The file will be downloaded automatically to your device.
                    PDF exports include your company logo and branding.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Expense Management</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How do I track business expenses?">
                <MudText>
                    Navigate to <strong>Expenses &rarr; New Expense</strong> to record business expenses.
                    Select a category, enter the amount, payment method, and vendor details.
                    You can attach receipt photos for documentation.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Can I set up recurring expenses?">
                <MudText>
                    Yes! When creating an expense, toggle <strong>Recurring</strong> and configure the frequency:
                    <ul>
                        <li>Daily, Weekly, Monthly, or Yearly</li>
                        <li>Specify which days (for weekly expenses)</li>
                        <li>Set an end date or occurrence count</li>
                    </ul>
                    The system will automatically generate future expense records.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do expense budgets work?">
                <MudText>
                    Set budget limits for expense categories in <strong>Settings &rarr; Expense Categories</strong>.
                    When creating an expense, the system will warn you if it exceeds the category budget.
                    View budget vs actual spending in the <strong>Budget vs Actual</strong> expense report.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">AI Assistant</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="What can the AI Assistant help with?">
                <MudText>
                    The AI Chat feature (powered by Claude) can answer questions about:
                    <ul>
                        <li>Drug information and interactions</li>
                        <li>How to use DawaCloud features</li>
                        <li>Inventory management best practices</li>
                        <li>Pharmaceutical regulations and compliance</li>
                        <li>Business insights and recommendations</li>
                    </ul>
                    Access it via the <strong>AI Chat</strong> icon in the navigation menu.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I enable AI Chat?">
                <MudText>
                    AI Chat must be configured in <strong>Settings &rarr; AI Assistant</strong>.
                    Enter your Anthropic API key, select the Claude model (Haiku, Sonnet, or Opus),
                    and test the connection. Contact support if you need assistance obtaining an API key.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <MudText Typo="Typo.h6" Class="mb-3 mt-6">Security & Compliance</MudText>
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Text="How is my data secured?">
                <MudText>
                    DawaCloud uses industry-standard security measures:
                    <ul>
                        <li>Encrypted database connections (TLS/SSL)</li>
                        <li>Role-based access control (RBAC)</li>
                        <li>Complete audit trail of all actions</li>
                        <li>Regular automated backups</li>
                        <li>Session management and timeout</li>
                    </ul>
                    View audit logs in <strong>Audit &rarr; Activity Logs</strong>.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="Can I track controlled drugs?">
                <MudText>
                    Yes — mark drugs as <strong>Controlled</strong> when creating them.
                    All movements of controlled drugs are logged with full traceability.
                    Generate controlled drugs reports from <strong>Reports &rarr; Compliance Reports</strong>.
                </MudText>
            </MudExpansionPanel>
            <MudExpansionPanel Text="How do I manage user permissions?">
                <MudText>
                    Go to <strong>Settings &rarr; Users &rarr; Edit User</strong> to assign roles:
                    <ul>
                        <li><strong>Admin</strong> — full system access</li>
                        <li><strong>Manager</strong> — manage operations, view reports</li>
                        <li><strong>Pharmacist</strong> — POS, dispensing, inventory</li>
                        <li><strong>Cashier</strong> — POS only</li>
                    </ul>
                    Create custom roles with specific permissions as needed.
                </MudText>
            </MudExpansionPanel>
        </MudExpansionPanels>
        </div>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-4 dc-card animate-fade-in-up animate-delay-2">
            <MudText Typo="Typo.h6" Class="mb-3">Quick Tips</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Keyboard">
                    <strong>Ctrl+K</strong> opens the command palette
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Keyboard">
                    <strong>F2</strong> focuses the POS search bar
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Keyboard">
                    <strong>F4/F5</strong> hold and recall sales in POS
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Keyboard">
                    <strong>F12</strong> processes payment in POS
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.QrCodeScanner">
                    Barcode scanners work automatically in POS search
                </MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Elevation="0" Class="pa-4 mt-4 dc-card animate-fade-in-up animate-delay-3">
            <MudText Typo="Typo.h6" Class="mb-3">Contact Support</MudText>
            <MudText Typo="Typo.body2">
                <strong>Guru Brothers Ltd</strong>
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" /> info@revopharma.com
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" /> +211 920 123456
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Web" Size="Size.Small" /> www.revopharma.com
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>
