@page "/inventory/stock-counts/{id:int}/count"
@using MediatR
@using MudBlazor
@using DawaCloud.Web.Features.Inventory.Queries
@using DawaCloud.Web.Features.Inventory.Commands
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_stockCount == null)
    {
        <MudAlert Severity="Severity.Error">Stock count not found</MudAlert>
    }
    else
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <div>
                    <MudText Typo="Typo.h5">@_stockCount.ReferenceNumber</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Count Date: @_stockCount.CountDate.ToString("dd MMM yyyy HH:mm")
                    </MudText>
                </div>
                <div>
                    <MudChip T="string" Color="@GetStatusColor()" Size="Size.Large">
                        @_stockCount.Status
                    </MudChip>
                </div>
            </div>

            <MudText Typo="Typo.body2" Class="mb-2">
                Progress: @_stockCount.TotalItemsCounted / @_stockCount.TotalItems items counted (@GetProgressPercentage()%)
            </MudText>
            <MudProgressLinear Color="Color.Primary" Value="@GetProgressValue()" Class="mb-2" />

            @if (_stockCount.ItemsWithVariance > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    @_stockCount.ItemsWithVariance items with variance. Total variance value: SSP @_stockCount.TotalVarianceValue.ToString("N2")
                </MudAlert>
            }
        </MudPaper>

        <MudPaper Elevation="2" Class="pa-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6">Items to Count</MudText>

                @if (_isInProgress)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="CompleteCount"
                               Disabled="@_processing"
                               StartIcon="@Icons.Material.Filled.CheckCircle">
                        Complete Count
                    </MudButton>
                }
            </div>

            <MudTextField @bind-Value="_searchText"
                          Placeholder="Search drugs..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Class="mb-4" />

            <MudTable Items="@GetFilteredItems()" Dense="true" Hover="true" Striped="true">
                <HeaderContent>
                    <MudTh>Drug</MudTh>
                    <MudTh>Batch</MudTh>
                    <MudTh Style="text-align: right">System Qty</MudTh>
                    <MudTh Style="text-align: right">Physical Qty</MudTh>
                    <MudTh Style="text-align: right">Variance</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Drug">
                        <div>
                            <MudText Typo="Typo.body2">@context.DrugName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DrugCode</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Batch">@context.BatchNumber</MudTd>
                    <MudTd DataLabel="System Qty" Style="text-align: right">@context.SystemQuantity</MudTd>
                    <MudTd DataLabel="Physical Qty" Style="text-align: right">
                        @if (_isInProgress && _editingItemId == context.Id)
                        {
                            <MudNumericField @bind-Value="_editingQuantity"
                                             Min="0"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             HideSpinButtons="false" />
                        }
                        else
                        {
                            <span>@context.PhysicalQuantity</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Variance" Style="text-align: right">
                        <MudText Typo="Typo.body2" Color="@GetVarianceColor(context.Variance)">
                            @context.Variance.ToString("+0;-0;0")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsCounted)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Counted</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">Pending</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        @if (_isInProgress)
                        {
                            @if (_editingItemId == context.Id)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Check"
                                               Color="Color.Success"
                                               Size="Size.Small"
                                               OnClick="@(() => SaveCount(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               OnClick="CancelEdit" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => StartEdit(context))" />
                            }
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int Id { get; set; }

    private StockCountDetailsDto? _stockCount;
    private bool _loading = true;
    private bool _processing = false;
    private bool _isInProgress => _stockCount?.Status == "InProgress";

    private int? _editingItemId;
    private int _editingQuantity;

    private string _searchText = string.Empty;

    private List<StockCountItemDto> GetFilteredItems()
    {
        if (_stockCount == null)
            return new List<StockCountItemDto>();

        var items = _stockCount.Items.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            items = items.Where(i =>
                i.DrugName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                i.DrugCode.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                i.BatchNumber.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
        }

        return items.ToList();
    }

    private double GetProgressValue()
    {
        if (_stockCount == null || _stockCount.TotalItems == 0)
            return 0;

        return (_stockCount.TotalItemsCounted * 100.0 / _stockCount.TotalItems);
    }

    private string GetProgressPercentage()
    {
        return GetProgressValue().ToString("N1");
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadStockCount();
    }

    private async Task LoadStockCount()
    {
        _loading = true;
        try
        {
            _stockCount = await Mediator.Send(new GetStockCountDetailsQuery(Id));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading stock count: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartEdit(StockCountItemDto item)
    {
        _editingItemId = item.Id;
        _editingQuantity = item.PhysicalQuantity;
    }

    private void CancelEdit()
    {
        _editingItemId = null;
        _editingQuantity = 0;
    }

    private async Task SaveCount(StockCountItemDto item)
    {
        try
        {
            var command = new UpdateStockCountItemCommand(
                item.Id,
                _editingQuantity
            );

            var result = await Mediator.Send(command);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                _editingItemId = null;
                await LoadStockCount();
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving count: {ex.Message}", Severity.Error);
        }
    }

    private async Task CompleteCount()
    {
        _processing = true;
        StateHasChanged();

        try
        {
            var command = new CompleteStockCountCommand(Id, AutoAdjust: true);
            var commandResult = await Mediator.Send(command);

            if (commandResult.Success)
            {
                Snackbar.Add(commandResult.Message, Severity.Success);
                Navigation.NavigateTo("/inventory/stock-counts");
            }
            else
            {
                Snackbar.Add(commandResult.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error completing stock count: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private Color GetStatusColor()
    {
        if (_stockCount == null)
            return Color.Default;

        return _stockCount.Status switch
        {
            "InProgress" => Color.Info,
            "Completed" => Color.Success,
            "Cancelled" => Color.Error,
            _ => Color.Default
        };
    }

    private Color GetVarianceColor(int variance)
    {
        if (variance < 0)
            return Color.Error;
        else if (variance > 0)
            return Color.Warning;
        else
            return Color.Default;
    }
}
