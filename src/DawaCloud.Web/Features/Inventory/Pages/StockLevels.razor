@page "/inventory"
@page "/inventory/stock-levels"
@using MudBlazor
@using Microsoft.JSInterop
@using ClosedXML.Excel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@using DawaCloud.Web.Features.Inventory.Queries
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Stock Levels - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6">
    <div class="tw:flex tw:flex-wrap tw:items-start tw:justify-between tw:gap-4">
        <div>
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:mb-1 tw:font-display">Stock Levels</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0">Real-time inventory quantities across all batches</p>
        </div>
        <div class="tw:flex tw:items-center tw:gap-3">
            <button class="dc-btn-secondary" @onclick="ExportToExcel">
                <MudIcon Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" />
                <span>Export</span>
            </button>
            <a href="/inventory/adjustments/new" class="dc-btn-primary">
                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                <span>Stock Adjustment</span>
            </a>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:mb-6">
    <div class="dc-kpi tw:animate-slide-up">
        <div class="dc-icon-box tw:bg-accent-50 tw:text-accent-500">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Medium" />
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Total SKUs</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_stockItems.Count</div>
    </div>
    <div class="dc-kpi tw:animate-slide-up" style="animation-delay: 0.05s;">
        <div class="dc-icon-box tw:bg-warning/10 tw:text-warning">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Medium" />
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Low Stock</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_stockItems.Count(s => s.StockLevel == "Low")</div>
    </div>
    <div class="dc-kpi tw:animate-slide-up" style="animation-delay: 0.1s;">
        <div class="dc-icon-box tw:bg-danger/10 tw:text-danger">
            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Medium" />
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Out of Stock</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_stockItems.Count(s => s.StockLevel == "Out")</div>
    </div>
    <div class="dc-kpi tw:animate-slide-up" style="animation-delay: 0.15s;">
        <div class="dc-icon-box tw:bg-primary-50 tw:text-primary-600">
            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Medium" />
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Stock Value</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_stockItems.Sum(s => s.TotalValue).ToString("N0")</div>
    </div>
</div>

<!-- Filters and Table -->
<div class="dc-card">
    <div class="tw:flex tw:flex-wrap tw:justify-between tw:items-center tw:gap-4 tw:mb-6">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by drug name or code..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 400px;" />

        <div class="tw:flex tw:gap-2">
            <MudSelect T="string" @bind-Value="_selectedCategory" Label="Category" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Categories</MudSelectItem>
                <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                <MudSelectItem Value="@("Cardiovascular")">Cardiovascular</MudSelectItem>
            </MudSelect>

            <MudSelect T="string" @bind-Value="_selectedStockLevel" Label="Stock Level" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Levels</MudSelectItem>
                <MudSelectItem Value="@("Good")">Good Stock</MudSelectItem>
                <MudSelectItem Value="@("Low")">Low Stock</MudSelectItem>
                <MudSelectItem Value="@("Out")">Out of Stock</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <!-- Stock Table -->
    <MudTable T="StockLevelDto" Items="@FilteredItems" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading">
        <HeaderContent>
            <MudTh>Drug</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Available</MudTh>
            <MudTh>Reserved</MudTh>
            <MudTh>Reorder Level</MudTh>
            <MudTh>Total Value</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Drug">
                <div>
                    <MudText Typo="Typo.body2" Class="tw:font-semibold">@context.DrugName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DrugCode</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Category">@context.Category</MudTd>
            <MudTd DataLabel="Available">
                <MudText Typo="Typo.body2">@context.AvailableQuantity @context.Unit</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.BatchCount batches</MudText>
            </MudTd>
            <MudTd DataLabel="Reserved">@context.ReservedQuantity @context.Unit</MudTd>
            <MudTd DataLabel="Reorder Level">@context.ReorderLevel</MudTd>
            <MudTd DataLabel="Total Value">SSP @context.TotalValue.ToString("N2")</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStockLevelColor(context.StockLevel)">@context.StockLevel</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudTooltip Text="View Movements"><MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Info" Href="@($"/inventory/movements?drugId={context.DrugId}")" /></MudTooltip>
                <MudTooltip Text="Adjust Stock"><MudIconButton Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Default" Href="@($"/inventory/adjustments/new?drugId={context.DrugId}")" /></MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    private List<StockLevelDto> _stockItems = new();
    private string _searchString = string.Empty;
    private string _selectedCategory = "All";
    private string _selectedStockLevel = "All";
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStockLevels();
    }

    private async Task LoadStockLevels()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _stockItems = await Mediator.Send(new GetStockLevelsQuery());
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading stock levels: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<StockLevelDto> FilteredItems =>
        _stockItems.Where(s =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             s.DrugName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             s.DrugCode.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedCategory == "All" || s.Category == _selectedCategory) &&
            (_selectedStockLevel == "All" || s.StockLevel == _selectedStockLevel)
        );

    private Color GetStockLevelColor(string level) => level switch
    {
        "Good" => Color.Success,
        "Low" => Color.Warning,
        "Out" => Color.Error,
        _ => Color.Default
    };

    private async Task ExportToExcel()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var worksheet = workbook.Worksheets.Add("Stock Levels");

            // Add headers
            worksheet.Cell(1, 1).Value = "Drug Code";
            worksheet.Cell(1, 2).Value = "Drug Name";
            worksheet.Cell(1, 3).Value = "Category";
            worksheet.Cell(1, 4).Value = "Available Quantity";
            worksheet.Cell(1, 5).Value = "Reserved Quantity";
            worksheet.Cell(1, 6).Value = "Reorder Level";
            worksheet.Cell(1, 7).Value = "Total Value (SSP)";
            worksheet.Cell(1, 8).Value = "Stock Level";

            // Style headers
            var headerRange = worksheet.Range(1, 1, 1, 8);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = XLColor.LightBlue;
            headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

            // Add data rows
            int row = 2;
            foreach (var item in FilteredItems)
            {
                worksheet.Cell(row, 1).Value = item.DrugCode;
                worksheet.Cell(row, 2).Value = item.DrugName;
                worksheet.Cell(row, 3).Value = item.Category;
                worksheet.Cell(row, 4).Value = item.AvailableQuantity;
                worksheet.Cell(row, 5).Value = item.ReservedQuantity;
                worksheet.Cell(row, 6).Value = item.ReorderLevel;
                worksheet.Cell(row, 7).Value = item.TotalValue;
                worksheet.Cell(row, 8).Value = item.StockLevel;

                // Color code rows based on stock level
                var rowRange = worksheet.Range(row, 1, row, 8);
                if (item.StockLevel == "Out")
                    rowRange.Style.Font.FontColor = XLColor.Red;
                else if (item.StockLevel == "Low")
                    rowRange.Style.Font.FontColor = XLColor.Orange;

                row++;
            }

            // Auto-fit columns
            worksheet.Columns().AdjustToContents();

            // Convert to base64
            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());

            // Download via JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile",
                $"stock-levels-{DateTime.UtcNow:yyyyMMdd-HHmmss}.xlsx",
                base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            Snackbar.Add($"Exported {FilteredItems.Count()} stock items successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting: {ex.Message}", Severity.Error);
        }
    }
}
