@page "/supplier/dashboard"
@using MudBlazor

<PageTitle>Supplier Dashboard - DawaCloud</PageTitle>

<!-- Welcome Section -->
<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Welcome, MedSupply Ltd</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Supplier Portal Dashboard</p>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi animate-fade-in-up animate-delay-1">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Pending Requests</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">5</div>
        <div class="tw:text-xs tw:text-text-secondary tw:mt-1">Awaiting your response</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-2">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning/10">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Style="color: var(--tw-color-warning);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">In Transit</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">3</div>
        <div class="tw:text-xs tw:text-text-secondary tw:mt-1">Deliveries pending</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-3">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-success/10">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-success);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Delivered This Month</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">12</div>
        <div class="tw:text-xs tw:text-text-secondary tw:mt-1">Orders completed</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-4">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-info/10">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color: var(--tw-color-info);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">This Month's Value</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP 850K</div>
        <div class="tw:text-xs tw:text-text-secondary tw:mt-1">Total order value</div>
    </div>
</div>

<!-- Pending Requests -->
<MudGrid Class="mt-4">
    <MudItem xs="12" lg="8">
        <div class="dc-card animate-fade-in-up animate-delay-2">
            <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
                <div class="tw:flex tw:items-center tw:gap-3">
                    <div class="dc-icon-box tw:bg-warning/10">
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Style="color: var(--tw-color-warning);" />
                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:m-0 tw:font-display">Pending Drug Requests</span>
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/supplier/requests">
                    View All
                </MudButton>
            </div>
            <MudTable T="RequestDto" Items="@_pendingRequests" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Request #</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Items</MudTh>
                    <MudTh>Est. Value</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.RequestNumber</MudTd>
                    <MudTd>@context.RequestDate.ToString("dd MMM yyyy")</MudTd>
                    <MudTd>@context.ItemCount items</MudTd>
                    <MudTd>SSP @context.EstimatedValue.ToString("N0")</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" Href="@($"/supplier/requests/{context.Id}")">
                            Respond
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    </MudItem>

    <MudItem xs="12" lg="4">
        <!-- Recent Activity -->
        <div class="dc-card animate-fade-in-up animate-delay-3">
            <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
                <div class="tw:flex tw:items-center tw:gap-3">
                    <div class="dc-icon-box tw:bg-info/10">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Style="color: var(--tw-color-info);" />
                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:m-0 tw:font-display">Recent Activity</span>
                </div>
            </div>
            <MudTimeline TimelinePosition="TimelinePosition.Start">
                @foreach (var activity in _recentActivity)
                {
                    <MudTimelineItem Color="@activity.Color" Size="Size.Small">
                        <MudText Typo="Typo.body2">@activity.Description</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@activity.Time</MudText>
                    </MudTimelineItem>
                }
            </MudTimeline>
        </div>

        <!-- Contact Info -->
        <div class="dc-card animate-fade-in-up animate-delay-4 mt-4">
            <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
                <div class="tw:flex tw:items-center tw:gap-3">
                    <div class="dc-icon-box tw:bg-primary-50">
                        <MudIcon Icon="@Icons.Material.Filled.ContactSupport" Style="color: var(--tw-color-primary-600);" />
                    </div>
                    <span class="tw:text-lg tw:font-semibold tw:text-text tw:m-0 tw:font-display">Need Help?</span>
                </div>
            </div>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Email">
                    <MudText Typo="Typo.body2">procurement@DawaCloud.com</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Phone">
                    <MudText Typo="Typo.body2">+211 920 123 456</MudText>
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Chat">
                    <MudText Typo="Typo.body2">+211 920 123 456</MudText>
                </MudListItem>
            </MudList>
        </div>
    </MudItem>
</MudGrid>

@code {
    private List<RequestDto> _pendingRequests = new();
    private List<ActivityItem> _recentActivity = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        _pendingRequests = new List<RequestDto>
        {
            new() { Id = 1, RequestNumber = "REQ-2024-0045", RequestDate = DateTime.UtcNow.AddDays(-1), ItemCount = 8, EstimatedValue = 125000, Status = "Pending" },
            new() { Id = 2, RequestNumber = "REQ-2024-0044", RequestDate = DateTime.UtcNow.AddDays(-2), ItemCount = 5, EstimatedValue = 85000, Status = "Pending" },
            new() { Id = 3, RequestNumber = "REQ-2024-0043", RequestDate = DateTime.UtcNow.AddDays(-3), ItemCount = 12, EstimatedValue = 230000, Status = "Awaiting Confirmation" },
            new() { Id = 4, RequestNumber = "REQ-2024-0042", RequestDate = DateTime.UtcNow.AddDays(-4), ItemCount = 3, EstimatedValue = 45000, Status = "Pending" },
            new() { Id = 5, RequestNumber = "REQ-2024-0041", RequestDate = DateTime.UtcNow.AddDays(-5), ItemCount = 6, EstimatedValue = 95000, Status = "Pending" },
        };

        _recentActivity = new List<ActivityItem>
        {
            new() { Description = "Delivery confirmed for REQ-2024-0038", Time = "2 hours ago", Color = Color.Success },
            new() { Description = "New request received REQ-2024-0045", Time = "1 day ago", Color = Color.Info },
            new() { Description = "Payment received for INV-2024-0125", Time = "2 days ago", Color = Color.Primary },
            new() { Description = "Delivery note uploaded for REQ-2024-0039", Time = "3 days ago", Color = Color.Success },
            new() { Description = "Request accepted REQ-2024-0040", Time = "4 days ago", Color = Color.Warning },
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Awaiting Confirmation" => Color.Info,
        "Confirmed" => Color.Success,
        "In Transit" => Color.Primary,
        _ => Color.Default
    };

    private class RequestDto
    {
        public int Id { get; set; }
        public string RequestNumber { get; set; } = string.Empty;
        public DateTime RequestDate { get; set; }
        public int ItemCount { get; set; }
        public decimal EstimatedValue { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private class ActivityItem
    {
        public string Description { get; set; } = string.Empty;
        public string Time { get; set; } = string.Empty;
        public Color Color { get; set; }
    }
}
