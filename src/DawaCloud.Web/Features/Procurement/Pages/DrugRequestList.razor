@page "/procurement/requests"
@using MudBlazor
@using DawaCloud.Web.Features.Procurement.Queries
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@using DawaCloud.Web.Data.Entities
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Drug Requests - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Drug Requests</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Procurement requests and supplier orders</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/procurement/requests/new">
            New Request
        </MudButton>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi animate-fade-in-up animate-delay-1">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning-50">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Style="color: var(--tw-color-warning-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Pending Approval</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_requests.Count(r => r.Status == "PendingApproval")</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-2">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-success-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-success-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Approved</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_requests.Count(r => r.Status == "Approved")</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-3">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-info-50">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Style="color: var(--tw-color-info-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">In Transit</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_requests.Count(r => r.Status == "SentToSupplier" || r.Status == "SupplierConfirmed")</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-4">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.Receipt" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Total Value</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_requests.Sum(r => r.TotalAmount).ToString("N0")</div>
    </div>
</div>

<!-- Requests Table -->
<div class="dc-card animate-fade-in-up animate-delay-2 tw:mt-4">
    <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
        <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status Filter" Variant="Variant.Outlined" Dense="true" Style="max-width: 250px;" OnSelectedValuesChanged="@((IEnumerable<string> _) => LoadRequests())">
            <MudSelectItem Value="@("All")">All Status</MudSelectItem>
            <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
            <MudSelectItem Value="@("PendingApproval")">Pending Approval</MudSelectItem>
            <MudSelectItem Value="@("Approved")">Approved</MudSelectItem>
            <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            <MudSelectItem Value="@("SentToSupplier")">Sent to Supplier</MudSelectItem>
            <MudSelectItem Value="@("SupplierConfirmed")">Supplier Confirmed</MudSelectItem>
            <MudSelectItem Value="@("Delivered")">Delivered</MudSelectItem>
            <MudSelectItem Value="@("Completed")">Completed</MudSelectItem>
        </MudSelect>
    </div>

    <MudTable T="DrugRequestSummaryDto" Items="@_requests" Dense="true" Hover="true" Loading="@_loading" Class="mt-4">
            <HeaderContent>
                <MudTh>Request #</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Supplier</MudTh>
                <MudTh>Items</MudTh>
                <MudTh>Total Amount</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Approved By</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Request #">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.RequestNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Date">@context.RequestDate.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Supplier">@context.SupplierName</MudTd>
                <MudTd DataLabel="Items">@context.ItemCount items</MudTd>
                <MudTd DataLabel="Total Amount">SSP @context.TotalAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                        @FormatStatus(context.Status)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Approved By">
                    @if (!string.IsNullOrEmpty(context.ApprovedBy))
                    {
                        <div>
                            <MudText Typo="Typo.body2">@context.ApprovedBy</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ApprovedAt?.ToString("dd MMM HH:mm")</MudText>
                        </div>
                    }
                    else
                    {
                        <MudText Color="Color.Secondary">-</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Href="@($"/procurement/requests/{context.Id}")"
                                   Title="View Details" />
                    @if (context.Status == "PendingApproval")
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Check"
                                       Size="Size.Small"
                                       Color="Color.Success"
                                       Title="Approve" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

@code {
    private List<DrugRequestSummaryDto> _requests = new();
    private string _selectedStatus = "All";
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            DrugRequestStatus? status = _selectedStatus != "All" ? Enum.Parse<DrugRequestStatus>(_selectedStatus) : null;
            _requests = await Mediator.Send(new GetDrugRequestsQuery(Status: status));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading drug requests: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "PendingApproval" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "SentToSupplier" => Color.Info,
        "SupplierConfirmed" => Color.Primary,
        "Delivered" => Color.Success,
        "Completed" => Color.Success,
        _ => Color.Default
    };

    private string FormatStatus(string status) => status switch
    {
        "PendingApproval" => "Pending Approval",
        "SentToSupplier" => "Sent to Supplier",
        "SupplierConfirmed" => "Supplier Confirmed",
        "PartiallyDelivered" => "Partially Delivered",
        _ => status
    };
}
