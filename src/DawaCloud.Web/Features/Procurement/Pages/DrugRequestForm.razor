@page "/procurement/requests/new"
@page "/procurement/requests/{Id:int}"
@using MudBlazor
@using MediatR
@using DawaCloud.Web.Data
@using DawaCloud.Web.Features.Procurement.Commands
@using DawaCloud.Web.Features.Procurement.Components
@using DawaCloud.Web.Features.Drugs.Queries
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IMediator Mediator
@inject IServiceScopeFactory ScopeFactory
@inject IDialogService DialogService

<PageTitle>@(_isViewMode ? "Request Details" : "New Drug Request") - DawaCloud</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="mb-4" />

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="mb-1">@(_isViewMode ? $"Request #{_request.RequestNumber}" : "New Drug Request")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_isViewMode ? "View request details" : "Create a new procurement request")
            </MudText>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/procurement/requests">
                Back to List
            </MudButton>
            @if (_isViewMode && _request.Status == "PendingApproval")
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Check"
                           OnClick="ApproveRequest">
                    Approve
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="RejectRequest">
                    Reject
                </MudButton>
            }
        </div>
    </div>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6">
                @if (_isViewMode)
                {
                    <!-- View Mode -->
                    <MudText Typo="Typo.h6" Class="mb-4">Request Information</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Request Number</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_request.RequestNumber</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Request Date</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_request.RequestDate.ToString("dd MMM yyyy")</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Supplier</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_request.SupplierName</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_request.Status)">@FormatStatus(_request.Status)</MudChip>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <!-- Create Mode -->
                    <MudForm @ref="_form">
                        <MudText Typo="Typo.h6" Class="mb-4">Request Details</MudText>
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" @bind-Value="_selectedSupplierId" Label="Supplier" Variant="Variant.Outlined" Required="true">
                                    @foreach (var supplier in _suppliers)
                                    {
                                        <MudSelectItem T="int?" Value="@supplier.Id">@supplier.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="_expectedDeliveryDate" Label="Expected Delivery Date" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_notes" Label="Notes" Variant="Variant.Outlined" Lines="2" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                }

                <MudDivider Class="my-4" />

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Request Items</MudText>
                    @if (!_isViewMode)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddItem">
                            Add Item
                        </MudButton>
                    }
                </div>

                <MudTable T="RequestItemDto" Items="_items" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Drug</MudTh>
                        <MudTh>Requested Qty</MudTh>
                        <MudTh>Unit Price</MudTh>
                        <MudTh>Total</MudTh>
                        @if (!_isViewMode)
                        {
                            <MudTh>Actions</MudTh>
                        }
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Drug">@context.DrugName</MudTd>
                        <MudTd DataLabel="Requested Qty">@context.RequestedQuantity</MudTd>
                        <MudTd DataLabel="Unit Price">SSP @context.UnitPrice.ToString("N2")</MudTd>
                        <MudTd DataLabel="Total">SSP @context.TotalAmount.ToString("N2")</MudTd>
                        @if (!_isViewMode)
                        {
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveItem(context))" />
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <!-- Summary Card -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Summary</MudText>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Total Items</MudText>
                        <MudText Typo="Typo.body2" Class="fw-bold">@_items.Count</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Total Quantity</MudText>
                        <MudText Typo="Typo.body2" Class="fw-bold">@_items.Sum(i => i.RequestedQuantity)</MudText>
                    </div>
                    <MudDivider Class="my-2" />
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.subtitle1">Total Amount</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">SSP @_items.Sum(i => i.TotalAmount).ToString("N2")</MudText>
                    </div>
                </div>
            </MudPaper>

            @if (!_isViewMode)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveRequest"
                           Disabled="@(_items.Count == 0)">
                    Submit Request
                </MudButton>
            }
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isViewMode => Id.HasValue;
    private MudForm? _form;
    private RequestDto _request = new();
    private List<RequestItemDto> _items = new();
    private List<SupplierDto> _suppliers = new();
    private List<DrugListDto> _availableDrugs = new();

    private int? _selectedSupplierId;
    private DateTime? _expectedDeliveryDate;
    private string _notes = string.Empty;

    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliersAsync();
        await LoadDrugsAsync();

        if (_isViewMode)
        {
            LoadRequest();
        }

        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new("Home", href: "/"),
            new("Procurement", href: "/procurement/requests"),
            new(_isViewMode ? _request.RequestNumber : "New Request", href: null, disabled: true)
        };
    }

    private async Task LoadSuppliersAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            _suppliers = await db.Suppliers
                .Where(s => s.IsActive)
                .Select(s => new SupplierDto { Id = s.Id, Name = s.Name })
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading suppliers: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadDrugsAsync()
    {
        try
        {
            var query = new GetDrugsQuery(null, null, "Active"); // Load all active drugs
            var result = await Mediator.Send(query);
            _availableDrugs = result.Drugs;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading drugs: {ex.Message}", Severity.Error);
        }
    }

    private void LoadRequest()
    {
        // Sample data
        _request = new RequestDto
        {
            Id = Id ?? 0,
            RequestNumber = "REQ-2024-0015",
            RequestDate = DateTime.Now.AddDays(-2),
            SupplierName = "ABC Pharmaceuticals Ltd",
            Status = "PendingApproval",
            TotalAmount = 125000
        };
        
        _items = new List<RequestItemDto>
        {
            new() { DrugName = "Paracetamol 500mg", RequestedQuantity = 1000, UnitPrice = 3.50m },
            new() { DrugName = "Amoxicillin 250mg", RequestedQuantity = 500, UnitPrice = 12.00m },
            new() { DrugName = "Ibuprofen 400mg", RequestedQuantity = 800, UnitPrice = 4.20m }
        };
    }

    private async Task AddItem()
    {
        var parameters = new DialogParameters
        {
            { "AvailableDrugs", _availableDrugs }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<AddRequestItemDialog>("Add Item to Request", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is AddRequestItemDialog.RequestItemDto requestItem)
        {
            _items.Add(new RequestItemDto
            {
                DrugId = requestItem.DrugId,
                DrugName = requestItem.DrugName,
                RequestedQuantity = requestItem.RequestedQuantity,
                UnitPrice = requestItem.UnitPrice
            });

            Snackbar.Add($"Added {requestItem.DrugName} to request", Severity.Success);
        }
    }

    private void RemoveItem(RequestItemDto item)
    {
        _items.Remove(item);
    }

    private async Task SaveRequest()
    {
        try
        {
            if (!_selectedSupplierId.HasValue || _selectedSupplierId == 0)
            {
                Snackbar.Add("Please select a supplier", Severity.Warning);
                return;
            }
            if (!_items.Any())
            {
                Snackbar.Add("Please add at least one item", Severity.Warning);
                return;
            }
            var itemDtos = _items.Select(i => new DrugRequestItemDto(i.DrugId, i.RequestedQuantity, i.UnitPrice)).ToList();
            var command = new CreateDrugRequestCommand(_selectedSupplierId.Value, _notes, itemDtos);
            var result = await Mediator.Send(command);
            if (result.Success)
            {
                Snackbar.Add("Request submitted successfully", Severity.Success);
                Navigation.NavigateTo("/procurement/requests");
            }
            else
                Snackbar.Add(result.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task ApproveRequest()
    {
        await Task.Delay(500);
        Snackbar.Add("Request approved", Severity.Success);
        Navigation.NavigateTo("/procurement/requests");
    }

    private async Task RejectRequest()
    {
        await Task.Delay(500);
        Snackbar.Add("Request rejected", Severity.Warning);
        Navigation.NavigateTo("/procurement/requests");
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "PendingApproval" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private string FormatStatus(string status) => status switch
    {
        "PendingApproval" => "Pending Approval",
        _ => status
    };

    private class RequestDto
    {
        public int Id { get; set; }
        public string RequestNumber { get; set; } = string.Empty;
        public DateTime RequestDate { get; set; }
        public string SupplierName { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public decimal TotalAmount { get; set; }
    }

    private class RequestItemDto
    {
        public int DrugId { get; set; }
        public string DrugName { get; set; } = string.Empty;
        public int RequestedQuantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalAmount => RequestedQuantity * UnitPrice;
    }

    private class SupplierDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
