@using MudBlazor
@using DawaCloud.Web.Features.Drugs.Queries
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudAutocomplete T="DrugListDto"
                                 @bind-Value="_selectedDrug"
                                 Label="Select Drug"
                                 Variant="Variant.Outlined"
                                 Required="true"
                                 SearchFunc="SearchDrugs"
                                 ToStringFunc="@(d => d?.Name ?? string.Empty)"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true">
                    <ItemTemplate Context="drug">
                        <div>
                            <MudText Typo="Typo.body2">@drug.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @drug.Code | Current Stock: @drug.CurrentStock units
                            </MudText>
                        </div>
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>

            @if (_selectedDrug != null)
            {
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_requestedQuantity"
                                     Label="Requested Quantity"
                                     Variant="Variant.Outlined"
                                     Required="true"
                                     Min="1"
                                     HelperText="Number of units to request" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_unitPrice"
                                     Label="Estimated Unit Price (SSP)"
                                     Variant="Variant.Outlined"
                                     Required="true"
                                     Min="0"
                                     Format="N2"
                                     Adornment="Adornment.Start"
                                     AdornmentText="SSP"
                                     HelperText="Estimated cost per unit" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField Value="@GetTotalAmount()"
                                  Label="Estimated Total Amount"
                                  Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  Adornment="Adornment.Start"
                                  AdornmentText="SSP" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Add Item
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public List<DrugListDto> AvailableDrugs { get; set; } = new();

    private DrugListDto? _selectedDrug;
    private int _requestedQuantity = 1;
    private decimal _unitPrice = 0;

    private async Task<IEnumerable<DrugListDto>> SearchDrugs(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return AvailableDrugs;

        return AvailableDrugs.Where(d =>
            d.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            d.Code.Contains(value, StringComparison.OrdinalIgnoreCase)
        );
    }

    private string GetTotalAmount()
    {
        if (_selectedDrug == null || _requestedQuantity == 0)
            return "0.00";

        var total = _requestedQuantity * _unitPrice;
        return total.ToString("N2");
    }

    private bool CanSubmit()
    {
        return _selectedDrug != null
            && _requestedQuantity > 0
            && _unitPrice >= 0;
    }

    private void Submit()
    {
        if (!CanSubmit())
        {
            Snackbar.Add("Please fill all required fields", Severity.Warning);
            return;
        }

        var requestItem = new RequestItemDto
        {
            DrugId = _selectedDrug!.Id,
            DrugName = _selectedDrug.Name,
            RequestedQuantity = _requestedQuantity,
            UnitPrice = _unitPrice
        };

        MudDialog.Close(DialogResult.Ok(requestItem));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    public class RequestItemDto
    {
        public int DrugId { get; set; }
        public string DrugName { get; set; } = string.Empty;
        public int RequestedQuantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalAmount => RequestedQuantity * UnitPrice;
    }
}
