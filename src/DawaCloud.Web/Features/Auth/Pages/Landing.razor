@page "/welcome"
@using MudBlazor
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager

<PageTitle>DawaCloud | Pharmaceutical Management System</PageTitle>

<div class="landing">
    @* ── Navigation Bar ── *@
    <nav class="landing-nav">
        <div class="landing-nav-inner">
            <div class="landing-brand">
                <div class="landing-brand-icon">
                    <svg viewBox="0 0 48 48" width="36" height="36">
                        <defs>
                            <linearGradient id="lbg" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#0D47A1"/><stop offset="100%" stop-color="#1565C0"/>
                            </linearGradient>
                            <linearGradient id="lcl" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#fff"/><stop offset="100%" stop-color="#E3F2FD"/>
                            </linearGradient>
                            <linearGradient id="lct" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" stop-color="#10B981"/><stop offset="100%" stop-color="#059669"/>
                            </linearGradient>
                        </defs>
                        <rect width="48" height="48" rx="10" fill="url(#lbg)"/>
                        <g transform="translate(24,22)">
                            <ellipse cx="0" cy="3" rx="14" ry="6.5" fill="url(#lcl)" opacity="0.95"/>
                            <circle cx="-7" cy="-1" r="6" fill="url(#lcl)" opacity="0.95"/>
                            <circle cx="2" cy="-4.5" r="7.5" fill="url(#lcl)" opacity="0.95"/>
                            <circle cx="8" cy="-1" r="5.5" fill="url(#lcl)" opacity="0.95"/>
                            <rect x="-14" y="0" width="28" height="9" rx="4.5" fill="url(#lcl)" opacity="0.95"/>
                        </g>
                        <g transform="translate(24,18) rotate(-30)">
                            <path d="M-2,-7 a2,2 0 0,1 4,0 v4.5 h-4 z" fill="url(#lct)"/>
                            <path d="M-2,-2.5 h4 v4.5 a2,2 0 0,1 -4,0 z" fill="#fff"/>
                        </g>
                        <text x="24" y="42" text-anchor="middle" font-family="Inter,sans-serif" font-size="10" font-weight="800" fill="#fff" opacity="0.85">DC</text>
                    </svg>
                </div>
                <span class="landing-brand-text">DawaCloud</span>
            </div>
            <div class="landing-nav-links">
                <a href="#features" class="landing-nav-link">Features</a>
                <a href="#modules" class="landing-nav-link">Modules</a>
                <a href="#about" class="landing-nav-link">About</a>
                <a href="#pricing" class="landing-nav-link">Pricing</a>
                <a href="/auth/login" class="landing-nav-btn outline">Sign In</a>
                <a href="/auth/register" class="landing-nav-btn solid">Get Started</a>
            </div>
        </div>
    </nav>

    @* ── Hero Section ── *@
    <section class="landing-hero">
        <div class="landing-hero-bg">
            <div class="landing-hero-gradient"></div>
            <div class="landing-hero-pattern"></div>
            <div class="landing-hero-orb landing-hero-orb--1"></div>
            <div class="landing-hero-orb landing-hero-orb--2"></div>
            <div class="landing-hero-orb landing-hero-orb--3"></div>
        </div>
        <div class="landing-hero-content">
            <div class="landing-hero-badge">
                <MudIcon Icon="@Icons.Material.Filled.Verified" Size="Size.Small" />
                <span>Trusted Pharmaceutical Solution</span>
            </div>
            <h1 class="landing-hero-title">
                Modern Pharmacy<br />
                <span class="landing-hero-accent">Management System</span>
            </h1>
            <p class="landing-hero-subtitle">
                Streamline your pharmaceutical operations with DawaCloud. Manage inventory, process sales,
                track batches, generate reports, and ensure compliance — all from a single, elegant platform.
            </p>
            <div class="landing-hero-actions">
                <a href="/auth/register" class="landing-btn primary">
                    <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Size="Size.Small" />
                    Start Free Trial
                </a>
                <a href="#features" class="landing-btn ghost">
                    <MudIcon Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" />
                    Explore Features
                </a>
            </div>
            <div class="landing-hero-stats">
                <div class="landing-hero-stat">
                    <span class="landing-hero-stat-value">500+</span>
                    <span class="landing-hero-stat-label">Pharmacies</span>
                </div>
                <div class="landing-hero-stat-sep"></div>
                <div class="landing-hero-stat">
                    <span class="landing-hero-stat-value">50K+</span>
                    <span class="landing-hero-stat-label">Drugs Managed</span>
                </div>
                <div class="landing-hero-stat-sep"></div>
                <div class="landing-hero-stat">
                    <span class="landing-hero-stat-value">99.9%</span>
                    <span class="landing-hero-stat-label">Uptime</span>
                </div>
            </div>
        </div>
    </section>

    @* ── Features Section ── *@
    <section class="landing-features" id="features">
        <div class="landing-section-inner">
            <div class="landing-section-header">
                <span class="landing-section-badge">Features</span>
                <h2>Everything Your Pharmacy Needs</h2>
                <p>Comprehensive tools designed for modern pharmaceutical operations</p>
            </div>
            <div class="landing-features-grid">
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB);">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Style="color: #1565C0;" />
                    </div>
                    <h3>Inventory Management</h3>
                    <p>Real-time stock tracking with batch and expiry management. Automated low-stock alerts and reorder suggestions.</p>
                </div>
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #E8F5E9, #C8E6C9);">
                        <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Style="color: #2E7D32;" />
                    </div>
                    <h3>Point of Sale</h3>
                    <p>Fast, intuitive POS system with barcode scanning, receipt printing, and multi-payment support.</p>
                </div>
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #FFF3E0, #FFE0B2);">
                        <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Style="color: #E65100;" />
                    </div>
                    <h3>Procurement</h3>
                    <p>Manage supplier orders, goods receipts, drug requests, and track delivery status end to end.</p>
                </div>
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #F3E5F5, #E1BEE7);">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" Style="color: #7B1FA2;" />
                    </div>
                    <h3>Reports & Analytics</h3>
                    <p>Sales trends, profit margins, stock valuation, and expiry reports. Export to PDF and Excel.</p>
                </div>
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #FFEBEE, #FFCDD2);">
                        <MudIcon Icon="@Icons.Material.Filled.Security" Style="color: #C62828;" />
                    </div>
                    <h3>Role-Based Access</h3>
                    <p>Granular permissions for administrators, pharmacists, cashiers, and accountants.</p>
                </div>
                <div class="landing-feature-card">
                    <div class="landing-feature-icon" style="background: linear-gradient(135deg, #E0F7FA, #B2EBF2);">
                        <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Style="color: #00838F;" />
                    </div>
                    <h3>Multi-Currency</h3>
                    <p>Support for SSP, USD, and other currencies with real-time exchange rates and conversion.</p>
                </div>
            </div>
        </div>
    </section>

    @* ── Modules Section ── *@
    <section class="landing-modules" id="modules">
        <div class="landing-section-inner">
            <div class="landing-section-header">
                <span class="landing-section-badge">Modules</span>
                <h2>Comprehensive Platform</h2>
                <p>Integrated modules that work seamlessly together</p>
            </div>
            <div class="landing-modules-grid">
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Dashboard" />
                    <span>Dashboard</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Medication" />
                    <span>Drug Catalog</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Category" />
                    <span>Categories</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.QrCode" />
                    <span>Batch Tracking</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Storefront" />
                    <span>Wholesale</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt" />
                    <span>Invoicing</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.RequestQuote" />
                    <span>Quotations</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.People" />
                    <span>Customers</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.LocalPharmacy" />
                    <span>Suppliers</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" />
                    <span>Alerts</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" />
                    <span>Settings</span>
                </div>
                <div class="landing-module-item">
                    <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" />
                    <span>User Mgmt</span>
                </div>
            </div>
        </div>
    </section>

    @* ── Pricing Section ── *@
    <section class="landing-pricing" id="pricing">
        <div class="landing-section-inner">
            <div class="landing-section-header">
                <span class="landing-section-badge">Pricing</span>
                <h2>Simple, Transparent Pricing</h2>
                <p>Start free, upgrade as you grow. No hidden fees.</p>
            </div>

            <div class="landing-pricing-toggle">
                <span class="@(!_annualBilling ? "active" : "")">Monthly</span>
                <label class="landing-toggle">
                    <input type="checkbox" @bind="_annualBilling" />
                    <span class="landing-toggle-slider"></span>
                </label>
                <span class="@(_annualBilling ? "active" : "")">Annual</span>
                <span class="landing-save-badge">Save 20%</span>
            </div>

            <div class="landing-pricing-grid">
                <!-- Free Trial -->
                <div class="landing-pricing-card">
                    <h3>Free Trial</h3>
                    <div class="landing-pricing-price">
                        <span class="landing-pricing-amount">$0</span>
                        <span class="landing-pricing-interval">/14 days</span>
                    </div>
                    <ul class="landing-pricing-features">
                        <li>2 Users</li>
                        <li>100 Drugs</li>
                        <li>Basic POS</li>
                        <li>Inventory Management</li>
                    </ul>
                    <a href="/auth/register" class="landing-btn ghost" style="width: 100%; justify-content: center;">Start Free Trial</a>
                </div>

                <!-- Starter -->
                <div class="landing-pricing-card">
                    <h3>Starter</h3>
                    <div class="landing-pricing-price">
                        <span class="landing-pricing-amount">$@(_annualBilling ? "23" : "29")</span>
                        <span class="landing-pricing-interval">/month</span>
                    </div>
                    <ul class="landing-pricing-features">
                        <li>5 Users</li>
                        <li>500 Drugs</li>
                        <li>Reports & Analytics</li>
                        <li>Multi-currency</li>
                        <li>Email Support</li>
                    </ul>
                    <a href="/auth/register?plan=starter" class="landing-btn ghost" style="width: 100%; justify-content: center;">Get Started</a>
                </div>

                <!-- Professional -->
                <div class="landing-pricing-card featured">
                    <div class="landing-pricing-popular">Most Popular</div>
                    <h3>Professional</h3>
                    <div class="landing-pricing-price">
                        <span class="landing-pricing-amount">$@(_annualBilling ? "63" : "79")</span>
                        <span class="landing-pricing-interval">/month</span>
                    </div>
                    <ul class="landing-pricing-features">
                        <li>15 Users</li>
                        <li>Unlimited Drugs</li>
                        <li>Wholesale Module</li>
                        <li>Insurance Claims</li>
                        <li>API Access</li>
                        <li>Priority Support</li>
                    </ul>
                    <a href="/auth/register?plan=professional" class="landing-btn primary" style="width: 100%; justify-content: center;">Get Started</a>
                </div>

                <!-- Enterprise -->
                <div class="landing-pricing-card">
                    <h3>Enterprise</h3>
                    <div class="landing-pricing-price">
                        <span class="landing-pricing-amount">Custom</span>
                    </div>
                    <ul class="landing-pricing-features">
                        <li>Unlimited Users</li>
                        <li>Unlimited Drugs</li>
                        <li>Multi-branch</li>
                        <li>Custom Integrations</li>
                        <li>Dedicated Support</li>
                        <li>SLA Guarantee</li>
                    </ul>
                    <a href="mailto:sales@dawacloud.com" class="landing-btn ghost" style="width: 100%; justify-content: center;">Contact Sales</a>
                </div>
            </div>
        </div>
    </section>

    @* ── CTA Section ── *@
    <section class="landing-cta" id="about">
        <div class="landing-cta-inner">
            <div class="landing-cta-bg"></div>
            <div class="landing-cta-content">
                <h2>Ready to Transform Your Pharmacy?</h2>
                <p>Join hundreds of pharmacies across South Sudan and East Africa using DawaCloud to streamline their operations.</p>
                <div class="landing-hero-actions" style="justify-content: center;">
                    <a href="/auth/register" class="landing-btn primary">
                        <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Size="Size.Small" />
                        Get Started Now
                    </a>
                    <a href="/auth/login" class="landing-btn ghost">
                        <MudIcon Icon="@Icons.Material.Filled.Login" Size="Size.Small" />
                        Sign In
                    </a>
                </div>
            </div>
        </div>
    </section>

    @* ── Footer ── *@
    <footer class="landing-footer">
        <div class="landing-footer-inner">
            <div class="landing-footer-brand">
                <span class="landing-brand-text" style="color: #fff;">DawaCloud</span>
                <p>Pharmaceutical Management System</p>
            </div>
            <div class="landing-footer-links">
                <a href="/auth/login">Sign In</a>
                <a href="/auth/register">Create Account</a>
                <a href="#features">Features</a>
            </div>
            <div class="landing-footer-copy">
                &copy; @DateTime.UtcNow.Year DawaCloud. All rights reserved.
            </div>
        </div>
    </footer>
</div>

<style>
    /* ── Reset for landing page ── */
    .landing { font-family: 'Inter', 'Segoe UI', sans-serif; color: #0f172a; overflow-x: hidden; }

    /* ── Navigation ── */
    .landing-nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: rgba(255,255,255,0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(0,0,0,0.06); padding: 0 2rem;
    }
    .landing-nav-inner {
        max-width: 1200px; margin: 0 auto; display: flex; align-items: center;
        justify-content: space-between; height: 72px;
    }
    .landing-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .landing-brand-text {
        font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em;
        background: linear-gradient(135deg, #0D47A1, #1565C0);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .landing-nav-links { display: flex; align-items: center; gap: 8px; }
    .landing-nav-link {
        padding: 8px 16px; font-size: 0.9rem; font-weight: 500; color: #475569;
        text-decoration: none; border-radius: 8px; transition: all 0.2s;
    }
    .landing-nav-link:hover { color: #0D47A1; background: #E3F2FD; }
    .landing-nav-btn {
        padding: 10px 22px; font-size: 0.875rem; font-weight: 600; border-radius: 10px;
        text-decoration: none; transition: all 0.25s;
    }
    .landing-nav-btn.outline { color: #1565C0; border: 2px solid #1565C0; }
    .landing-nav-btn.outline:hover { background: #E3F2FD; }
    .landing-nav-btn.solid {
        background: linear-gradient(135deg, #0D47A1, #1565C0); color: #fff;
        box-shadow: 0 4px 14px rgba(21,101,192,0.3);
    }
    .landing-nav-btn.solid:hover { box-shadow: 0 6px 24px rgba(21,101,192,0.4); transform: translateY(-1px); }

    /* ── Hero ── */
    .landing-hero {
        position: relative; min-height: 100vh; display: flex; align-items: center;
        justify-content: center; padding: 120px 2rem 80px; overflow: hidden;
    }
    .landing-hero-bg { position: absolute; inset: 0; z-index: 0; }
    .landing-hero-gradient {
        position: absolute; inset: 0;
        background: linear-gradient(160deg, #f0f7ff 0%, #e3f2fd 30%, #fff 60%, #e8f5e9 100%);
    }
    .landing-hero-pattern {
        position: absolute; inset: 0; opacity: 0.4;
        background-image: radial-gradient(circle at 1px 1px, #cbd5e1 1px, transparent 0);
        background-size: 32px 32px;
    }
    .landing-hero-orb {
        position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.35;
        animation: orbFloat 8s ease-in-out infinite;
    }
    .landing-hero-orb--1 { width: 500px; height: 500px; top: -10%; right: -5%; background: #BBDEFB; animation-delay: 0s; }
    .landing-hero-orb--2 { width: 350px; height: 350px; bottom: -5%; left: -5%; background: #C8E6C9; animation-delay: 2s; }
    .landing-hero-orb--3 { width: 250px; height: 250px; top: 40%; left: 30%; background: #E3F2FD; animation-delay: 4s; }

    @@keyframes orbFloat {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(15px, -20px) scale(1.03); }
        66% { transform: translate(-10px, 10px) scale(0.97); }
    }

    .landing-hero-content {
        position: relative; z-index: 1; max-width: 720px; text-align: center;
        animation: heroReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @@keyframes heroReveal {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .landing-hero-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 16px; border-radius: 999px;
        background: #E3F2FD; color: #0D47A1;
        font-size: 0.8rem; font-weight: 600; margin-bottom: 1.5rem;
    }
    .landing-hero-title {
        font-size: 3.5rem; font-weight: 800; line-height: 1.1;
        letter-spacing: -0.03em; color: #0f172a; margin-bottom: 1.25rem;
    }
    .landing-hero-accent {
        background: linear-gradient(135deg, #0D47A1, #1976D2, #42A5F5);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .landing-hero-subtitle {
        font-size: 1.15rem; line-height: 1.7; color: #64748b;
        max-width: 560px; margin: 0 auto 2rem;
    }
    .landing-hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem; }
    .landing-btn {
        display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
        border-radius: 12px; font-size: 0.95rem; font-weight: 600;
        text-decoration: none; transition: all 0.3s;
    }
    .landing-btn.primary {
        background: linear-gradient(135deg, #0D47A1, #1565C0); color: #fff;
        box-shadow: 0 4px 20px rgba(21,101,192,0.35);
    }
    .landing-btn.primary:hover { box-shadow: 0 8px 32px rgba(21,101,192,0.45); transform: translateY(-2px); }
    .landing-btn.ghost { color: #475569; border: 2px solid #e2e8f0; background: #fff; }
    .landing-btn.ghost:hover { border-color: #1565C0; color: #1565C0; background: #f0f7ff; }

    .landing-hero-stats { display: flex; align-items: center; justify-content: center; gap: 2rem; flex-wrap: wrap; }
    .landing-hero-stat { text-align: center; }
    .landing-hero-stat-value { display: block; font-size: 1.75rem; font-weight: 800; color: #0D47A1; }
    .landing-hero-stat-label { font-size: 0.8rem; color: #94a3b8; font-weight: 500; }
    .landing-hero-stat-sep { width: 1px; height: 40px; background: #e2e8f0; }

    /* ── Sections ── */
    .landing-section-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
    .landing-section-header { text-align: center; margin-bottom: 3rem; }
    .landing-section-badge {
        display: inline-block; padding: 4px 14px; border-radius: 999px;
        background: #E3F2FD; color: #0D47A1; font-size: 0.8rem; font-weight: 600;
        margin-bottom: 1rem;
    }
    .landing-section-header h2 { font-size: 2.25rem; font-weight: 800; letter-spacing: -0.02em; color: #0f172a; margin-bottom: 0.5rem; }
    .landing-section-header p { font-size: 1.05rem; color: #64748b; max-width: 480px; margin: 0 auto; }

    /* ── Features Grid ── */
    .landing-features { padding: 100px 0; background: #fff; }
    .landing-features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .landing-feature-card {
        padding: 32px; border-radius: 16px; border: 1px solid #f1f5f9;
        background: #fff; transition: all 0.3s;
    }
    .landing-feature-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(0,0,0,0.08); border-color: transparent; }
    .landing-feature-icon {
        width: 56px; height: 56px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;
    }
    .landing-feature-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; color: #0f172a; }
    .landing-feature-card p { font-size: 0.9rem; line-height: 1.65; color: #64748b; }

    /* ── Modules Grid ── */
    .landing-modules { padding: 100px 0; background: #f8fafc; }
    .landing-modules-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .landing-module-item {
        display: flex; flex-direction: column; align-items: center; gap: 10px;
        padding: 28px 16px; border-radius: 14px; background: #fff;
        border: 1px solid #f1f5f9; transition: all 0.25s; cursor: default;
    }
