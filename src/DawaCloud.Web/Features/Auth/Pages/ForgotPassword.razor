@page "/auth/forgot-password"
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@layout Shared.Layout.AuthLayout
@attribute [AllowAnonymous]

<PageTitle>DawaCloud | Forgot Password</PageTitle>

<div class="tw:bg-surface tw:rounded-2xl tw:p-8 tw:shadow-card tw:border tw:border-border">
    @if (!_emailSent)
    {
        @* ── Request form state ── *@
        <div class="tw:text-center tw:mb-6">
            <div class="tw:mb-4 tw:flex tw:justify-center">
                <div class="tw:w-16 tw:h-16 tw:rounded-2xl tw:flex tw:items-center tw:justify-center tw:bg-primary-50">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 32px; color: var(--tw-color-primary-600);" />
                </div>
            </div>
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:mb-2 tw:font-display">
                Forgot Password?
            </h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0">
                No worries! Enter your email and we'll send you reset instructions
            </p>
        </div>

        <form method="post" action="/api/auth/forgot-password-form" id="forgotPasswordForm">
            <MudTextField Label="Email Address"
                          @bind-Value="_email"
                          name="email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Required="true"
                          RequiredError="Email is required"
                          Validation="@(new EmailAddressAttribute())"
                          HelperText="Enter your registered email address"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Class="tw:mt-3 tw:mb-3 tw:py-3"
                       ButtonType="ButtonType.Submit"
                       Disabled="@string.IsNullOrEmpty(_email)">
                <MudIcon Icon="@Icons.Material.Filled.Send" Class="tw:mr-2" />
                <span>Send Reset Link</span>
            </MudButton>
        </form>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="tw:mt-4" Dense="true" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
                @_errorMessage
            </MudAlert>
        }

        <div class="tw:text-center tw:mt-4">
            <MudLink Href="/auth/login" Color="Color.Primary" Typo="Typo.body2">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="tw:mr-1" />
                Back to Sign In
            </MudLink>
        </div>
    }
    else
    {
        @* ── Email sent confirmation state ── *@
        <div class="tw:text-center">
            <div class="tw:mb-5 tw:flex tw:justify-center">
                <div class="tw:w-20 tw:h-20 tw:rounded-2xl tw:flex tw:items-center tw:justify-center tw:bg-accent-50">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Style="font-size: 40px; color: var(--tw-color-accent-500);" />
                </div>
            </div>
            <h2 class="tw:text-xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:mb-2 tw:font-display">Check Your Email</h2>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mb-4">
                We've sent password reset instructions to
            </p>
            <MudChip T="string" Color="Color.Primary" Size="Size.Medium">@_email</MudChip>

            <div class="tw:mt-5 tw:text-left tw:bg-primary-50 tw:border tw:border-primary-100 tw:rounded-xl tw:p-4">
                <p class="tw:text-sm tw:text-text-secondary tw:m-0">
                    <strong class="tw:text-text">Didn't receive the email?</strong>
                </p>
                <ul class="tw:mt-2 tw:ml-4 tw:text-sm tw:text-text-secondary tw:space-y-1">
                    <li>Check your spam/junk folder</li>
                    <li>Verify the email address is correct</li>
                    <li>Wait a few minutes and try again</li>
                </ul>
            </div>

            <MudButton Variant="Variant.Text"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="tw:mt-4"
                       OnClick="HandleResend"
                       Disabled="@(_resendCountdown > 0)">
                @if (_resendCountdown > 0)
                {
                    <span>Resend in @_resendCountdown seconds</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Class="tw:mr-2" />
                    <span>Resend Email</span>
                }
            </MudButton>

            <div class="tw:flex tw:items-center tw:gap-3 tw:my-4">
                <span class="tw:flex-1 tw:h-px tw:bg-border"></span>
            </div>

            <div class="tw:text-center">
                <MudLink Href="/auth/login" Color="Color.Primary" Typo="Typo.body2">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="tw:mr-1" />
                    Back to Sign In
                </MudLink>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private bool _emailSent;
    private string _email = string.Empty;
    private string? _errorMessage;
    private int _resendCountdown;
    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            _errorMessage = Uri.UnescapeDataString(Error);
        }

        if (Success == "true" && !string.IsNullOrEmpty(Email))
        {
            _email = Uri.UnescapeDataString(Email);
            _emailSent = true;
            StartResendCountdown();
        }
    }

    private void StartResendCountdown()
    {
        _resendCountdown = 60;
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) =>
        {
            _resendCountdown--;
            if (_resendCountdown <= 0)
            {
                _timer?.Stop();
                _timer?.Dispose();
            }
            InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    private void HandleResend()
    {
        _emailSent = false;
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
