@page "/auth/login"
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using DawaCloud.Web.Features.Auth.Resources
@layout Shared.Layout.AuthLayout
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<AuthMessages> Localizer

<PageTitle>@Localizer["PageTitle_Login"]</PageTitle>

<div class="auth-card">
    @* ── Welcome header ── *@
    <div class="auth-card-header">
        <h1 class="auth-card-title">@Localizer["WelcomeBack"]</h1>
        <p class="auth-card-subtitle">@Localizer["SignInPrompt"]</p>
    </div>

    @* ── Login form ── *@
    <form method="post" action="/api/auth/login-form" id="loginForm" class="auth-form">
        <input type="hidden" name="returnUrl" value="@_returnUrl" />

        <div class="field-stagger field-stagger--1">
            <MudTextField Label="@Localizer["EmailAddress"]"
                          @bind-Value="_model.Email"
                          name="email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Required="true"
                          RequiredError="@Localizer["EmailRequired"]"
                          Validation="@(new EmailAddressAttribute())"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email" />
        </div>

        <div class="field-stagger field-stagger--2">
            <MudTextField Label="@Localizer["Password"]"
                          @bind-Value="_model.Password"
                          name="password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          InputType="@_passwordInputType"
                          Required="true"
                          RequiredError="@Localizer["PasswordRequired"]"
                          Adornment="Adornment.End"
                          AdornmentIcon="@_passwordIcon"
                          OnAdornmentClick="TogglePasswordVisibility" />
        </div>

        <div class="field-stagger field-stagger--3">
            <div class="auth-remember-row">
                <MudCheckBox @bind-Value="_model.RememberMe" Color="Color.Primary">
                    <MudText Typo="Typo.body2">@Localizer["RememberMe"]</MudText>
                </MudCheckBox>
                <input type="hidden" name="rememberMe" value="@_model.RememberMe.ToString().ToLower()" />
                <MudLink Href="/auth/forgot-password" Typo="Typo.body2">
                    @Localizer["ForgotPassword"]
                </MudLink>
            </div>
        </div>

        <div class="field-stagger field-stagger--4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       ButtonType="ButtonType.Submit"
                       Disabled="@_isLoading"
                       Class="auth-submit-btn">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="margin-right: 0.5rem;" />
                    <span>@Localizer["SigningIn"]</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Login" Style="margin-right: 0.5rem;" />
                    <span>@Localizer["SignIn"]</span>
                }
            </MudButton>
        </div>
    </form>

    @* ── Error message ── *@
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Style="margin-top: 0.75rem;" Dense="true" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
            @_errorMessage
        </MudAlert>
    }

    @* ── Demo credentials ── *@
    <div class="field-stagger field-stagger--6">
        <div class="auth-demo-box">
            <div class="auth-demo-label">
                <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Small" Style="color: var(--tw-color-primary-600, #0A7285); opacity: 0.5;" />
                <span>@Localizer["DemoCredentials"]</span>
            </div>
            <div class="auth-demo-creds">
                <code>admin@@dawacloud.com</code>
                <span class="auth-demo-sep">/</span>
                <code>Admin@@123456</code>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool _isLoading;
    private bool _passwordVisible;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;
    private string? _errorMessage;
    private string _returnUrl = "/dashboard";

    private LoginModel _model = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            _errorMessage = Uri.UnescapeDataString(Error);
        }

        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            _returnUrl = Uri.UnescapeDataString(ReturnUrl);
        }
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordVisible)
        {
            _passwordVisible = false;
            _passwordInputType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
        else
        {
            _passwordVisible = true;
            _passwordInputType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}

<style>
    /* ── Auth card ── */
    .auth-card {
        background: var(--tw-color-surface, #fff);
        border-radius: 1.25rem;
        padding: 2rem;
        border: 1px solid var(--tw-color-border, #E2E8F0);
        box-shadow: 0 2px 8px -2px rgba(0,0,0,0.08);
    }

    .auth-card-header { margin-bottom: 1.75rem; }

    .auth-card-title {
        font-family: "Instrument Serif", Georgia, serif;
        font-size: 1.65rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        color: var(--tw-color-text, #1E293B);
        margin: 0 0 0.375rem;
    }

    .auth-card-subtitle {
        font-size: 0.875rem;
        color: var(--tw-color-text-secondary, #64748B);
        margin: 0;
    }

    .auth-form { display: flex; flex-direction: column; }

    .auth-remember-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 0.25rem 0 0.5rem;
    }

    .auth-submit-btn {
        margin-top: 0.5rem;
        padding-top: 0.75rem !important;
        padding-bottom: 0.75rem !important;
    }

    /* Demo credentials box */
    .auth-demo-box {
        margin-top: 1rem;
        padding: 0.875rem 1rem;
        border-radius: 0.75rem;
        background: var(--tw-color-muted, #F1F5F9);
        border: 1px dashed var(--tw-color-border, #E2E8F0);
        text-align: center;
    }

    .auth-demo-label {
        display: flex; align-items: center; justify-content: center; gap: 0.375rem;
        margin-bottom: 0.375rem;
        font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--tw-color-text-secondary, #64748B);
    }

    .auth-demo-creds {
        display: flex; align-items: center; justify-content: center;
        gap: 0.5rem; flex-wrap: wrap;
    }

    .auth-demo-creds code {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.78rem;
        color: var(--tw-color-text, #1E293B);
        background: var(--tw-color-surface, #fff);
        padding: 0.125rem 0.625rem;
        border-radius: 0.375rem;
        border: 1px solid var(--tw-color-border, #E2E8F0);
    }

    .auth-demo-sep {
        color: var(--tw-color-text-muted, #94A3B8);
        font-size: 0.75rem;
    }

    /* ── Staggered entry animation ── */
    .field-stagger { animation: fieldSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .field-stagger--1 { animation-delay: 0.08s; }
    .field-stagger--2 { animation-delay: 0.14s; }
    .field-stagger--3 { animation-delay: 0.20s; }
    .field-stagger--4 { animation-delay: 0.26s; }
    .field-stagger--5 { animation-delay: 0.32s; }
    .field-stagger--6 { animation-delay: 0.38s; }

    @@keyframes fieldSlideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 600px) {
        .auth-card { padding: 1.5rem; }
        .auth-card-title { font-size: 1.4rem; }
    }
</style>
