@page "/auth/login"
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Localization
@using DawaCloud.Web.Features.Auth.Resources
@layout Shared.Layout.AuthLayout
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<AuthMessages> Localizer

<PageTitle>@Localizer["PageTitle_Login"]</PageTitle>

<div class="auth-container">
    <div class="auth-card">

        @* ── Welcome header ── *@
        <div class="login-header">
            <h1 class="login-heading">@Localizer["WelcomeBack"]</h1>
            <p class="login-subtext">@Localizer["SignInPrompt"]</p>
        </div>

        @* ── Login form ── *@
        <form method="post" action="/api/auth/login-form" id="loginForm" class="login-form">
            <input type="hidden" name="returnUrl" value="@_returnUrl" />

            <div class="login-field login-field--1">
                <MudTextField Label="@Localizer["EmailAddress"]"
                              @bind-Value="_model.Email"
                              name="email"
                              Variant="Variant.Outlined"
                              Margin="Margin.Normal"
                              Required="true"
                              RequiredError="@Localizer["EmailRequired"]"
                              Validation="@(new EmailAddressAttribute())"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email" />
            </div>

            <div class="login-field login-field--2">
                <MudTextField Label="@Localizer["Password"]"
                              @bind-Value="_model.Password"
                              name="password"
                              Variant="Variant.Outlined"
                              Margin="Margin.Normal"
                              InputType="@_passwordInputType"
                              Required="true"
                              RequiredError="@Localizer["PasswordRequired"]"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_passwordIcon"
                              OnAdornmentClick="TogglePasswordVisibility" />
            </div>

            <div class="login-field login-field--3">
                <div class="login-meta-row">
                    <MudCheckBox @bind-Value="_model.RememberMe" Color="Color.Primary">
                        <MudText Typo="Typo.body2">@Localizer["RememberMe"]</MudText>
                    </MudCheckBox>
                    <input type="hidden" name="rememberMe" value="@_model.RememberMe.ToString().ToLower()" />
                    <MudLink Href="/auth/forgot-password" Typo="Typo.body2">
                        @Localizer["ForgotPassword"]
                    </MudLink>
                </div>
            </div>

            <div class="login-field login-field--4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           ButtonType="ButtonType.Submit"
                           Disabled="@_isLoading"
                           Class="login-submit-btn">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>@Localizer["SigningIn"]</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                        <span>@Localizer["SignIn"]</span>
                    }
                </MudButton>
            </div>
        </form>

        @* ── Error message ── *@
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="login-field" style="animation-delay: 0s;">
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
                    @_errorMessage
                </MudAlert>
            </div>
        }

        @* ── Separator ── *@
        <div class="login-separator login-field login-field--5">
            <span class="login-sep-line"></span>
            <span class="login-sep-text">@Localizer["Or"]</span>
            <span class="login-sep-line"></span>
        </div>

        @* ── Sign up link ── *@
        <div class="login-field login-field--5">
            <div class="login-signup">
                <span>@Localizer["NewToDawaCloud"]</span>
                <MudLink Href="/auth/register" Typo="Typo.body2">
                    <strong>@Localizer["CreateAccount"]</strong>
                </MudLink>
            </div>
        </div>

        @* ── Demo credentials ── *@
        <div class="login-field login-field--6">
            <div class="login-demo">
                <div class="login-demo-header">
                    <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Small" Style="color: #0d3b66; opacity: 0.5;" />
                    <span class="login-demo-label">@Localizer["DemoCredentials"]</span>
                </div>
                <div class="login-demo-creds">
                    <code class="login-demo-value">admin@@dawacloud.com</code>
                    <span class="login-demo-sep">/</span>
                    <code class="login-demo-value">Admin@@123456</code>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private bool _isLoading;
    private bool _passwordVisible;
    private InputType _passwordInputType = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;
    private string? _errorMessage;
    private string _returnUrl = "/";

    private LoginModel _model = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            _errorMessage = Uri.UnescapeDataString(Error);
        }

        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            _returnUrl = Uri.UnescapeDataString(ReturnUrl);
        }
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordVisible)
        {
            _passwordVisible = false;
            _passwordInputType = InputType.Password;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
        else
        {
            _passwordVisible = true;
            _passwordInputType = InputType.Text;
            _passwordIcon = Icons.Material.Filled.Visibility;
        }
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}

<style>
    .login-header { margin-bottom: 1.75rem; }

    .login-heading {
        font-family: 'Inter', sans-serif;
        font-size: 1.65rem;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #0f172a;
        margin: 0 0 0.35rem 0;
        line-height: 1.2;
    }

    .login-subtext {
        font-family: 'Inter', sans-serif;
        font-size: 0.9rem;
        color: #64748b;
        margin: 0;
    }

    .login-form { display: flex; flex-direction: column; }

    .login-field { animation: fieldSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .login-field--1 { animation-delay: 0.08s; }
    .login-field--2 { animation-delay: 0.14s; }
    .login-field--3 { animation-delay: 0.20s; }
    .login-field--4 { animation-delay: 0.26s; }
    .login-field--5 { animation-delay: 0.32s; }
    .login-field--6 { animation-delay: 0.38s; }

    @@keyframes fieldSlideIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .login-meta-row { display: flex; justify-content: space-between; align-items: center; margin: 0.25rem 0 0.5rem; }
    .login-submit-btn { margin-top: 0.5rem; padding: 0.75rem 1.5rem; }

    .login-separator { display: flex; align-items: center; gap: 0.75rem; margin: 1.25rem 0; }
    .login-sep-line { flex: 1; height: 1px; background: #e2e8f0; }
    .login-sep-text { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; }

    .login-signup { text-align: center; font-family: 'Inter', sans-serif; font-size: 0.875rem; color: #64748b; display: flex; align-items: center; justify-content: center; gap: 0.4rem; }

    .login-demo { margin-top: 1rem; padding: 0.85rem 1rem; border-radius: 12px; background: #f1f5f9; border: 1px dashed #cbd5e1; text-align: center; }
    .login-demo-header { display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-bottom: 0.4rem; }
    .login-demo-label { font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; }
    .login-demo-creds { display: flex; align-items: center; justify-content: center; gap: 0.5rem; flex-wrap: wrap; }
    .login-demo-value { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 0.78rem; color: #334155; background: #ffffff; padding: 0.2rem 0.55rem; border-radius: 6px; border: 1px solid #e2e8f0; }
    .login-demo-sep { color: #94a3b8; font-size: 0.75rem; }

    @@media (max-width: 600px) { .login-heading { font-size: 1.4rem; } }
</style>
