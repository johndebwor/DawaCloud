    private async Task EditTemplate(TemplateModel template)
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var dbTemplate = await dbContext.NotificationTemplates.FindAsync(template.Id);

            if (dbTemplate == null)
            {
                Snackbar.Add("Template not found", Severity.Error);
                return;
            }

            var parameters = new DialogParameters
            {
                { nameof(Components.TemplateEditorDialog.TemplateId), template.Id },
                { nameof(Components.TemplateEditorDialog.Template), dbTemplate }
            };

            var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
            var dialog = await DialogService.ShowAsync<Components.TemplateEditorDialog>("Edit Notification Template", parameters, options);
            var result = await dialog.Result;

            if (!result.Canceled && result.Data != null)
            {
                var updatedTemplate = (dynamic)result.Data;
                var command = new UpdateNotificationTemplateCommand(
                    template.Id,
                    updatedTemplate.Name,
                    updatedTemplate.Code,
                    updatedTemplate.Type,
                    updatedTemplate.Channel,
                    updatedTemplate.Subject,
                    updatedTemplate.Body,
                    updatedTemplate.IsActive
                );

                await Mediator.Send(command);
                Snackbar.Add("Template updated successfully", Severity.Success);
                await LoadSettingsAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error editing template: {ex.Message}", Severity.Error);
        }
    }

