@code {
    private MudForm? _companyForm;
    private CompanySettingsModel _companySettings = new();
    private EmailSettingsModel _emailSettings = new();
    private WhatsAppSettingsModel _whatsAppSettings = new();
    private List<TaxCategoryModel> _taxCategories = new();
    private List<TemplateModel> _templates = new();
    private string? _logoPreviewUrl;
    private IBrowserFile? _logoFile;
    private byte[]? _logoFileBytes;
    private string? _logoFileExtension;
    private bool _isUploadingLogo;

    private bool HasLogo => !string.IsNullOrEmpty(_logoPreviewUrl) || !string.IsNullOrEmpty(_companySettings.LogoUrl);

    // Currency settings
    private List<CurrencyDto> _currencies = new();
    private List<ExchangeRateDto> _exchangeRates = new();
    private int _baseCurrencyId;
    private int _purchaseCurrencyId;
    private int _salesCurrencyId;
    private bool _isLoadingCurrencies = true;

    // Rounding settings
    private RoundingSettingsModel _roundingSettings = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        await LoadCurrencySettingsAsync();
        await LoadRoundingSettingsAsync();
        await LoadInsuranceSettings();
        await LoadAiChatSettings();
        await LoadSubscriptionInfo();
    }

    private async Task LoadCurrencySettingsAsync()
    {
        try
        {
            _isLoadingCurrencies = true;
            _currencies = await CurrencyService.GetAllCurrenciesAsync();
            _exchangeRates = await CurrencyService.GetAllExchangeRatesAsync();

            var baseCurrency = _currencies.FirstOrDefault(c => c.IsBaseCurrency);
            var purchaseCurrency = _currencies.FirstOrDefault(c => c.IsDefaultPurchaseCurrency);
            var salesCurrency = _currencies.FirstOrDefault(c => c.IsDefaultSalesCurrency);

            _baseCurrencyId = baseCurrency?.Id ?? 0;
            _purchaseCurrencyId = purchaseCurrency?.Id ?? 0;
            _salesCurrencyId = salesCurrency?.Id ?? 0;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading currencies: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingCurrencies = false;
        }
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var settings = await dbContext.CompanySettings.FirstOrDefaultAsync();
            if (settings != null)
            {
                _companySettings = new CompanySettingsModel
                {
                    CompanyName = settings.CompanyName,
                    PharmacyLicenseNumber = settings.PharmacyLicenseNumber,
                    TaxId = settings.TaxId,
                    Email = settings.Email,
                    Phone = settings.Phone,
                    Website = settings.Website,
                    Address = settings.Address,
                    City = settings.City,
                    Country = settings.Country,
                    LogoUrl = settings.LogoUrl,
                    Currency = settings.DefaultCurrency,
                    DefaultTaxRate = settings.DefaultTaxRate,
                    LowStockThresholdDays = settings.LowStockThresholdDays,
                    ExpiryAlertDays30 = settings.ExpiryAlertDays30,
                    ExpiryAlertDays60 = settings.ExpiryAlertDays60,
                    ExpiryAlertDays90 = settings.ExpiryAlertDays90,
                    PosProductDisplayStyle = settings.PosProductDisplayStyle
                };
                _emailSettings = new EmailSettingsModel
                {
                    SmtpHost = settings.SmtpHost,
                    SmtpPort = settings.SmtpPort,
                    Username = settings.SmtpUsername,
                    Password = settings.SmtpPassword,
                    FromEmail = settings.FromEmail,
                    FromName = settings.FromName
                };
                _whatsAppSettings = new WhatsAppSettingsModel
                {
                    AccountSid = settings.TwilioAccountSid,
                    AuthToken = settings.TwilioAuthToken,
                    FromNumber = settings.TwilioFromNumber
                };
            }
            else
            {
                // Defaults
                _companySettings = new CompanySettingsModel
                {
                    CompanyName = "Guru Brothers Ltd",
                    DefaultTaxRate = 16,
                    LowStockThresholdDays = 14,
                    ExpiryAlertDays30 = 30,
                    ExpiryAlertDays60 = 60,
                    ExpiryAlertDays90 = 90,
                    Currency = "SSP"
                };
            }

            // Load notification templates from DB
            _templates = (await dbContext.NotificationTemplates.ToListAsync())
                .Select(t => new TemplateModel
                {
                    Id = t.Id,
                    Name = t.Name,
                    Type = t.Type.ToString(),
                    Channel = t.Channel.ToString(),
                    Subject = t.Subject,
                    Body = t.Body,
                    IsActive = t.IsActive
                }).ToList();

            // Load tax categories from database
            var taxCategoriesDto = await Mediator.Send(new GetTaxCategoriesQuery());
            _taxCategories = taxCategoriesDto.Select(tc => new TaxCategoryModel
            {
                Id = tc.Id,
                Name = tc.Name,
                Rate = tc.Rate,
                Description = tc.Description,
                IsDefault = tc.IsDefault,
                IsActive = tc.IsActive
            }).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading settings: {ex.Message}", Severity.Error);
        }
    }

    private Color GetChannelColor(string channel) => channel switch
    {
        "Email" => Color.Info,
        "WhatsApp" => Color.Success,
