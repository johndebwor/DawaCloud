    private async Task SaveCurrencySettings()
    {
        try
        {
            if (_baseCurrencyId == 0 || _purchaseCurrencyId == 0 || _salesCurrencyId == 0)
            {
                Snackbar.Add("Please select all currency options", Severity.Warning);
                return;
            }

            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            // Update all currencies to remove the flags first
            var allCurrencies = await dbContext.Currencies.ToListAsync();
            foreach (var currency in allCurrencies)
            {
                currency.IsBaseCurrency = false;
                currency.IsDefaultPurchaseCurrency = false;
                currency.IsDefaultSalesCurrency = false;
            }

            // Set the selected currencies
            var baseCurrency = allCurrencies.FirstOrDefault(c => c.Id == _baseCurrencyId);
            if (baseCurrency != null)
                baseCurrency.IsBaseCurrency = true;

            var purchaseCurrency = allCurrencies.FirstOrDefault(c => c.Id == _purchaseCurrencyId);
            if (purchaseCurrency != null)
                purchaseCurrency.IsDefaultPurchaseCurrency = true;

            var salesCurrency = allCurrencies.FirstOrDefault(c => c.Id == _salesCurrencyId);
            if (salesCurrency != null)
                salesCurrency.IsDefaultSalesCurrency = true;

            // Also persist IDs to CompanySettings
            var companySettings = await dbContext.CompanySettings.FirstOrDefaultAsync();
            if (companySettings != null)
            {
                companySettings.BaseCurrencyId = _baseCurrencyId;
                companySettings.DefaultPurchaseCurrencyId = _purchaseCurrencyId;
                companySettings.DefaultSalesCurrencyId = _salesCurrencyId;
            }

            await dbContext.SaveChangesAsync();

            // Clear cache and reload to confirm
            CurrencyService.ClearCache();
            await LoadCurrencySettingsAsync();
            Snackbar.Add("Currency settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving currency settings: {ex.Message}", Severity.Error);
        }
    }

