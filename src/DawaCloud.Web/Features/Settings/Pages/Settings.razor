    };

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file == null) return;

            if (file.Size > 2 * 1024 * 1024)
            {
                Snackbar.Add("File size must be less than 2MB", Severity.Warning);
                return;
            }

            if (!file.ContentType.StartsWith("image/"))
            {
                Snackbar.Add("Please select an image file (PNG, JPG, etc.)", Severity.Warning);
                return;
            }

            _isUploadingLogo = true;
            StateHasChanged();

            _logoFile = file;
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024).ReadAsync(buffer);
            _logoFileExtension = Path.GetExtension(file.Name);

            // Save to temp file for crop dialog
            var previewDir = Path.Combine("wwwroot", "images");
            Directory.CreateDirectory(previewDir);
            var tempName = $"logo-temp-{Guid.NewGuid():N}{_logoFileExtension}";
            var tempPath = Path.Combine(previewDir, tempName);
            await File.WriteAllBytesAsync(tempPath, buffer);
            var tempUrl = $"/images/{tempName}?t={DateTime.UtcNow.Ticks}";

            _isUploadingLogo = false;
            StateHasChanged();

            // Open crop dialog
            var parameters = new DialogParameters
            {
                { nameof(ImageCropDialog.ImageDataUrl), tempUrl },
                { nameof(ImageCropDialog.AspectRatio), 1.0 },
                { nameof(ImageCropDialog.OutputWidth), 200 },
                { nameof(ImageCropDialog.OutputHeight), 200 }
            };
            var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
            var dialog = await DialogService.ShowAsync<ImageCropDialog>("Crop Logo", parameters, options);
            var result = await dialog.Result;

            // Clean up temp file
            try { if (File.Exists(tempPath)) File.Delete(tempPath); } catch { }

            if (!result.Canceled && result.Data is string croppedDataUrl)
            {
                // Convert cropped base64 data URL to bytes
                var base64 = croppedDataUrl.Substring(croppedDataUrl.IndexOf(",") + 1);
                _logoFileBytes = Convert.FromBase64String(base64);
                _logoFileExtension = ".png";

                // Save cropped preview
                var previewName = $"logo-preview-{Guid.NewGuid():N}.png";
                var previewPath = Path.Combine(previewDir, previewName);
                await File.WriteAllBytesAsync(previewPath, _logoFileBytes);
                _logoPreviewUrl = $"/images/{previewName}?t={DateTime.UtcNow.Ticks}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error processing logo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploadingLogo = false;
            StateHasChanged();
        }
    }

    private void RemoveLogo()
    {
        _logoPreviewUrl = null;
        _logoFile = null;
        _logoFileBytes = null;
        _logoFileExtension = null;
        _companySettings.LogoUrl = null;
        StateHasChanged();
    }

    private async Task SaveCompanySettings()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var settings = await dbContext.CompanySettings.FirstOrDefaultAsync();
            if (settings == null)
            {
                settings = new Data.Entities.CompanySettings();
                dbContext.CompanySettings.Add(settings);
            }

            // Save logo file if one was uploaded
            if (_logoFileBytes != null)
            {
                var uploadsPath = Path.Combine("wwwroot", "images");
                Directory.CreateDirectory(uploadsPath);

                // Use a unique filename to avoid file-lock conflicts with static file middleware
                var fileName = $"company-logo-{DateTime.UtcNow:yyyyMMddHHmmss}{_logoFileExtension}";
                var filePath = Path.Combine(uploadsPath, fileName);

                await File.WriteAllBytesAsync(filePath, _logoFileBytes);

                // Try to delete old logo file
                if (!string.IsNullOrEmpty(_companySettings.LogoUrl))
                {
                    var oldPath = Path.Combine("wwwroot", _companySettings.LogoUrl.TrimStart('/'));
                    try { if (File.Exists(oldPath)) File.Delete(oldPath); } catch { /* locked, will be cleaned up later */ }
                }

                _companySettings.LogoUrl = $"/images/{fileName}";
                _logoFile = null;
                _logoFileBytes = null;
                _logoFileExtension = null;
                _logoPreviewUrl = null;
            }

            settings.CompanyName = _companySettings.CompanyName;
            settings.PharmacyLicenseNumber = _companySettings.PharmacyLicenseNumber;
            settings.TaxId = _companySettings.TaxId;
            settings.Email = _companySettings.Email;
            settings.Phone = _companySettings.Phone;
            settings.Website = _companySettings.Website;
            settings.Address = _companySettings.Address;
            settings.City = _companySettings.City;
            settings.Country = _companySettings.Country;
            settings.LogoUrl = _companySettings.LogoUrl;
            settings.DefaultCurrency = _companySettings.Currency;
            settings.DefaultTaxRate = _companySettings.DefaultTaxRate;
            settings.PosProductDisplayStyle = _companySettings.PosProductDisplayStyle;
            await dbContext.SaveChangesAsync();
            Snackbar.Add("Company settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving company settings: {ex.Message}", Severity.Error);
        }
    }

