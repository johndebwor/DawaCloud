@page "/suppliers/new"
@page "/suppliers/{Id:int}"
@using MudBlazor
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@using DawaCloud.Web.Features.Suppliers.Commands
@using DawaCloud.Web.Data
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IMediator Mediator
@inject IServiceScopeFactory ScopeFactory

<PageTitle>@(_isViewMode ? "Supplier Details" : _isEditMode ? "Edit Supplier" : "New Supplier") - DawaCloud</PageTitle>

<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:flex-wrap tw:justify-between tw:items-center tw:gap-4">
        <div class="tw:flex tw:items-center tw:gap-4">
            <a href="/suppliers" class="dc-btn-secondary">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
                Back
            </a>
            <div>
                <h1 class="tw:text-2xl tw:font-bold tw:font-display tw:tracking-tight tw:text-text tw:m-0">@GetPageTitle()</h1>
                <p class="tw:text-text-secondary tw:text-sm tw:mt-0.5 tw:m-0">@GetPageSubtitle()</p>
            </div>
        </div>
        <div class="tw:flex tw:items-center tw:gap-2">
            @if (_isViewMode)
            {
                <button class="dc-btn-primary" @onclick="EnableEdit">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    Edit
                </button>
                <a href="@($"/procurement/requests/new?supplierId={Id}")" class="dc-btn-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" />
                    Create Request
                </a>
            }
        </div>
    </div>
</div>

<MudGrid>
    <MudItem xs="12" md="8">
        <div class="dc-card animate-fade-in-up animate-delay-1">
                <MudForm @ref="_form">
                    <MudText Typo="Typo.h6" Class="mb-4">Company Information</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Name"
                                          Label="Company Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Code"
                                          Label="Supplier Code"
                                          Variant="Variant.Outlined"
                                          ReadOnly="true"
                                          HelperText="Auto-generated" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Email"
                                          Label="Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Phone"
                                          Label="Phone"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Address"
                                          Label="Address"
                                          Variant="Variant.Outlined"
                                          Lines="2"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.City"
                                          Label="City"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Country"
                                          Label="Country"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.TaxId"
                                          Label="Tax ID / PIN"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.h6" Class="mb-4">Contact Person</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactPersonName"
                                          Label="Contact Name"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactPersonPhone"
                                          Label="Contact Phone"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.ContactPersonEmail"
                                          Label="Contact Email"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          ReadOnly="@_isViewMode" />
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.h6" Class="mb-4">Notification Preferences</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudSwitch @bind-Value="_model.EmailNotificationsEnabled"
                                       Label="Email Notifications"
                                       Color="Color.Primary"
                                       Disabled="@_isViewMode" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSwitch @bind-Value="_model.WhatsAppNotificationsEnabled"
                                       Label="WhatsApp Notifications"
                                       Color="Color.Success"
                                       Disabled="@_isViewMode" />
                        </MudItem>
                    </MudGrid>
                </MudForm>

                @if (!_isViewMode)
                {
                    <div class="d-flex justify-end gap-2 mt-4">
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/suppliers">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSupplier">
                            @(_isEditMode ? "Save Changes" : "Create Supplier")
                        </MudButton>
                    </div>
                }
        </div>
    </MudItem>

    <MudItem xs="12" md="4">
        @if (_isViewMode || _isEditMode)
        {
            <!-- Stats Card -->
            <div class="dc-card tw:mb-4 animate-fade-in-up animate-delay-2">
                    <MudText Typo="Typo.h6" Class="mb-3">Supplier Statistics</MudText>
                    <div class="d-flex flex-column gap-3">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Orders</MudText>
                            <MudText Typo="Typo.h5">24</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Value</MudText>
                            <MudText Typo="Typo.h5" Color="Color.Primary">SSP 2.4M</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Last Order</MudText>
                            <MudText Typo="Typo.body1">15 Jan 2024</MudText>
                        </div>
                    </div>
            </div>

            <!-- Status Card -->
            <div class="dc-card animate-fade-in-up animate-delay-3">
                    <MudText Typo="Typo.h6" Class="mb-3">Status</MudText>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Active</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_model.IsActive ? Color.Success : Color.Default)">
                                @(_model.IsActive ? "Yes" : "No")
                            </MudChip>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Email Notifications</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_model.EmailNotificationsEnabled ? Color.Info : Color.Default)">
                                @(_model.EmailNotificationsEnabled ? "On" : "Off")
                            </MudChip>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">WhatsApp Notifications</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_model.WhatsAppNotificationsEnabled ? Color.Success : Color.Default)">
                                @(_model.WhatsAppNotificationsEnabled ? "On" : "Off")
                            </MudChip>
                        </div>
                    </div>
            </div>
        }
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isViewMode = true;
    private bool _isEditMode => Id.HasValue && !_isViewMode;
    private bool _isCreateMode => !Id.HasValue;
    private MudForm? _form;
    private SupplierModel _model = new();
    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            await LoadSupplierAsync();
            _isViewMode = true;
        }
        else
        {
            _isViewMode = false;
            _model.Code = $"SUP-{DateTime.UtcNow:yyyyMMddHHmm}";
        }

        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new("Home", href: "/"),
            new("Suppliers", href: "/suppliers"),
            new(GetPageTitle(), href: null, disabled: true)
        };
    }

    private async Task LoadSupplierAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
            var supplier = await db.Suppliers.FirstOrDefaultAsync(s => s.Id == Id);
            if (supplier != null)
            {
                _model = new SupplierModel
                {
                    Id = supplier.Id,
                    Code = supplier.Code,
                    Name = supplier.Name,
                    Email = supplier.Email,
                    Phone = supplier.Phone,
                    Address = supplier.Address,
                    City = supplier.City,
                    Country = supplier.Country,
                    TaxId = supplier.TaxId,
                    EmailNotificationsEnabled = supplier.EmailNotificationsEnabled,
                    WhatsAppNotificationsEnabled = supplier.WhatsAppNotificationsEnabled,
                    IsActive = supplier.IsActive
                };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading supplier: {ex.Message}", Severity.Error);
        }
    }

    private string GetPageTitle()
    {
        if (_isCreateMode) return "New Supplier";
        if (_isViewMode) return _model.Name;
        return "Edit Supplier";
    }

    private string GetPageSubtitle()
    {
        if (_isCreateMode) return "Register a new supplier";
        if (_isViewMode) return _model.Code;
        return "Update supplier information";
    }

    private void EnableEdit()
    {
        _isViewMode = false;
    }

    private async Task SaveSupplier()
    {
        try
        {
            if (_isEditMode)
            {
                using var scope = ScopeFactory.CreateScope();
                var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
                var supplier = await db.Suppliers.FindAsync(_model.Id);
                if (supplier != null)
                {
                    supplier.Name = _model.Name;
                    supplier.Email = _model.Email;
                    supplier.Phone = _model.Phone;
                    supplier.Address = _model.Address;
                    supplier.City = _model.City;
                    supplier.Country = _model.Country;
                    supplier.TaxId = _model.TaxId;
                    supplier.EmailNotificationsEnabled = _model.EmailNotificationsEnabled;
                    supplier.WhatsAppNotificationsEnabled = _model.WhatsAppNotificationsEnabled;
                    supplier.IsActive = _model.IsActive;
                    await db.SaveChangesAsync();
                    Snackbar.Add("Supplier updated successfully", Severity.Success);
                }
            }
            else
            {
                var contacts = new List<CreateSupplierContactDto>();
                if (!string.IsNullOrEmpty(_model.ContactPersonName))
                {
                    contacts.Add(new CreateSupplierContactDto(
                        _model.ContactPersonName,
                        _model.ContactPersonEmail,
                        _model.ContactPersonPhone,
                        "Primary Contact",
                        true
                    ));
                }
                var command = new CreateSupplierCommand(
                    _model.Name, _model.Email, _model.Phone, _model.Address,
                    _model.City, _model.Country, _model.TaxId,
                    _model.EmailNotificationsEnabled, _model.WhatsAppNotificationsEnabled,
                    null, contacts
                );
                var result = await Mediator.Send(command);
                if (result.Success)
                    Snackbar.Add("Supplier created successfully", Severity.Success);
                else
                {
                    Snackbar.Add(result.Message, Severity.Error);
                    return;
                }
            }
            Navigation.NavigateTo("/suppliers");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving supplier: {ex.Message}", Severity.Error);
        }
    }

    private class SupplierModel
    {
        public int Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? Country { get; set; }
        public string? TaxId { get; set; }
        public string? ContactPersonName { get; set; }
        public string? ContactPersonPhone { get; set; }
        public string? ContactPersonEmail { get; set; }
        public bool EmailNotificationsEnabled { get; set; }
        public bool WhatsAppNotificationsEnabled { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
