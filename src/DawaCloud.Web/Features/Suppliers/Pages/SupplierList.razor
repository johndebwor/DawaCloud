@page "/suppliers"
@using MudBlazor
@using DawaCloud.Web.Features.Suppliers.Queries
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireInventoryAccess")]
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Suppliers - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Suppliers</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Manage supplier information and contacts</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/suppliers/new">
            Add Supplier
        </MudButton>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi animate-fade-in-up animate-delay-1">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-success/10">
                <MudIcon Icon="@Icons.Material.Filled.Store" Style="color: var(--tw-color-success);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Total Suppliers</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_suppliers.Count</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-2">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Active</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_suppliers.Count(s => s.IsActive)</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-3">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-info/10">
                <MudIcon Icon="@Icons.Material.Filled.Email" Style="color: var(--tw-color-info);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Email Enabled</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_suppliers.Count(s => s.EmailNotificationsEnabled)</div>
    </div>
    <div class="dc-kpi animate-fade-in-up animate-delay-4">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning/10">
                <MudIcon Icon="@Icons.Material.Filled.Chat" Style="color: var(--tw-color-warning);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">WhatsApp Enabled</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_suppliers.Count(s => s.WhatsAppNotificationsEnabled)</div>
    </div>
</div>

<!-- Suppliers Table -->
<div class="dc-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
        <MudTextField @bind-Value="_searchTerm"
                      Placeholder="Search suppliers..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      OnDebounceIntervalElapsed="LoadSuppliers"
                      DebounceInterval="300"
                      Style="max-width: 400px;" />

        <MudSwitch @bind-Value="_showActiveOnly" Color="Color.Primary" Label="Active Only" OnChanged="@((bool _) => LoadSuppliers())" />
    </div>

    <MudTable T="SupplierDto" Items="@FilteredSuppliers" Dense="true" Hover="true" Loading="@_loading" Class="mt-4">
            <HeaderContent>
                <MudTh>Code</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Contact Info</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Notifications</MudTh>
                <MudTh>Contacts</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code">@context.Code</MudTd>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="Contact Info">
                    <div>
                        @if (!string.IsNullOrEmpty(context.Email))
                        {
                            <MudText Typo="Typo.body2">@context.Email</MudText>
                        }
                        @if (!string.IsNullOrEmpty(context.Phone))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Phone</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Location">
                    @if (!string.IsNullOrEmpty(context.City))
                    {
                        <span>@context.City, @context.Country</span>
                    }
                    else
                    {
                        <span>@context.Country</span>
                    }
                </MudTd>
                <MudTd DataLabel="Notifications">
                    <div class="d-flex gap-1">
                        @if (context.EmailNotificationsEnabled)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Email">Email</MudChip>
                        }
                        @if (context.WhatsAppNotificationsEnabled)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Chat">WhatsApp</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Contacts">@context.ContactCount</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="View Details"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" Href="@($"/suppliers/{context.Id}")" /></MudTooltip>
                    <MudTooltip Text="Create Request"><MudIconButton Icon="@Icons.Material.Filled.Send" Size="Size.Small" Color="Color.Primary" Href="@($"/procurement/requests/new?supplierId={context.Id}")" /></MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

@code {
    private List<SupplierDto> _suppliers = new();
    private string _searchTerm = string.Empty;
    private bool _showActiveOnly = false;
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _suppliers = await Mediator.Send(new GetSuppliersQuery(
                SearchTerm: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                IsActive: _showActiveOnly ? true : null
            ));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading suppliers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<SupplierDto> FilteredSuppliers => _suppliers;
}
