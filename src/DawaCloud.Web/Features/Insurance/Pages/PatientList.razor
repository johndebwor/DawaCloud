@page "/insurance/patients"
@using MudBlazor
@inject NavigationManager Navigation

<PageTitle>Insurance Patients - DawaCloud</PageTitle>

<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Insurance Patients</h1>
            <p>Manage patients with health insurance coverage</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/insurance/patients/new">
            Register Patient
        </MudButton>
    </div>
</div>

<div class="df-alert-card animate-fade-in-up animate-delay-1 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by name, member number..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 300px;" />

        <div class="d-flex gap-2">
            <MudSelect T="int?" @bind-Value="_selectedProviderId" Label="Provider" Variant="Variant.Outlined" Dense="true" Clearable="true">
                <MudSelectItem T="int?" Value="null">All Providers</MudSelectItem>
                @foreach (var provider in _providers)
                {
                    <MudSelectItem T="int?" Value="@provider.Id">@provider.Name</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Variant="Variant.Outlined" Dense="true">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Expired")">Expired</MudSelectItem>
                <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="PatientDto" Items="@FilteredPatients" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Member Number</MudTh>
            <MudTh>Patient Name</MudTh>
            <MudTh>Provider</MudTh>
            <MudTh>Coverage Period</MudTh>
            <MudTh>Coverage Used</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Member Number">
                <MudText Typo="Typo.body2" Class="fw-bold">@context.MemberNumber</MudText>
            </MudTd>
            <MudTd DataLabel="Patient Name">
                <div>
                    <MudText Typo="Typo.body2">@context.FullName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Phone</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Provider">
                <MudText Typo="Typo.body2">@context.ProviderName</MudText>
            </MudTd>
            <MudTd DataLabel="Coverage Period">
                <div>
                    <MudText Typo="Typo.body2">@context.CoverageStartDate.ToString("dd MMM yyyy")</MudText>
                    @if (context.CoverageEndDate.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">to @context.CoverageEndDate.Value.ToString("dd MMM yyyy")</MudText>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Coverage Used">
                @if (context.AnnualCoverageLimit.HasValue)
                {
                    var percentage = (double)((context.YearToDateUsed / context.AnnualCoverageLimit.Value) * 100);
                    <div>
                        <MudText Typo="Typo.body2">SSP @context.YearToDateUsed.ToString("N0") / @context.AnnualCoverageLimit.Value.ToString("N0")</MudText>
                        <MudProgressLinear Color="@GetUsageColor(percentage)" Value="@percentage" Size="Size.Small" Class="mt-1" />
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.body2">SSP @context.YearToDateUsed.ToString("N0")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Unlimited</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudButtonGroup Variant="Variant.Text" Size="Size.Small">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Href="@($"/insurance/patients/{context.Id}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Href="@($"/insurance/patients/{context.Id}/edit")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Receipt" Color="Color.Secondary" Href="@($"/insurance/claims?patientId={context.Id}")" />
                </MudButtonGroup>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</div>

@code {
    private List<PatientDto> _patients = new();
    private List<ProviderDto> _providers = new();
    private string _searchString = string.Empty;
    private int? _selectedProviderId;
    private string _selectedStatus = "All";

    private IEnumerable<PatientDto> FilteredPatients =>
        _patients.Where(p =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             p.FullName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             p.MemberNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (!_selectedProviderId.HasValue || p.ProviderId == _selectedProviderId.Value) &&
            (_selectedStatus == "All" || p.Status == _selectedStatus)
        );

    protected override void OnInitialized()
    {
        LoadProviders();
        LoadPatients();
    }

    private void LoadProviders()
    {
        _providers = new List<ProviderDto>
        {
            new() { Id = 1, Name = "Phoenix Health Insurance" },
            new() { Id = 2, Name = "National Health Insurance Fund" },
            new() { Id = 3, Name = "Private Health Plans" }
        };
    }

    private void LoadPatients()
    {
        // Sample data
        _patients = new List<PatientDto>
        {
            new() { Id = 1, MemberNumber = "PHX-2024-001", FullName = "Sarah Ayaa", Phone = "+211921234567", ProviderId = 1, ProviderName = "Phoenix Health Insurance", CoverageStartDate = DateTime.Now.AddMonths(-6), AnnualCoverageLimit = 500000, YearToDateUsed = 125000, Status = "Active" },
            new() { Id = 2, MemberNumber = "NHIF-2023-456", FullName = "John Deng", Phone = "+211922345678", ProviderId = 2, ProviderName = "National Health Insurance Fund", CoverageStartDate = DateTime.Now.AddYears(-1), AnnualCoverageLimit = 300000, YearToDateUsed = 280000, Status = "Active" },
            new() { Id = 3, MemberNumber = "PHP-2024-789", FullName = "Grace Nyibol", Phone = "+211923456789", ProviderId = 3, ProviderName = "Private Health Plans", CoverageStartDate = DateTime.Now.AddMonths(-3), AnnualCoverageLimit = 1000000, YearToDateUsed = 45000, Status = "Active" }
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Expired" => Color.Warning,
        "Inactive" => Color.Default,
        _ => Color.Default
    };

    private Color GetUsageColor(double percentage) => percentage switch
    {
        >= 90 => Color.Error,
        >= 75 => Color.Warning,
        _ => Color.Success
    };

    private class PatientDto
    {
        public int Id { get; set; }
        public string MemberNumber { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public int ProviderId { get; set; }
        public string ProviderName { get; set; } = string.Empty;
        public DateTime CoverageStartDate { get; set; }
        public DateTime? CoverageEndDate { get; set; }
        public decimal? AnnualCoverageLimit { get; set; }
        public decimal YearToDateUsed { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private class ProviderDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
