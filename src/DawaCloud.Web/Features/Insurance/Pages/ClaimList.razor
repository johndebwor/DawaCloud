@page "/insurance/claims"
@using MudBlazor

<PageTitle>Insurance Claims - DawaCloud</PageTitle>

<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Insurance Claims</h1>
            <p>Track and manage prescription insurance claims</p>
        </div>
    </div>
</div>

<div class="df-alert-card animate-fade-in-up animate-delay-1 mt-4">
    <MudTable T="ClaimDto" Items="@_claims" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Claim Number</MudTh>
            <MudTh>Patient</MudTh>
            <MudTh>Provider</MudTh>
            <MudTh>Claim Date</MudTh>
            <MudTh>Total Amount</MudTh>
            <MudTh>Covered Amount</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ClaimNumber</MudTd>
            <MudTd>@context.PatientName</MudTd>
            <MudTd>@context.ProviderName</MudTd>
            <MudTd>@context.ClaimDate.ToString("dd MMM yyyy")</MudTd>
            <MudTd>SSP @context.TotalAmount.ToString("N2")</MudTd>
            <MudTd>SSP @context.CoveredAmount.ToString("N2")</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip></MudTd>
        </RowTemplate>
    </MudTable>
</div>

@code {
    private List<ClaimDto> _claims = new();

    protected override void OnInitialized()
    {
        _claims = new List<ClaimDto>
        {
            new() { ClaimNumber = "CLM-2024-001", PatientName = "Sarah Ayaa", ProviderName = "Phoenix Health", ClaimDate = DateTime.Now.AddDays(-5), TotalAmount = 15000, CoveredAmount = 12000, Status = "Approved" },
            new() { ClaimNumber = "CLM-2024-002", PatientName = "John Deng", ProviderName = "NHIF", ClaimDate = DateTime.Now.AddDays(-2), TotalAmount = 8500, CoveredAmount = 5950, Status = "Submitted" }
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Submitted" => Color.Info,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private class ClaimDto
    {
        public string ClaimNumber { get; set; } = string.Empty;
        public string PatientName { get; set; } = string.Empty;
        public string ProviderName { get; set; } = string.Empty;
        public DateTime ClaimDate { get; set; }
        public decimal TotalAmount { get; set; }
        public decimal CoveredAmount { get; set; }
        public string Status { get; set; } = string.Empty;
    }
}
