@page "/wholesale"
@page "/wholesale/customers"
@using MudBlazor
@using MediatR
@using Microsoft.Extensions.Localization
@using DawaCloud.Web.Features.Wholesale.Commands
@using DawaCloud.Web.Features.Wholesale.Queries
@using DawaCloud.Web.Features.Wholesale.Components
@using DawaCloud.Web.Features.Wholesale.Resources
@using Microsoft.JSInterop
@using ClosedXML.Excel
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SalesMessages> Localizer

<PageTitle>@Localizer["PageTitle_Wholesale"]</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">@Localizer["WholesaleCustomers"]</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">@Localizer["ManageB2BCustomers"]</p>
        </div>
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload"
                       OnClick="ExportCustomers">
                @Localizer["Export"]
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateCustomer">
                @Localizer["AddCustomer"]
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">@Localizer["TotalCustomers"]</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_customers.Count</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-accent-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-success);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">@Localizer["ActiveCustomers"]</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_customers.Count(c => c.IsActive)</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning/10">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="color: var(--tw-color-warning);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">@Localizer["TotalOutstanding"]</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_customers.Sum(c => c.CurrentBalance).ToString("N0")</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-danger/10">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color: var(--tw-color-danger);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">@Localizer["OverCreditLimit"]</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_customers.Count(c => c.CurrentBalance > c.CreditLimit)</div>
    </div>
</div>

<!-- Customers Table -->
<div class="dc-card tw:mt-4">
    <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="@Localizer["SearchCustomers"]"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      OnDebounceIntervalElapsed="LoadCustomersAsync"
                      DebounceInterval="300"
                      Style="max-width: 400px;" />
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudSelect T="string" Value="_selectedTier" ValueChanged="OnFilterChanged" Label="@Localizer["PricingTier"]" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">@Localizer["AllTiers"]</MudSelectItem>
                <MudSelectItem Value="@("Retail")">@Localizer["Retail"]</MudSelectItem>
                <MudSelectItem Value="@("Wholesale")">@Localizer["Wholesale"]</MudSelectItem>
                <MudSelectItem Value="@("Bulk")">@Localizer["Bulk"]</MudSelectItem>
                <MudSelectItem Value="@("VIP")">@Localizer["VIP"]</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="CustomerDto" Items="@FilteredCustomers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
        <HeaderContent>
            <MudTh>@Localizer["Code"]</MudTh>
            <MudTh>@Localizer["Customer"]</MudTh>
            <MudTh>@Localizer["Contact"]</MudTh>
            <MudTh>@Localizer["Tier"]</MudTh>
            <MudTh>@Localizer["CreditLimit"]</MudTh>
            <MudTh>@Localizer["Balance"]</MudTh>
            <MudTh>@Localizer["Status"]</MudTh>
            <MudTh>@Localizer["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">
                <MudText Typo="Typo.body2" Class="fw-bold">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel="Customer">
                <div>
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.City</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Contact">
                <div>
                    @if (!string.IsNullOrEmpty(context.Email))
                    {
                        <MudText Typo="Typo.body2">@context.Email</MudText>
                    }
                    @if (!string.IsNullOrEmpty(context.Phone))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Phone</MudText>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Tier">
                <MudChip T="string" Size="Size.Small" Color="@GetTierColor(context.PricingTier)">@context.PricingTier</MudChip>
            </MudTd>
            <MudTd DataLabel="Credit Limit">SSP @context.CreditLimit.ToString("N0")</MudTd>
            <MudTd DataLabel="Balance">
                <MudText Color="@(context.CurrentBalance > context.CreditLimit ? Color.Error : Color.Default)">
                    SSP @context.CurrentBalance.ToString("N0")
                </MudText>
            </MudTd>
            <MudTd DataLabel="@Localizer["Status"]">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                    @(context.IsActive ? Localizer["Active"] : Localizer["Inactive"])
                </MudChip>
            </MudTd>
            <MudTd DataLabel="@Localizer["Actions"]">
                <MudTooltip Text="@Localizer["Edit"]"><MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" OnClick="@(() => EditCustomer(context.Id))" /></MudTooltip>
                <MudTooltip Text="@Localizer["ViewSales"]"><MudIconButton Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Color="Color.Primary" Href="@($"/wholesale/sales?customerId={context.Id}")" /></MudTooltip>
                <MudTooltip Text="@Localizer["Delete"]"><MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteCustomer(context.Id))" /></MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>


@code {
    private List<CustomerDto> _customers = new();
    private string _searchString = string.Empty;
    private string _selectedTier = "All";

    private IEnumerable<CustomerDto> FilteredCustomers => _customers;

    protected override async Task OnInitializedAsync()
    {
        await LoadCustomersAsync();
    }

    private async Task LoadCustomersAsync()
    {
        var query = new GetCustomersQuery(_searchString, _selectedTier, true);
        _customers = await Mediator.Send(query);
    }

    private async Task OnFilterChanged(string value)
    {
        _selectedTier = value;
        await LoadCustomersAsync();
    }

    private Color GetTierColor(string tier) => tier switch
    {
        "VIP" => Color.Primary,
        "Bulk" => Color.Warning,
        "Wholesale" => Color.Info,
        _ => Color.Default
    };

    private async Task CreateCustomer()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = await DialogService.ShowAsync<CustomerDialog>(Localizer["AddCustomer"], parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadCustomersAsync();
        }
    }

    private async Task EditCustomer(int customerId)
    {
        var parameters = new DialogParameters
        {
            { nameof(CustomerDialog.CustomerId), customerId }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };

        var dialog = await DialogService.ShowAsync<CustomerDialog>(Localizer["Edit"], parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadCustomersAsync();
        }
    }

    private async Task DeleteCustomer(int customerId)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            Localizer["ConfirmDeleteCustomer"],
            Localizer["ConfirmDeleteCustomerMessage"],
            yesText: Localizer["Delete"],
            cancelText: Localizer["Cancel"]
        );

        if (confirm == true)
        {
            var command = new DeleteCustomerCommand(customerId);
            var result = await Mediator.Send(command);

            if (result.IsSuccess)
            {
                Snackbar.Add(Localizer["CustomerDeleted"], Severity.Success);
                await LoadCustomersAsync();
            }
            else
            {
                Snackbar.Add(result.Error ?? Localizer["DeleteFailed"], Severity.Error);
            }
        }
    }

    private async Task ExportCustomers()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var ws = workbook.Worksheets.Add("Customers");

            // Header
            ws.Cell(1, 1).Value = Localizer["Code"].Value;
            ws.Cell(1, 2).Value = Localizer["Customer"].Value;
            ws.Cell(1, 3).Value = "City";
            ws.Cell(1, 4).Value = Localizer["Contact"].Value;
            ws.Cell(1, 5).Value = "Phone";
            ws.Cell(1, 6).Value = Localizer["Tier"].Value;
            ws.Cell(1, 7).Value = Localizer["CreditLimit"].Value;
            ws.Cell(1, 8).Value = Localizer["Balance"].Value;
            ws.Cell(1, 9).Value = Localizer["Status"].Value;

            var headerRange = ws.Range(1, 1, 1, 9);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#1565C0");
            headerRange.Style.Font.FontColor = XLColor.White;

            int row = 2;
            foreach (var c in _customers)
            {
                ws.Cell(row, 1).Value = c.Code;
                ws.Cell(row, 2).Value = c.Name;
                ws.Cell(row, 3).Value = c.City;
                ws.Cell(row, 4).Value = c.Email;
                ws.Cell(row, 5).Value = c.Phone;
                ws.Cell(row, 6).Value = c.PricingTier;
                ws.Cell(row, 7).Value = c.CreditLimit;
                ws.Cell(row, 7).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 8).Value = c.CurrentBalance;
                ws.Cell(row, 8).Style.NumberFormat.Format = "#,##0.00";
                ws.Cell(row, 9).Value = c.IsActive ? Localizer["Active"].Value : Localizer["Inactive"].Value;
                row++;
            }

            ws.Columns().AdjustToContents();

            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var bytes = stream.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"Customers_{DateTime.UtcNow:yyyyMMdd_HHmmss}.xlsx";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            Snackbar.Add(Localizer["ExportSuccess"], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(Localizer["ExportFailed"], Severity.Error);
        }
    }
}
