@page "/wholesale/quotations"
@using MudBlazor
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireSalesAccess")]
@using DawaCloud.Web.Features.Wholesale.Commands
@using DawaCloud.Web.Features.Wholesale.Queries
@using DawaCloud.Web.Data.Entities
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IMediator Mediator
@inject IDialogService DialogService

<PageTitle>Quotations - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Quotations</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Manage price quotations and proposals for wholesale customers</p>
        </div>
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateQuotation">
                New Quotation
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.Description" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Total Quotations</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_quotations.Count</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning/10">
                <MudIcon Icon="@Icons.Material.Filled.Pending" Style="color: var(--tw-color-warning);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Pending Response</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_quotations.Count(q => q.Status == QuotationStatus.Sent)</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-accent-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-success);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Accepted</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">@_quotations.Count(q => q.Status == QuotationStatus.Accepted)</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-info/10">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color: var(--tw-color-info);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Total Value</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_quotations.Sum(q => q.TotalAmount).ToString("N0")</div>
    </div>
</div>

<!-- Quotations Table -->
<div class="dc-card tw:mt-4">
    <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search quotations..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      Style="max-width: 400px;" />
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                <MudSelectItem Value="@("Accepted")">Accepted</MudSelectItem>
                <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
                <MudSelectItem Value="@("Expired")">Expired</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center pa-8">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <MudTable T="Queries.QuotationDto" Items="@FilteredQuotations" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
            <HeaderContent>
                <MudTh>Quotation #</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Valid Until</MudTh>
                <MudTh>Items</MudTh>
                <MudTh>Total Amount</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Quotation #">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.QuotationNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Customer">
                    <MudText Typo="Typo.body2">@context.CustomerName</MudText>
                </MudTd>
                <MudTd DataLabel="Date">@context.QuotationDate.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Valid Until">
                    <MudText Color="@(context.IsExpired ? Color.Error : Color.Default)">
                        @context.ValidUntil.ToString("dd MMM yyyy")
                    </MudText>
                    @if (context.IsExpired)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Expired</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Items">@context.ItemCount items</MudTd>
                <MudTd DataLabel="Total Amount">SSP @context.TotalAmount.ToString("N0")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status.ToString()</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="View"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" OnClick="@(() => ViewQuotation(context))" /></MudTooltip>
                    <MudTooltip Text="Duplicate"><MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" Color="Color.Default" OnClick="@(() => DuplicateQuotation(context))" /></MudTooltip>
                    @if (context.Status == QuotationStatus.Accepted && !context.IsExpired && context.ConvertedToSaleId == null)
                    {
                        <MudTooltip Text="Convert to Sale"><MudIconButton Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Color="Color.Success" OnClick="@(() => ConvertToSale(context))" /></MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<QuotationDto> _quotations = new();
    private string _searchString = string.Empty;
    private QuotationStatus? _selectedStatusFilter = null;
    private string _selectedStatus = "All";
    private bool _isLoading = true;

    // KPIs
    private decimal _totalValue => _quotations.Sum(q => q.TotalAmount);
    private int _pendingCount => _quotations.Count(q => q.Status == QuotationStatus.Sent);
    private int _acceptedCount => _quotations.Count(q => q.Status == QuotationStatus.Accepted);

    private IEnumerable<Queries.QuotationDto> FilteredQuotations
    {
        get
        {
            var filtered = _quotations.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_searchString))
            {
                filtered = filtered.Where(q =>
                    q.QuotationNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                    q.CustomerName.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
            }

            if (_selectedStatus != "All" && Enum.TryParse<QuotationStatus>(_selectedStatus, out var status))
            {
                filtered = filtered.Where(q => q.Status == status);
            }

            return filtered;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadQuotationsAsync();
    }

    private async Task LoadQuotationsAsync()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var query = new GetQuotationsQuery(null, null, null, _selectedStatusFilter, _searchString);
            _quotations = await Mediator.Send(query);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading quotations: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private Color GetStatusColor(QuotationStatus status) => status switch
    {
        QuotationStatus.Draft => Color.Default,
        QuotationStatus.Sent => Color.Warning,
        QuotationStatus.Accepted => Color.Success,
        QuotationStatus.Rejected => Color.Error,
        QuotationStatus.Expired => Color.Secondary,
        QuotationStatus.Converted => Color.Info,
        _ => Color.Default
    };

    private void CreateQuotation()
    {
        Navigation.NavigateTo("/wholesale/quotations/new");
    }

    private void ViewQuotation(Queries.QuotationDto quotation)
    {
        Navigation.NavigateTo($"/wholesale/quotations/{quotation.Id}");
    }

    private void DuplicateQuotation(Queries.QuotationDto quotation)
    {
        Snackbar.Add("Duplicate quotation functionality coming soon", Severity.Info);
    }

    private async Task ConvertToSale(Queries.QuotationDto quotation)
    {
        var result = await DialogService.ShowMessageBox(
            "Convert to Sale",
            $"Convert quotation {quotation.QuotationNumber} to a sale order?",
            yesText: "Convert",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var command = new ConvertQuotationToSaleCommand(quotation.Id);
                var conversionResult = await Mediator.Send(command);

                if (conversionResult.IsSuccess)
                {
                    Snackbar.Add("Quotation converted to sale successfully", Severity.Success);
                    Navigation.NavigateTo($"/wholesale/sales/{conversionResult.Value}");
                }
                else
                {
                    Snackbar.Add(conversionResult.Error ?? "Failed to convert quotation", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error converting quotation: {ex.Message}", Severity.Error);
            }
        }
    }
}
