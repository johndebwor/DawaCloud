@page "/wholesale/sales"
@page "/wholesale/invoices"
@using MudBlazor
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireSalesAccess")]
@using MediatR
@using DawaCloud.Web.Features.Wholesale.Commands
@using DawaCloud.Web.Features.Wholesale.Queries
@using DawaCloud.Web.Features.Wholesale.Components
@using DawaCloud.Web.Features.Wholesale.Services
@using DawaCloud.Web.Data.Entities
@using ClosedXML.Excel
@inject IJSRuntime JSRuntime
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IInvoiceService InvoiceService

<PageTitle>Wholesale Sales - DawaCloud</PageTitle>

<!-- Hero Section -->
<div class="dc-hero tw:mb-6">
    <div class="tw:flex tw:items-center tw:justify-between tw:flex-wrap tw:gap-4">
        <div class="tw:flex-1">
            <h1 class="tw:text-2xl tw:font-bold tw:tracking-tight tw:text-text tw:m-0 tw:font-display">Wholesale Sales</h1>
            <p class="tw:text-sm tw:text-text-secondary tw:m-0 tw:mt-1">Manage invoices, orders, and wholesale transactions</p>
        </div>
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload" OnClick="ExportToExcel">
                Export
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Description" Href="/wholesale/quotations">
                Quotations
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/wholesale/sales/new">
                New Sale
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="tw:grid tw:grid-cols-1 sm:tw:grid-cols-2 lg:tw:grid-cols-4 tw:gap-4 tw:my-6">
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-primary-50">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color: var(--tw-color-primary-600);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">This Month's Sales</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_thisMonthTotal.ToString("N0")</div>
        <div class="tw:text-sm tw:text-text-secondary">@_thisMonthCount invoices</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-accent-50">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--tw-color-success);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Paid Invoices</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_paidTotal.ToString("N0")</div>
        <div class="tw:text-sm tw:text-text-secondary">@_paidCount invoices</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-warning/10">
                <MudIcon Icon="@Icons.Material.Filled.Pending" Style="color: var(--tw-color-warning);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Pending Payment</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_pendingTotal.ToString("N0")</div>
        <div class="tw:text-sm tw:text-text-secondary">@_pendingCount invoices</div>
    </div>
    <div class="dc-kpi">
        <div class="tw:flex tw:items-center tw:gap-3">
            <div class="dc-icon-box tw:bg-danger/10">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color: var(--tw-color-danger);" />
            </div>
        </div>
        <div class="tw:text-xs tw:font-medium tw:text-text-secondary tw:uppercase tw:tracking-wide tw:mt-3">Outstanding</div>
        <div class="tw:text-2xl tw:font-bold tw:text-text tw:mt-1 tw:font-display">SSP @_outstandingTotal.ToString("N0")</div>
        <div class="tw:text-sm tw:text-text-secondary">@_outstandingCount invoices</div>
    </div>
</div>

<!-- Sales Table -->
<div class="dc-card tw:mt-4">
    <div class="tw:flex tw:items-center tw:justify-between tw:gap-4 tw:mb-4">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search invoices..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      OnDebounceIntervalElapsed="LoadSalesAsync"
                      DebounceInterval="300"
                      Style="max-width: 400px;" />
        <div class="tw:flex tw:flex-wrap tw:items-center tw:gap-3">
            <MudSelect T="PaymentStatus?" Value="_selectedPayment" ValueChanged="OnFilterChanged" Label="Payment" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem T="PaymentStatus?" Value="null">All</MudSelectItem>
                <MudSelectItem T="PaymentStatus?" Value="PaymentStatus.Pending">Pending</MudSelectItem>
                <MudSelectItem T="PaymentStatus?" Value="PaymentStatus.PartiallyPaid">Partially Paid</MudSelectItem>
                <MudSelectItem T="PaymentStatus?" Value="PaymentStatus.Paid">Paid</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center pa-8">
            <MudProgressCircular Indeterminate="true" />
        </div>
    }
    else
    {
        <MudTable T="SaleDto" Items="@_sales" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
            <HeaderContent>
                <MudTh>Invoice #</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Paid</MudTh>
                <MudTh>Balance</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Payment</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Invoice #">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.InvoiceNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Customer">
                    <MudText Typo="Typo.body2">@context.CustomerName</MudText>
                </MudTd>
                <MudTd DataLabel="Date">@context.SaleDate.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Amount">SSP @context.TotalAmount.ToString("N0")</MudTd>
                <MudTd DataLabel="Paid">SSP @context.PaidAmount.ToString("N0")</MudTd>
                <MudTd DataLabel="Balance">
                    <MudText Color="@(context.BalanceAmount > 0 ? Color.Warning : Color.Success)">
                        SSP @context.BalanceAmount.ToString("N0")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Payment">
                    <MudChip T="string" Size="Size.Small" Color="@GetPaymentColor(context.PaymentStatus)">@context.PaymentStatus</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="Print Invoice"><MudIconButton Icon="@Icons.Material.Filled.Print" Size="Size.Small" Color="Color.Default" OnClick="@(() => PrintInvoice(context))" /></MudTooltip>
                    @if (context.BalanceAmount > 0)
                    {
                        <MudTooltip Text="Record Payment"><MudIconButton Icon="@Icons.Material.Filled.Payment" Size="Size.Small" Color="Color.Success" OnClick="@(() => RecordPayment(context))" /></MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
            </PagerContent>
        </MudTable>
    }
</div>

@code {
    private List<SaleDto> _sales = new();
    private string _searchString = string.Empty;
    private PaymentStatus? _selectedPayment = null;
    private bool _isLoading = true;

    // KPI values
    private decimal _thisMonthTotal = 0;
    private int _thisMonthCount = 0;
    private decimal _paidTotal = 0;
    private int _paidCount = 0;
    private decimal _pendingTotal = 0;
    private int _pendingCount = 0;
    private decimal _outstandingTotal = 0;
    private int _outstandingCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadSalesAsync();
    }

    private async Task LoadSalesAsync()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            var query = new GetSalesQuery(null, null, null, _selectedPayment, _searchString);
            _sales = await Mediator.Send(query);

            CalculateKPIs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sales: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void CalculateKPIs()
    {
        var thisMonth = DateTime.UtcNow.Month;
        var thisMonthSales = _sales.Where(s => s.SaleDate.Month == thisMonth).ToList();

        _thisMonthTotal = thisMonthSales.Sum(s => s.TotalAmount);
        _thisMonthCount = thisMonthSales.Count;

        _paidTotal = _sales.Where(s => s.PaymentStatus == PaymentStatus.Paid).Sum(s => s.PaidAmount);
        _paidCount = _sales.Count(s => s.PaymentStatus == PaymentStatus.Paid);

        _pendingTotal = _sales.Where(s => s.PaymentStatus == PaymentStatus.Pending).Sum(s => s.BalanceAmount);
        _pendingCount = _sales.Count(s => s.PaymentStatus == PaymentStatus.Pending);

        _outstandingTotal = _sales.Sum(s => s.BalanceAmount);
        _outstandingCount = _sales.Count(s => s.BalanceAmount > 0);
    }

    private async Task OnFilterChanged(PaymentStatus? value)
    {
        _selectedPayment = value;
        await LoadSalesAsync();
    }

    private Color GetStatusColor(SaleStatus status) => status switch
    {
        SaleStatus.Draft => Color.Info,
        SaleStatus.Confirmed => Color.Primary,
        SaleStatus.Completed => Color.Success,
        SaleStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private Color GetPaymentColor(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => Color.Success,
        PaymentStatus.PartiallyPaid => Color.Warning,
        PaymentStatus.Pending => Color.Info,
        _ => Color.Default
    };

    private async Task RecordPayment(SaleDto sale)
    {
        var parameters = new DialogParameters
        {
            { nameof(PaymentDialog.SaleId), sale.Id },
            { nameof(PaymentDialog.InvoiceNumber), sale.InvoiceNumber },
            { nameof(PaymentDialog.TotalAmount), sale.TotalAmount },
            { nameof(PaymentDialog.PaidAmount), sale.PaidAmount }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PaymentDialog>("Record Payment", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadSalesAsync();
        }
    }

    private async Task PrintInvoice(SaleDto sale)
    {
        try
        {
            // Generate PDF
            var pdfBytes = await InvoiceService.GenerateInvoicePdfAsync(sale.Id);

            // Convert to base64 for download
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"Invoice_{sale.InvoiceNumber}.pdf";

            // Trigger download via JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error generating invoice: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            if (!_sales.Any())
            {
                Snackbar.Add("No sales to export", Severity.Warning);
                return;
            }

            using var workbook = new XLWorkbook();
            var worksheet = workbook.Worksheets.Add("Wholesale Sales");

            // Add headers
            worksheet.Cell(1, 1).Value = "Invoice Number";
            worksheet.Cell(1, 2).Value = "Customer";
            worksheet.Cell(1, 3).Value = "Sale Date";
            worksheet.Cell(1, 4).Value = "Items";
            worksheet.Cell(1, 5).Value = "Subtotal";
            worksheet.Cell(1, 6).Value = "Tax Amount";
            worksheet.Cell(1, 7).Value = "Discount";
            worksheet.Cell(1, 8).Value = "Total Amount";
            worksheet.Cell(1, 9).Value = "Paid Amount";
            worksheet.Cell(1, 10).Value = "Balance";
            worksheet.Cell(1, 11).Value = "Status";
            worksheet.Cell(1, 12).Value = "Payment Status";

            // Style headers
            var headerRange = worksheet.Range(1, 1, 1, 12);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = XLColor.FromHtml("#00897b");
            headerRange.Style.Font.FontColor = XLColor.White;

            // Add data rows
            int row = 2;
            foreach (var sale in _sales)
            {
                worksheet.Cell(row, 1).Value = sale.InvoiceNumber;
                worksheet.Cell(row, 2).Value = sale.CustomerName;
                worksheet.Cell(row, 3).Value = sale.SaleDate.ToString("dd MMM yyyy");
                worksheet.Cell(row, 4).Value = sale.ItemCount;
                worksheet.Cell(row, 5).Value = sale.SubTotal;
                worksheet.Cell(row, 6).Value = sale.TaxAmount;
                worksheet.Cell(row, 7).Value = sale.DiscountAmount;
                worksheet.Cell(row, 8).Value = sale.TotalAmount;
                worksheet.Cell(row, 9).Value = sale.PaidAmount;
                worksheet.Cell(row, 10).Value = sale.BalanceAmount;
                worksheet.Cell(row, 11).Value = sale.Status.ToString();
                worksheet.Cell(row, 12).Value = sale.PaymentStatus.ToString();
                row++;
            }

            // Format currency columns
            worksheet.Column(5).Style.NumberFormat.Format = "#,##0.00";
            worksheet.Column(6).Style.NumberFormat.Format = "#,##0.00";
            worksheet.Column(7).Style.NumberFormat.Format = "#,##0.00";
            worksheet.Column(8).Style.NumberFormat.Format = "#,##0.00";
            worksheet.Column(9).Style.NumberFormat.Format = "#,##0.00";
            worksheet.Column(10).Style.NumberFormat.Format = "#,##0.00";

            // Auto-fit columns
            worksheet.Columns().AdjustToContents();

            // Convert to base64
            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());

            // Download via JavaScript
            var fileName = $"wholesale-sales-{DateTime.UtcNow:yyyyMMdd-HHmmss}.xlsx";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            Snackbar.Add($"Exported {_sales.Count} sales to Excel", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting to Excel: {ex.Message}", Severity.Error);
        }
    }
}
