@page "/wholesale/sales/new"
@page "/wholesale/sales/{Id:int}"
@using MudBlazor
@using MediatR
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireSalesAccess")]
@using DawaCloud.Web.Features.Wholesale.Commands
@using DawaCloud.Web.Features.Wholesale.Queries
@using DawaCloud.Web.Features.Wholesale.Components
@using DawaCloud.Web.Features.Wholesale.DTOs
@using DawaCloud.Web.Features.Drugs.Queries
@using DawaCloud.Web.Data.Entities
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IMediator Mediator
@inject IDialogService DialogService

<PageTitle>@(_isViewMode ? "Invoice Details" : "New Wholesale Sale") - DawaCloud</PageTitle>

<div class="dc-hero tw:mb-6 animate-fade-in-up">
    <div class="tw:flex tw:flex-wrap tw:justify-between tw:items-center tw:gap-4">
        <div class="tw:flex tw:items-center tw:gap-4">
            <a href="/wholesale/sales" class="dc-btn-secondary">
                <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
                Back
            </a>
            <div>
                <h1 class="tw:text-2xl tw:font-bold tw:font-display tw:tracking-tight tw:text-text tw:m-0">
                    @(_isViewMode ? $"Invoice #{_sale.InvoiceNumber}" : "New Wholesale Sale")
                </h1>
                <p class="tw:text-text-secondary tw:text-sm tw:mt-0.5 tw:m-0">
                    @(_isViewMode ? $"Customer: {_sale.CustomerName}" : "Create a new wholesale invoice")
                </p>
            </div>
        </div>
        <div class="tw:flex tw:items-center tw:gap-2">
            @if (_isViewMode)
            {
                <button class="dc-btn-secondary" @onclick="PrintInvoice">
                    <MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" />
                    Print Invoice
                </button>
                @if (_sale.BalanceAmount > 0)
                {
                    <button class="dc-btn-primary" @onclick="RecordPayment">
                        <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Small" />
                        Record Payment
                    </button>
                }
            }
        </div>
    </div>
</div>

<MudGrid>
    <MudItem xs="12" md="8">
        <div class="dc-card animate-fade-in-up animate-delay-1">
                @if (_isViewMode)
                {
                    <!-- View Mode -->
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Invoice Number</MudText>
                            <MudText Typo="Typo.h6" Class="mb-4">@_sale.InvoiceNumber</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Invoice Date</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_sale.SaleDate.ToString("dd MMM yyyy")</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Customer</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_sale.CustomerName</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_sale.Status)">@_sale.Status</MudChip>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Payment</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetPaymentColor(_sale.PaymentStatus)">@_sale.PaymentStatus</MudChip>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <!-- Create Mode -->
                    <MudForm @ref="_form">
                        <MudText Typo="Typo.h6" Class="mb-4">Customer & Details</MudText>
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" @bind-Value="_selectedCustomerId" Label="Customer" Variant="Variant.Outlined" Required="true">
                                    @foreach (var customer in _customers)
                                    {
                                        <MudSelectItem T="int?" Value="@customer.Id">@customer.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="_deliveryDate" Label="Delivery Date" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_deliveryAddress" Label="Delivery Address" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                }

                <MudDivider Class="my-4" />

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Line Items</MudText>
                    @if (!_isViewMode)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddItem">
                            Add Item
                        </MudButton>
                    }
                </div>

                <MudTable T="DTOs.SaleItemDto" Items="_items" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Drug</MudTh>
                        <MudTh>Batch</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Unit Price</MudTh>
                        <MudTh>Discount</MudTh>
                        <MudTh>Total</MudTh>
                        @if (!_isViewMode)
                        {
                            <MudTh>Actions</MudTh>
                        }
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Drug">
                            <div>
                                <MudText Typo="Typo.body2">@context.DrugName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DrugCode</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Batch">
                            <MudText Typo="Typo.body2">@context.BatchNumber</MudText>
                        </MudTd>
                        <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                        <MudTd DataLabel="Unit Price">SSP @context.UnitPrice.ToString("N2")</MudTd>
                        <MudTd DataLabel="Discount">@context.DiscountPercent%</MudTd>
                        <MudTd DataLabel="Total">SSP @context.LineTotal.ToString("N2")</MudTd>
                        @if (!_isViewMode)
                        {
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveItem(context))" />
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
        </div>
    </MudItem>

    <MudItem xs="12" md="4">
        <!-- Summary Card -->
        <div class="dc-card tw:mb-4 animate-fade-in-up animate-delay-2">
                <MudText Typo="Typo.h6" Class="mb-3">Invoice Summary</MudText>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Subtotal</MudText>
                        <MudText Typo="Typo.body2">SSP @_subtotal.ToString("N2")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Discount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Success">- SSP @_totalDiscount.ToString("N2")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Tax (16%)</MudText>
                        <MudText Typo="Typo.body2">SSP @_taxAmount.ToString("N2")</MudText>
                    </div>
                    <MudDivider Class="my-2" />
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.subtitle1">Total</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">SSP @_grandTotal.ToString("N2")</MudText>
                    </div>
                    
                    @if (_isViewMode)
                    {
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Amount Paid</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success">SSP @_sale.PaidAmount.ToString("N2")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.subtitle1">Balance Due</MudText>
                            <MudText Typo="Typo.h6" Color="@(_sale.BalanceAmount > 0 ? Color.Error : Color.Success)">
                                SSP @_sale.BalanceAmount.ToString("N2")
                            </MudText>
                        </div>
                    }
                </div>
        </div>

        @if (!_isViewMode)
            {
                <div class="d-flex flex-column gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsDraft"
                               Disabled="@(_items.Count == 0)">
                        Save as Draft
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="ConfirmSale"
                               Disabled="@(_items.Count == 0)">
                        Confirm Sale
                    </MudButton>
                </div>
        }
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isViewMode => Id.HasValue;
    private MudForm? _form;
    private Queries.SaleDto _sale = new(0, "", DateTime.UtcNow, 0, "", 0, 0, 0, 0, 0, 0, PaymentStatus.Pending, SaleStatus.Draft, 0);
    private List<DTOs.SaleItemDto> _items = new();
    private List<Wholesale.Queries.CustomerDto> _customers = new();
    private List<Drugs.Queries.DrugListDto> _drugs = new();
    private bool _isLoading = true;
    private bool _isSaving = false;

    private int? _selectedCustomerId;
    private DateTime? _deliveryDate;
    private string _deliveryAddress = string.Empty;
    private string _notes = string.Empty;

    private decimal _subtotal => _items.Sum(i => i.Quantity * i.UnitPrice);
    private decimal _totalDiscount => _items.Sum(i => i.Quantity * i.UnitPrice * i.DiscountPercent / 100);
    private decimal _taxAmount => (_subtotal - _totalDiscount) * 0.16m;
    private decimal _grandTotal => _subtotal - _totalDiscount + _taxAmount;

    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;

            // Load customers
            var customersQuery = new GetCustomersQuery(null, null);
            _customers = await Mediator.Send(customersQuery);

            // Load drugs for item selection
            var drugsQuery = new GetDrugsQuery(null, null, "Active");
            var drugsResult = await Mediator.Send(drugsQuery);
            _drugs = drugsResult.Drugs;

            if (_isViewMode)
            {
                await LoadSaleAsync();
            }

            _breadcrumbItems = new List<BreadcrumbItem>
            {
                new("Home", href: "/"),
                new("Wholesale", href: "/wholesale/sales"),
                new(_isViewMode ? _sale.InvoiceNumber : "New Sale", href: null, disabled: true)
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSaleAsync()
    {
        if (!Id.HasValue) return;

        try
        {
            var query = new GetSaleByIdQuery(Id.Value);
            var result = await Mediator.Send(query);

            if (result != null)
            {
                _sale = result;
                // Convert sale items to editable format if needed
                // This would require extending GetSaleByIdQuery to return line items
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sale: {ex.Message}", Severity.Error);
            Navigation.NavigateTo("/wholesale/sales");
        }
    }

    private async Task AddItem()
    {
        var parameters = new DialogParameters
        {
            { "AvailableDrugs", _drugs }
        };

        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddSaleItemDialog>("Add Item", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is DTOs.SaleItemDto newItem)
        {
            _items.Add(newItem);
            StateHasChanged();
        }
    }

    private void RemoveItem(DTOs.SaleItemDto item)
    {
        _items.Remove(item);
        StateHasChanged();
    }

    private async Task SaveAsDraft()
    {
        await SaveSaleAsync(SaleStatus.Draft);
    }

    private async Task ConfirmSale()
    {
        await SaveSaleAsync(SaleStatus.Confirmed);
    }

    private async Task SaveSaleAsync(SaleStatus status)
    {
        if (!_selectedCustomerId.HasValue)
        {
            Snackbar.Add("Please select a customer", Severity.Warning);
            return;
        }

        if (_items.Count == 0)
        {
            Snackbar.Add("Please add at least one item", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            var saleItems = _items.Select(i => new Commands.SaleItemDto(
                i.DrugId,
                i.BatchId,
                i.Quantity,
                i.UnitPrice
            )).ToList();

            var command = new CreateSaleCommand(
                _selectedCustomerId.Value,
                DateTime.UtcNow,
                saleItems,
                _notes,
                _deliveryAddress
            );

            var result = await Mediator.Send(command);

            if (result.IsSuccess)
            {
                var message = status == SaleStatus.Confirmed ? "Sale confirmed successfully" : "Sale saved as draft";
                Snackbar.Add(message, Severity.Success);
                Navigation.NavigateTo("/wholesale/sales");
            }
            else
            {
                Snackbar.Add(result.Error ?? "Failed to save sale", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving sale: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void PrintInvoice()
    {
        Snackbar.Add("Print invoice - PDF generation coming in next task", Severity.Info);
    }

    private void RecordPayment()
    {
        Snackbar.Add("Record payment - will integrate PaymentDialog", Severity.Info);
    }

    private Color GetStatusColor(SaleStatus status) => status switch
    {
        SaleStatus.Draft => Color.Info,
        SaleStatus.Confirmed => Color.Primary,
        SaleStatus.Completed => Color.Success,
        SaleStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private Color GetPaymentColor(PaymentStatus status) => status switch
    {
        PaymentStatus.Paid => Color.Success,
        PaymentStatus.PartiallyPaid => Color.Warning,
        PaymentStatus.Pending => Color.Info,
        _ => Color.Default
    };
}
