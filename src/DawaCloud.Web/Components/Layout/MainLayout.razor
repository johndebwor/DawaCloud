@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using DawaCloud.Web.Infrastructure.Identity
@using Microsoft.AspNetCore.Localization
@using DawaCloud.Web.Components.Shared
@using DawaCloud.Web.Shared.Extensions
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject DawaCloud.Web.Services.ThemeService ThemeService
@implements IDisposable

@{
    var culture = HttpContextAccessor.HttpContext?.Features
        .Get<IRequestCultureFeature>()?.RequestCulture.Culture;
    var isRtl = culture?.TextInfo.IsRightToLeft ?? false;
    var direction = isRtl ? "rtl" : "ltr";
}

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />

<div dir="@direction" class="@(isRtl ? "rtl-layout" : "")">
<MudLayout>
    <!-- AppBar -->
    <MudAppBar Elevation="0" Dense="false" Class="medical-appbar">
        <div class="medical-appbar-accent"></div>
        <div class="medical-appbar-content">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           Class="medical-menu-btn"
                           OnClick="@(() => _drawerOpen = !_drawerOpen)" />

            <!-- Logo -->
            <div class="medical-logo" @onclick="NavigateHome">
                <div class="medical-logo-mark">
                    <svg viewBox="0 0 32 32" fill="none" class="medical-logo-icon">
                        <rect x="12" y="2" width="8" height="28" rx="3" fill="url(#medicalCross)"/>
                        <rect x="2" y="12" width="28" height="8" rx="3" fill="url(#medicalCross)"/>
                        <defs>
                            <linearGradient id="medicalCross" x1="0" y1="0" x2="32" y2="32">
                                <stop offset="0%" stop-color="#0C8599"/>
                                <stop offset="100%" stop-color="#10B981"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <div class="medical-logo-label">
                    <span class="medical-logo-text">DawaCloud</span>
                    <span class="medical-logo-tag">Pharmacy</span>
                </div>
            </div>

            <div class="medical-spacer"></div>

            <!-- Search trigger -->
            <div class="medical-search"
                 @onclick="@(() => { _commandSearch = string.Empty; _showCommandPalette = true; })">
                <div class="medical-search-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                </div>
                <span>Search commands, drugs...</span>
                <kbd class="medical-search-kbd">Ctrl+K</kbd>
            </div>

            <!-- Mobile search icon -->
            <MudIconButton Icon="@Icons.Material.Filled.Search"
                           Color="Color.Inherit"
                           Class="medical-mobile-search"
                           OnClick="@(() => { _commandSearch = string.Empty; _showCommandPalette = true; })" />

            <div class="medical-toolbar-divider"></div>

            <!-- Dark Mode Toggle -->
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           Class="medical-toolbar-btn"
                           OnClick="ToggleTheme"
                           Title="@(_isDarkMode ? "Switch to light mode" : "Switch to dark mode")" />

            <!-- Notifications -->
            <MudIconButton Icon="@Icons.Material.Filled.NotificationsNone"
                           Color="Color.Inherit"
                           Class="medical-toolbar-btn"
                           OnClick="ToggleNotifications">
                @if (_notificationCount > 0)
                {
                    <MudBadge Content="@_notificationCount" Color="Color.Error" Overlap="true" />
                }
            </MudIconButton>

            <!-- User Menu -->
            <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                <ActivatorContent>
                    <div class="medical-user-chip">
                        <div class="medical-user-avatar">
                            @_userInitials
                        </div>
                        <div class="medical-user-chip-info">
                            <span class="medical-user-chip-name">@_userName</span>
                            <span class="medical-user-chip-role">@_userRole</span>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Style="color: var(--tw-color-text-muted); margin-left: 2px;" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Disabled="true">
                        <div class="medical-user-info">
                            <div class="medical-user-name">@_userName</div>
                            <div class="medical-user-email">@_userEmail</div>
                        </div>
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Person" OnClick="NavigateToProfile">
                        My Profile
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="NavigateToSettings">
                        Settings
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Help" OnClick="NavigateToHelp">
                        Help & Support
                    </MudMenuItem>
                    <MudDivider />
                    <div style="padding: 8px 12px;">
                        <LanguageSelector />
                    </div>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" OnClick="HandleSignOut">
                        Sign Out
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        </div>
    </MudAppBar>

    <!-- Navigation Drawer -->
    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               ClipMode="DrawerClipMode.Always"
               Width="260px"
               Class="medical-drawer">
        <div class="medical-drawer-content">
            <!-- Navigation Menu -->
            <MudNavMenu Class="medical-nav-menu">
                <!-- Dashboard -->
                <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                    Dashboard
                </MudNavLink>

                <!-- Pharmacy -->
                <MudNavGroup Title="Pharmacy" Icon="@Icons.Material.Filled.LocalPharmacy" Expanded="true">
                    <MudNavLink Href="/drugs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Medication">
                        Drugs
                    </MudNavLink>
                    <MudNavLink Href="/categories" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Category">
                        Categories
                    </MudNavLink>
                    <MudNavLink Href="/batches" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QrCode2">
                        Batches
                    </MudNavLink>
                </MudNavGroup>

                <!-- Inventory -->
                <MudNavGroup Title="Inventory" Icon="@Icons.Material.Filled.Warehouse">
                    <MudNavLink Href="/inventory/stock-levels" Icon="@Icons.Material.Filled.Inventory2">
                        Stock Levels
                    </MudNavLink>
                    <MudNavLink Href="/inventory/movements" Icon="@Icons.Material.Filled.LocalShipping">
                        Movements
                    </MudNavLink>
                    <MudNavLink Href="/inventory/stock-counts" Icon="@Icons.Material.Filled.Checklist">
                        Stock Counts
                    </MudNavLink>
                    <MudNavLink Href="/inventory/adjustments/new" Icon="@Icons.Material.Filled.Tune">
                        Adjustments
                    </MudNavLink>
                </MudNavGroup>

                <!-- Procurement -->
                <MudNavGroup Title="Procurement" Icon="@Icons.Material.Filled.ShoppingCart">
                    <MudNavLink Href="/suppliers" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Store">
                        Suppliers
                    </MudNavLink>
                    <MudNavLink Href="/procurement/requests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RequestQuote">
                        Purchase Orders
                    </MudNavLink>
                </MudNavGroup>

                <!-- Sales -->
                <MudNavGroup Title="Sales" Icon="@Icons.Material.Filled.Storefront">
                    <MudNavLink Href="/pos" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PointOfSale">
                        Point of Sale
                    </MudNavLink>
                    <MudNavLink Href="/wholesale/customers" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Business">
                        Wholesale Customers
                    </MudNavLink>
                    <MudNavLink Href="/wholesale/sales" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Receipt">
                        Wholesale Sales
                    </MudNavLink>
                </MudNavGroup>

                <!-- Finance -->
                <MudNavGroup Title="Finance" Icon="@Icons.Material.Filled.AccountBalance">
                    <MudNavLink Href="/finance/expenses" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CreditCard">
                        Expenses
                    </MudNavLink>
                    <MudNavLink Href="/finance/bank-accounts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                        Bank Accounts
                    </MudNavLink>
                </MudNavGroup>

                <!-- Analytics -->
                <MudNavGroup Title="Analytics & Reports" Icon="@Icons.Material.Filled.Insights">
                    <MudNavLink Href="/reports" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Assessment">
                        Reports
                    </MudNavLink>
                    <MudNavLink Href="/analytics" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Analytics">
                        Advanced Analytics
                    </MudNavLink>
                    <MudNavLink Href="/audit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">
                        Audit Logs
                    </MudNavLink>
                </MudNavGroup>

                <!-- AI & Tools -->
                <MudNavGroup Title="AI & Tools" Icon="@Icons.Material.Filled.AutoAwesome">
                    <MudNavLink Href="/chat" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SmartToy">
                        AI Assistant
                    </MudNavLink>
                </MudNavGroup>

                <!-- HR -->
                <MudNavGroup Title="HR" Icon="@Icons.Material.Filled.Badge">
                    <MudNavLink Href="/hr/employees" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonSearch">
                        Employees
                    </MudNavLink>
                    <MudNavLink Href="/hr/departments" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Business">
                        Departments
                    </MudNavLink>
                    <MudNavLink Href="/hr/attendance" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccessTime">
                        Attendance
                    </MudNavLink>
                    <MudNavLink Href="/hr/leave" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EventBusy">
                        Leave Requests
                    </MudNavLink>
                </MudNavGroup>

                <!-- System -->
                <MudNavGroup Title="System" Icon="@Icons.Material.Filled.Settings">
                    <MudNavLink Href="/users" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
                        Users
                    </MudNavLink>
                    <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SettingsApplications">
                        Settings
                    </MudNavLink>
                </MudNavGroup>
            </MudNavMenu>
        </div>
    </MudDrawer>

    <!-- Main Content -->
    <MudMainContent Class="medical-main-content">
        <div class="medical-content-wrapper">
            @Body
        </div>
    </MudMainContent>

    <!-- Notification Drawer -->
    <MudDrawer @bind-Open="_showNotifications"
               Anchor="Anchor.Right"
               Elevation="0"
               Width="340px"
               Class="medical-notification-drawer">
        <div class="medical-notification-header">
            <div class="medical-notification-title">Notifications</div>
        </div>
        <div class="medical-notification-list">
            @if (_notifications.Any())
            {
                @foreach (var notif in _notifications)
                {
                    <div class="medical-notification-item">
                        <div class="medical-notification-item-title">@notif.Title</div>
                        <div class="medical-notification-item-message">@notif.Message</div>
                        <div class="medical-notification-item-time">@notif.Time</div>
                    </div>
                }
            }
            else
            {
                <div class="medical-notification-empty">
                    <div class="medical-notification-empty-icon">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Size="Size.Large" Color="Color.Default" />
                    </div>
                    <div class="medical-notification-empty-text">No new notifications</div>
                </div>
            }
        </div>
    </MudDrawer>
</MudLayout>
</div>

<!-- RTL Support -->
<style>
    .rtl-layout .mud-drawer { right: 0; left: auto; }
</style>

<!-- Command Palette -->
<MudDialog @bind-Visible="_showCommandPalette" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, NoHeader = true, CloseButton = false })" Class="medical-command-palette">
    <DialogContent>
        <div class="medical-command-search">
            <MudTextField @bind-Value="_commandSearch"
                          Placeholder="Search commands, drugs, reports..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Immediate="true"
                          AutoFocus="true" />
        </div>
        <MudDivider />
        <div class="medical-command-results">
            @if (string.IsNullOrWhiteSpace(_commandSearch))
            {
                <MudList T="string" Dense="true">
                    <MudListSubheader>Quick Actions</MudListSubheader>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.PointOfSale" OnClick="@(() => NavigateCommand("/pos"))">New Sale (POS)</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Add" OnClick="@(() => NavigateCommand("/drugs/new"))">New Drug</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping" OnClick="@(() => NavigateCommand("/procurement/goods-receipts/new"))">Receive Stock</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Description" OnClick="@(() => NavigateCommand("/reports"))">Generate Report</MudListItem>
                    <MudListSubheader>Navigation</MudListSubheader>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Dashboard" OnClick="@(() => NavigateCommand("/dashboard"))">Dashboard</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Inventory" OnClick="@(() => NavigateCommand("/inventory/stock-levels"))">Stock Levels</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Store" OnClick="@(() => NavigateCommand("/suppliers"))">Suppliers</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Settings" OnClick="@(() => NavigateCommand("/settings"))">Settings</MudListItem>
                </MudList>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in GetFilteredCommands())
                    {
                        <MudListItem T="string" Icon="@item.Icon" OnClick="@(() => NavigateCommand(item.Url))">@item.Label</MudListItem>
                    }
                </MudList>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    private bool _drawerOpen = true;
    private string _searchText = string.Empty;
    private int _notificationCount = 0;
    private bool _isDarkMode;
    private MudTheme _theme = MudThemeConfiguration.DawaFlowTheme;

    // Notification drawer
    private bool _showNotifications = false;
    private List<NotificationItem> _notifications = new();

    // Command palette
    private bool _showCommandPalette = false;
    private string _commandSearch = string.Empty;

    private static readonly List<CommandItem> _allCommands = new()
    {
        new("New Sale (POS)", "/pos", Icons.Material.Filled.PointOfSale),
        new("New Drug", "/drugs/new", Icons.Material.Filled.Add),
        new("Receive Stock", "/procurement/goods-receipts/new", Icons.Material.Filled.LocalShipping),
        new("Generate Report", "/reports", Icons.Material.Filled.Description),
        new("Dashboard", "/dashboard", Icons.Material.Filled.Dashboard),
        new("Stock Levels", "/inventory/stock-levels", Icons.Material.Filled.Inventory),
        new("Stock Movements", "/inventory/movements", Icons.Material.Filled.History),
        new("Stock Counts", "/inventory/stock-counts", Icons.Material.Filled.Rule),
        new("Drugs", "/drugs", Icons.Material.Filled.Medication),
        new("Categories", "/categories", Icons.Material.Filled.Category),
        new("Batches", "/batches", Icons.Material.Filled.LocalOffer),
        new("Suppliers", "/suppliers", Icons.Material.Filled.Store),
        new("Procurement", "/procurement/requests", Icons.Material.Filled.ShoppingCart),
        new("Wholesale Customers", "/wholesale/customers", Icons.Material.Filled.People),
        new("Wholesale Sales", "/wholesale/sales", Icons.Material.Filled.Business),
        new("Expenses", "/finance/expenses", Icons.Material.Filled.Receipt),
        new("Bank Accounts", "/finance/bank-accounts", Icons.Material.Filled.AccountBalance),
        new("Reports", "/reports", Icons.Material.Filled.Assessment),
        new("Advanced Analytics", "/analytics", Icons.Material.Filled.Analytics),
        new("AI Assistant", "/chat", Icons.Material.Filled.SmartToy),
        new("Audit Logs", "/audit", Icons.Material.Filled.History),
        new("Users", "/users", Icons.Material.Filled.People),
        new("Settings", "/settings", Icons.Material.Filled.Settings),
        new("My Profile", "/profile", Icons.Material.Filled.Person),
        new("Help & Support", "/help", Icons.Material.Filled.Help),
    };

    // User info from authentication state
    private string _userName = string.Empty;
    private string _userEmail = string.Empty;
    private string _userRole = string.Empty;
    private string _userInitials => GetUserInitials();

    protected override async Task OnInitializedAsync()
    {
        ThemeService.OnThemeChanged += HandleThemeChanged;
        await LoadUserInfoAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            _isDarkMode = ThemeService.IsDarkMode;
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
        _isDarkMode = ThemeService.IsDarkMode;
    }

    private void HandleThemeChanged()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }

    private async Task LoadUserInfoAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var claimsPrincipal = authState.User;

        if (claimsPrincipal.Identity?.IsAuthenticated == true)
        {
            _userEmail = claimsPrincipal.Identity.Name ?? "User";

            var firstName = claimsPrincipal.FindFirst("FirstName")?.Value ?? string.Empty;
            var lastName = claimsPrincipal.FindFirst("LastName")?.Value ?? string.Empty;

            if (!string.IsNullOrEmpty(firstName) || !string.IsNullOrEmpty(lastName))
                _userName = $"{firstName} {lastName}".Trim();
            else
                _userName = _userEmail.Contains('@') ? _userEmail.Split('@')[0] : _userEmail;

            _userRole = claimsPrincipal.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
        }
        else
        {
            _userName = "Guest";
            _userEmail = "";
            _userRole = "";
        }
    }

    private string GetUserInitials()
    {
        if (string.IsNullOrWhiteSpace(_userName))
            return "?";

        var parts = _userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        else if (parts.Length == 1 && parts[0].Length > 0)
            return parts[0][0].ToString().ToUpper();
        return "?";
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void NavigateHome()
    {
        NavigationManager.NavigateTo("/dashboard");
    }

    private void HandleSignOut()
    {
        NavigationManager.NavigateTo("/api/auth/logout", forceLoad: true);
    }

    private void ToggleNotifications()
    {
        _showNotifications = !_showNotifications;
    }

    private IEnumerable<CommandItem> GetFilteredCommands()
    {
        if (string.IsNullOrWhiteSpace(_commandSearch)) return _allCommands;
        return _allCommands.Where(c => c.Label.Contains(_commandSearch, StringComparison.OrdinalIgnoreCase));
    }

    private void NavigateCommand(string url)
    {
        _showCommandPalette = false;
        NavigationManager.NavigateTo(url);
    }

    private void NavigateToProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/settings");
    }

    private void NavigateToHelp()
    {
        NavigationManager.NavigateTo("/help");
    }

    private record NotificationItem(string Title, string Message, string Time, string Color, bool IsRead);
    private record CommandItem(string Label, string Url, string Icon);
}
