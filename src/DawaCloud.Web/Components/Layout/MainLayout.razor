@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using DawaCloud.Web.Infrastructure.Identity
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<MudLayout Class="df-layout">
    <!-- Enhanced App Bar -->
    <MudAppBar Elevation="0" Dense="false" Class="df-appbar">
        <!-- Logo Section -->
        <div class="df-logo" @onclick="NavigateHome">
            <div class="df-logo-icon">
                <MudIcon Icon="@Icons.Material.Filled.Medication" Size="Size.Small" />
            </div>
            <span class="df-logo-text">DawaCloud</span>
        </div>

        <MudSpacer />

        <!-- Enhanced Search Field -->
        <div class="df-search-container d-none d-md-flex" @onclick="@(() => { _commandSearch = string.Empty; _showCommandPalette = true; })" style="cursor: pointer;">
            <MudIcon Icon="@Icons.Material.Filled.Search" Class="df-search-icon" Size="Size.Small" />
            <span class="df-search-field" style="line-height: 1.5; color: var(--df-text-tertiary);">Search drugs, actions, reports...</span>
            <div class="df-search-shortcut">
                <span>Ctrl</span>
                <span>K</span>
            </div>
        </div>

        <MudSpacer />

        <!-- Mobile Search Icon -->
        <MudIconButton Icon="@Icons.Material.Filled.Search"
                       Color="Color.Default"
                       Class="d-md-none" />

        <!-- Notification Button -->
        <div class="df-notification-btn" @onclick="ToggleNotifications">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" />
            @if (_notificationCount > 0)
            {
                <span class="df-notification-badge">@(_notificationCount > 9 ? "9+" : _notificationCount.ToString())</span>
            }
        </div>

        <!-- User Menu -->
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <div class="df-user-menu">
                    <div class="df-user-avatar">
                        @_userInitials
                    </div>
                    <div class="df-user-info d-none d-lg-block">
                        <div class="df-user-name">@_userName</div>
                        <div class="df-user-role">@_userRole</div>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown"
                             Size="Size.Small"
                             Class="d-none d-lg-block"
                             Style="color: var(--df-text-tertiary);" />
                </div>
            </ActivatorContent>
            <ChildContent>
                <div style="padding: 16px; background: var(--df-gradient-primary); color: white; min-width: 200px;">
                    <div style="font-weight: 600;">@_userName</div>
                    <div style="font-size: 0.8rem; opacity: 0.85;">@_userEmail</div>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Person" IconColor="Color.Default" OnClick="NavigateToProfile">
                    My Profile
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Settings" IconColor="Color.Default" OnClick="NavigateToSettings">
                    Settings
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Help" IconColor="Color.Default" OnClick="NavigateToHelp">
                    Help & Support
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" OnClick="HandleSignOut">
                    Sign Out
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <!-- Enhanced Navigation Drawer -->
    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="@(_drawerOpen ? DrawerVariant.Persistent : DrawerVariant.Mini)"
               ClipMode="DrawerClipMode.Always"
               Width="260px"
               MiniWidth="80px"
               Class="df-drawer"
               @onmouseenter="OnDrawerMouseEnter"
               @onmouseleave="OnDrawerMouseLeave">
        <div class="d-flex flex-column" style="height: 100%;">
            <!-- Drawer Header -->
            <div class="df-drawer-header">
                @if (_drawerOpen)
                {
                    <span style="font-weight: 600; color: var(--df-text-primary);">Navigation</span>
                }
                <MudIconButton Icon="@(_drawerOpen ? Icons.Material.Filled.ChevronLeft : Icons.Material.Filled.Menu)"
                               Color="Color.Default"
                               OnClick="ToggleDrawer"
                               Size="Size.Small"
                               Style="margin-left: auto;" />
            </div>

            <!-- Navigation Menu -->
            <div class="df-nav-section" style="flex: 1; overflow-y: auto;">
                @if (NavExpanded)
                {
                    <div class="df-nav-section-title">Main Menu</div>
                }

                <MudNavMenu>
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                        @if (NavExpanded) { <span>Dashboard</span> }
                    </MudNavLink>
                    <MudNavLink Href="/drugs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Medication">
                        @if (NavExpanded) { <span>Drugs</span> }
                    </MudNavLink>
                    <MudNavLink Href="/categories" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Category">
                        @if (NavExpanded) { <span>Categories</span> }
                    </MudNavLink>
                    <MudNavLink Href="/batches" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalOffer">
                        @if (NavExpanded) { <span>Batches</span> }
                    </MudNavLink>
                    @if (NavExpanded)
                    {
                        <MudNavGroup Title="Inventory" Icon="@Icons.Material.Filled.Inventory" Expanded="@_inventoryExpanded" ExpandedChanged="@((bool expanded) => _inventoryExpanded = expanded)">
                            <MudNavLink Href="/inventory/stock-levels" Match="NavLinkMatch.All">Stock Levels</MudNavLink>
                            <MudNavLink Href="/inventory/movements" Match="NavLinkMatch.All">Stock Movements</MudNavLink>
                            <MudNavLink Href="/inventory/stock-counts" Match="NavLinkMatch.All">Stock Counts</MudNavLink>
                            <MudNavLink Href="/inventory/adjustments/new" Match="NavLinkMatch.All">Adjustments</MudNavLink>
                        </MudNavGroup>
                    }
                    else
                    {
                        <MudNavLink Href="/inventory/stock-levels" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Inventory">
                        </MudNavLink>
                    }
                    <MudNavLink Href="/suppliers" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Store">
                        @if (NavExpanded) { <span>Suppliers</span> }
                    </MudNavLink>
                    <MudNavLink Href="/procurement/requests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ShoppingCart">
                        @if (NavExpanded) { <span>Procurement</span> }
                    </MudNavLink>
                </MudNavMenu>

                @if (NavExpanded)
                {
                    <div class="df-nav-section-title" style="margin-top: 16px;">Sales</div>
                }

                <MudNavMenu>
                    <MudNavLink Href="/pos" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PointOfSale">
                        @if (NavExpanded) { <span>Point of Sale</span> }
                    </MudNavLink>
                    @if (NavExpanded)
                    {
                        <MudNavGroup Title="Wholesale" Icon="@Icons.Material.Filled.Business" Expanded="@_wholesaleExpanded" ExpandedChanged="@((bool expanded) => _wholesaleExpanded = expanded)">
                            <MudNavLink Href="/wholesale/customers" Match="NavLinkMatch.All">Customers</MudNavLink>
                            <MudNavLink Href="/wholesale/sales" Match="NavLinkMatch.All">Sales & Invoices</MudNavLink>
                        </MudNavGroup>
                    }
                    else
                    {
                        <MudNavLink Href="/wholesale" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Business">
                        </MudNavLink>
                    }
                </MudNavMenu>

                @if (NavExpanded)
                {
                    <div class="df-nav-section-title" style="margin-top: 16px;">Analytics</div>
                }

                <MudNavMenu>
                    <MudNavLink Href="/reports" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Assessment">
                        @if (NavExpanded) { <span>Reports</span> }
                    </MudNavLink>
                    <MudNavLink Href="/audit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">
                        @if (NavExpanded) { <span>Audit Logs</span> }
                    </MudNavLink>
                </MudNavMenu>

                @if (NavExpanded)
                {
                    <div class="df-nav-section-title" style="margin-top: 16px;">System</div>
                }

                <MudNavMenu>
                    <MudNavLink Href="/users" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
                        @if (NavExpanded) { <span>Users</span> }
                    </MudNavLink>
                    <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">
                        @if (NavExpanded) { <span>Settings</span> }
                    </MudNavLink>
                </MudNavMenu>
            </div>

            <!-- Drawer Footer -->
            @if (NavExpanded)
            {
                <div class="df-drawer-footer">
                    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--df-surface-variant); border-radius: var(--df-border-radius); margin-bottom: 12px; cursor: pointer;"
                         @onclick="NavigateToHelp">
                        <MudIcon Icon="@Icons.Material.Filled.Help" Size="Size.Small" Style="color: var(--df-primary-500);" />
                        <div>
                            <div style="font-size: 0.8125rem; font-weight: 600; color: var(--df-text-primary);">Need Help?</div>
                            <div style="font-size: 0.75rem; color: var(--df-text-tertiary);">Check our documentation</div>
                        </div>
                    </div>
                    <div class="df-version">DawaCloud v1.0.0</div>
                </div>
            }
        </div>
    </MudDrawer>

    <!-- Main Content -->
    <MudMainContent Class="df-main-content">
        <div class="df-content-wrapper">
            @Body
        </div>
    </MudMainContent>

    <!-- Notification Drawer (right slide-out) -->
    <MudDrawer @bind-Open="_showNotifications"
               Anchor="Anchor.Right"
               Elevation="4"
               Width="360px"
               Class="df-notification-drawer">
        <div style="padding: 16px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--df-border);">
            <MudText Typo="Typo.h6">Notifications</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _showNotifications = false)" />
        </div>
        <div style="padding: 8px; overflow-y: auto; flex: 1;">
            @foreach (var notif in _notifications)
            {
                <div style="padding: 12px; border-radius: 8px; margin: 4px 0; background: @(notif.IsRead ? "transparent" : "var(--df-primary-50)"); border-left: 3px solid @notif.Color;">
                    <div style="font-size: 0.875rem; font-weight: 600;">@notif.Title</div>
                    <div style="font-size: 0.8rem; color: var(--df-text-secondary);">@notif.Message</div>
                    <div style="font-size: 0.75rem; color: var(--df-text-tertiary); margin-top: 4px;">@notif.Time</div>
                </div>
            }
            @if (!_notifications.Any())
            {
                <div class="text-center pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Color="Color.Secondary" Class="mt-2">No notifications</MudText>
                </div>
            }
        </div>
    </MudDrawer>
</MudLayout>

<!-- Command Palette Dialog -->
<MudDialog @bind-Visible="_showCommandPalette" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, NoHeader = true })">
    <DialogContent>
        <div class="pa-2">
            <MudTextField @bind-Value="_commandSearch"
                          Placeholder="Search commands, drugs, reports..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Immediate="true"
                          AutoFocus="true" />
        </div>
        <MudDivider />
        <div style="max-height: 400px; overflow-y: auto;">
            @if (string.IsNullOrWhiteSpace(_commandSearch))
            {
                <MudList T="string" Dense="true">
                    <MudListSubheader>Quick Actions</MudListSubheader>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.PointOfSale" OnClick="@(() => NavigateCommand("/pos"))">New Sale (POS)</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Add" OnClick="@(() => NavigateCommand("/drugs/new"))">New Drug</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.LocalShipping" OnClick="@(() => NavigateCommand("/procurement/goods-receipts/new"))">Receive Stock</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Description" OnClick="@(() => NavigateCommand("/reports"))">Generate Report</MudListItem>
                    <MudListSubheader>Navigation</MudListSubheader>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Dashboard" OnClick="@(() => NavigateCommand("/"))">Dashboard</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Inventory" OnClick="@(() => NavigateCommand("/inventory/stock-levels"))">Stock Levels</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Store" OnClick="@(() => NavigateCommand("/suppliers"))">Suppliers</MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Settings" OnClick="@(() => NavigateCommand("/settings"))">Settings</MudListItem>
                </MudList>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in GetFilteredCommands())
                    {
                        <MudListItem T="string" Icon="@item.Icon" OnClick="@(() => NavigateCommand(item.Url))">@item.Label</MudListItem>
                    }
                </MudList>
            }
        </div>
    </DialogContent>
</MudDialog>

<style>
    .df-layout {
        min-height: 100vh;
        background: var(--df-background);
    }

    .df-main-content {
        background: linear-gradient(180deg, var(--df-surface-variant) 0%, var(--df-background) 100%);
        min-height: calc(100vh - 64px);
    }

    .df-content-wrapper {
        max-width: 1600px;
        margin: 0 auto;
        padding: 24px;
    }

    /* Enhanced MudNavLink styles */
    .mud-nav-link {
        border-radius: var(--df-border-radius) !important;
        margin: 4px 8px !important;
        padding: 12px 16px !important;
        transition: all var(--df-transition-normal) !important;
        position: relative;
        overflow: hidden;
    }

    .mud-nav-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 3px;
        height: 0;
        background: var(--df-gradient-primary);
        border-radius: 0 4px 4px 0;
        transition: height var(--df-transition-normal);
    }

    .mud-nav-link:hover {
        background: var(--df-primary-50) !important;
    }

    .mud-nav-link:hover::before {
        height: 50%;
    }

    .mud-nav-link.active {
        background: var(--df-primary-50) !important;
        color: var(--df-primary-700) !important;
        font-weight: 600 !important;
    }

    .mud-nav-link.active::before {
        height: 70%;
    }

    .mud-nav-link .mud-icon-root {
        transition: all var(--df-transition-normal);
    }

    .mud-nav-link:hover .mud-icon-root,
    .mud-nav-link.active .mud-icon-root {
        color: var(--df-primary-600) !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 960px) {
        .df-content-wrapper {
            padding: 16px;
        }
    }
</style>

@code {
    private bool _drawerOpen = false;
    private bool _drawerHovered = false;
    private bool NavExpanded => _drawerOpen || _drawerHovered;
    private string _searchText = string.Empty;
    private int _notificationCount = 0;

    // Navigation group expansion state
    private bool _inventoryExpanded = false;
    private bool _wholesaleExpanded = false;

    // Notification drawer
    private bool _showNotifications = false;
    private List<NotificationItem> _notifications = new();

    // Command palette
    private bool _showCommandPalette = false;
    private string _commandSearch = string.Empty;

    private static readonly List<CommandItem> _allCommands = new()
    {
        new("New Sale (POS)", "/pos", Icons.Material.Filled.PointOfSale),
        new("New Drug", "/drugs/new", Icons.Material.Filled.Add),
        new("Receive Stock", "/procurement/goods-receipts/new", Icons.Material.Filled.LocalShipping),
        new("Generate Report", "/reports", Icons.Material.Filled.Description),
        new("Dashboard", "/", Icons.Material.Filled.Dashboard),
        new("Stock Levels", "/inventory/stock-levels", Icons.Material.Filled.Inventory),
        new("Stock Movements", "/inventory/movements", Icons.Material.Filled.History),
        new("Stock Counts", "/inventory/stock-counts", Icons.Material.Filled.Rule),
        new("Drugs", "/drugs", Icons.Material.Filled.Medication),
        new("Categories", "/categories", Icons.Material.Filled.Category),
        new("Batches", "/batches", Icons.Material.Filled.LocalOffer),
        new("Suppliers", "/suppliers", Icons.Material.Filled.Store),
        new("Procurement", "/procurement/requests", Icons.Material.Filled.ShoppingCart),
        new("Wholesale Customers", "/wholesale/customers", Icons.Material.Filled.People),
        new("Wholesale Sales", "/wholesale/sales", Icons.Material.Filled.Business),
        new("Reports", "/reports", Icons.Material.Filled.Assessment),
        new("Audit Logs", "/audit", Icons.Material.Filled.History),
        new("Users", "/users", Icons.Material.Filled.People),
        new("Settings", "/settings", Icons.Material.Filled.Settings),
        new("My Profile", "/profile", Icons.Material.Filled.Person),
        new("Help & Support", "/help", Icons.Material.Filled.Help),
    };

    // User info from authentication state
    private string _userName = string.Empty;
    private string _userEmail = string.Empty;
    private string _userRole = string.Empty;
    private string _userInitials => GetUserInitials();

    protected override async Task OnInitializedAsync()
    {
        await LoadUserInfoAsync();
    }

    private async Task LoadUserInfoAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var claimsPrincipal = authState.User;

        if (claimsPrincipal.Identity?.IsAuthenticated == true)
        {
            _userEmail = claimsPrincipal.Identity.Name ?? "User";

            var firstName = claimsPrincipal.FindFirst("FirstName")?.Value ?? string.Empty;
            var lastName = claimsPrincipal.FindFirst("LastName")?.Value ?? string.Empty;

            if (!string.IsNullOrEmpty(firstName) || !string.IsNullOrEmpty(lastName))
                _userName = $"{firstName} {lastName}".Trim();
            else
                _userName = _userEmail.Contains('@') ? _userEmail.Split('@')[0] : _userEmail;

            _userRole = claimsPrincipal.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
        }
        else
        {
            _userName = "Guest";
            _userEmail = "";
            _userRole = "";
        }
    }

    private string GetUserInitials()
    {
        if (string.IsNullOrWhiteSpace(_userName))
            return "?";

        var parts = _userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        else if (parts.Length == 1 && parts[0].Length > 0)
            return parts[0][0].ToString().ToUpper();
        return "?";
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void NavigateHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private void HandleSignOut()
    {
        NavigationManager.NavigateTo("/api/auth/logout", forceLoad: true);
    }

    private void ToggleNotifications()
    {
        _showNotifications = !_showNotifications;
    }

    private void OnDrawerMouseEnter()
    {
        if (!_drawerOpen)
            _drawerHovered = true;
    }

    private void OnDrawerMouseLeave()
    {
        _drawerHovered = false;
    }

    private IEnumerable<CommandItem> GetFilteredCommands()
    {
        if (string.IsNullOrWhiteSpace(_commandSearch)) return _allCommands;
        return _allCommands.Where(c => c.Label.Contains(_commandSearch, StringComparison.OrdinalIgnoreCase));
    }

    private void NavigateCommand(string url)
    {
        _showCommandPalette = false;
        NavigationManager.NavigateTo(url);
    }

    private void NavigateToProfile()
    {
        NavigationManager.NavigateTo("/profile");
    }

    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/settings");
    }

    private void NavigateToHelp()
    {
        NavigationManager.NavigateTo("/help");
    }

    private record NotificationItem(string Title, string Message, string Time, string Color, bool IsRead);
    private record CommandItem(string Label, string Url, string Icon);
}
