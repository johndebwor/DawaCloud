@inherits LayoutComponentBase
@using DawaCloud.Web.Shared.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="modern-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       Class="d-lg-none" />

        <MudText Typo="Typo.h6" Class="ml-3 modern-logo">DawaCloud</MudText>

        <MudSpacer />

        <MudTextField @bind-Value="_searchQuery"
                      Placeholder="Search drugs, actions... (⌘K)"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="modern-search mx-4"
                      OnKeyDown="@HandleSearchKeyDown"
                      Style="max-width: 400px;" />

        <MudSpacer />

        <MudBadge Content="3" Color="Color.Error" Overlap="true">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                           Color="Color.Inherit"
                           OnClick="@ToggleNotifications" />
        </MudBadge>

        <MudMenu Icon="@Icons.Material.Filled.AccountCircle"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Person">Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings">Settings</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout">Logout</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen"
               Variant="@DrawerVariant.Mini"
               OpenMiniOnHover="true"
               ClipMode="DrawerClipMode.Always"
               Elevation="0"
               Class="modern-drawer">
        <MudNavMenu Class="modern-navmenu">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/drugs" Icon="@Icons.Material.Filled.Medication">
                Drugs
            </MudNavLink>
            <MudNavLink Href="/categories" Icon="@Icons.Material.Filled.Category">
                Categories
            </MudNavLink>
            <MudNavLink Href="/batches" Icon="@Icons.Material.Filled.Inventory2">
                Batches
            </MudNavLink>
            <MudNavLink Href="/inventory/stock-levels" Icon="@Icons.Material.Filled.Inventory">
                Inventory
            </MudNavLink>
            <MudNavLink Href="/procurement/requests" Icon="@Icons.Material.Filled.ShoppingCart">
                Procurement
            </MudNavLink>
            <MudNavLink Href="/suppliers" Icon="@Icons.Material.Filled.LocalShipping">
                Suppliers
            </MudNavLink>
            <MudNavLink Href="/wholesale" Icon="@Icons.Material.Filled.BusinessCenter">
                Wholesale
            </MudNavLink>
            <MudNavLink Href="/pos" Icon="@Icons.Material.Filled.PointOfSale">
                POS
            </MudNavLink>
            <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Assessment">
                Reports
            </MudNavLink>
            <MudNavLink Href="/audit" Icon="@Icons.Material.Filled.History">
                Audit Logs
            </MudNavLink>
            <MudNavLink Href="/users" Icon="@Icons.Material.Filled.People">
                Users
            </MudNavLink>

            <div style="flex: 1;"></div>

            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                Settings
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="modern-main-content">
        <div class="pa-6">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _notificationsOpen = false;
    private string _searchQuery = string.Empty;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleNotifications()
    {
        _notificationsOpen = !_notificationsOpen;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if ((e.CtrlKey || e.MetaKey) && e.Key == "k")
        {
            // Open command palette
        }
    }
}
