@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject NavigationManager NavigationManager

@if (_isOpen)
{
    <div class="medical-command-overlay" @onclick="Close">
        <div class="medical-command-palette" @onclick:stopPropagation="true">
            <div class="medical-command-search">
                <MudTextField Value="@_searchQuery"
                              ValueChanged="@((string val) => _searchQuery = val)"
                              Placeholder="Type a command or search..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              @ref="_searchField"
                              OnKeyDown="HandleKeyDown" />
            </div>

            <div class="medical-command-results">
                @if (string.IsNullOrWhiteSpace(_searchQuery))
                {
                    <div class="medical-command-section">
                        <div class="medical-command-section-title">RECENT</div>
                        <div class="medical-command-item" @onclick='() => Navigate("/")'>
                            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                            <span>Dashboard</span>
                        </div>
                    </div>

                    <div class="medical-command-section">
                        <div class="medical-command-section-title">QUICK ACTIONS</div>
                        <div class="medical-command-item" @onclick='() => Navigate("/drugs/new")'>
                            <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                            <span>New Drug</span>
                            <span class="medical-search-kbd" style="margin-left: auto;">Ctrl+N</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/pos")'>
                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Size="Size.Small" />
                            <span>New Sale</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/inventory/receive")'>
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                            <span>Receive Stock</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/reports")'>
                            <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Small" />
                            <span>Generate Report</span>
                        </div>
                    </div>

                    <div class="medical-command-section">
                        <div class="medical-command-section-title">NAVIGATION</div>
                        <div class="medical-command-item" @onclick='() => Navigate("/")'>
                            <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" />
                            <span>Go to Dashboard</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/drugs")'>
                            <MudIcon Icon="@Icons.Material.Filled.Medication" Size="Size.Small" />
                            <span>Go to Drugs</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/inventory/stock-levels")'>
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Small" />
                            <span>Go to Inventory</span>
                        </div>
                        <div class="medical-command-item" @onclick='() => Navigate("/pos")'>
                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Size="Size.Small" />
                            <span>Go to POS</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="medical-command-section">
                        <div class="medical-command-section-title">RESULTS</div>
                        @foreach (var result in GetSearchResults())
                        {
                            <div class="medical-command-item" @onclick="() => Navigate(result.Url)">
                                <MudIcon Icon="@result.Icon" Size="Size.Small" />
                                <span>@result.Title</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _isOpen = false;
    private string _searchQuery = string.Empty;
    private MudTextField<string>? _searchField;

    public void Open()
    {
        _isOpen = true;
        StateHasChanged();
    }

    public void Close()
    {
        _isOpen = false;
        _searchQuery = string.Empty;
        StateHasChanged();
    }

    private void Navigate(string url)
    {
        Close();
        NavigationManager.NavigateTo(url);
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            Close();
        }
    }

    private List<SearchResult> GetSearchResults()
    {
        var query = _searchQuery.ToLower();
        var allItems = new List<SearchResult>
        {
            new("Dashboard", "/", Icons.Material.Filled.Dashboard),
            new("Drugs", "/drugs", Icons.Material.Filled.Medication),
            new("Categories", "/categories", Icons.Material.Filled.Category),
            new("Batches", "/batches", Icons.Material.Filled.Inventory2),
            new("Inventory", "/inventory/stock-levels", Icons.Material.Filled.Inventory),
            new("Procurement", "/procurement/requests", Icons.Material.Filled.ShoppingCart),
            new("Suppliers", "/suppliers", Icons.Material.Filled.LocalShipping),
            new("Wholesale", "/wholesale", Icons.Material.Filled.BusinessCenter),
            new("POS", "/pos", Icons.Material.Filled.PointOfSale),
            new("Reports", "/reports", Icons.Material.Filled.Assessment),
            new("Settings", "/settings", Icons.Material.Filled.Settings),
            new("Users", "/users", Icons.Material.Filled.People),
            new("Audit Logs", "/audit", Icons.Material.Filled.History),
        };

        return allItems
            .Where(item => item.Title.ToLower().Contains(query))
            .ToList();
    }

    private record SearchResult(string Title, string Url, string Icon);
}
