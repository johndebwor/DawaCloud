@page "/batches"
@using MudBlazor

<PageTitle>Drug Batches - DawaFlow</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Drug Batches</h1>
            <p>Track batch inventory, expiry, and quarantine</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/batches/new">
            Add Batch
        </MudButton>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.Inventory" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Active Batches</div>
            <div class="df-kpi-value">@_batches.Count(b => b.Status == "Active")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Expiring Soon</div>
            <div class="df-kpi-value">@_batches.Count(b => b.DaysToExpiry <= 30 && b.DaysToExpiry > 0)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon danger">
                <MudIcon Icon="@Icons.Material.Filled.Error" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Expired</div>
            <div class="df-kpi-value">@_batches.Count(b => b.Status == "Expired")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon default">
                <MudIcon Icon="@Icons.Material.Filled.Block" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Quarantined</div>
            <div class="df-kpi-value">@_batches.Count(b => b.Status == "Quarantined")</div>
        </div>
    </div>
</div>

<!-- Batches Table -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search batches..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 400px;" />

        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Expired")">Expired</MudSelectItem>
                <MudSelectItem Value="@("Expiring Soon")">Expiring Soon</MudSelectItem>
                <MudSelectItem Value="@("Quarantined")">Quarantined</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="BatchListItem" Items="@FilteredBatches" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
            <HeaderContent>
                <MudTh>Batch Number</MudTh>
                <MudTh>Drug</MudTh>
                <MudTh>Manufacture Date</MudTh>
                <MudTh>Expiry Date</MudTh>
                <MudTh>Quantity</MudTh>
                <MudTh>Cost Price</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Batch Number">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.BatchNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Drug">@context.DrugName</MudTd>
                <MudTd DataLabel="Manufacture Date">@context.ManufactureDate.ToString("dd MMM yyyy")</MudTd>
                <MudTd DataLabel="Expiry Date">
                    <div>
                        <MudText Typo="Typo.body2">@context.ExpiryDate.ToString("dd MMM yyyy")</MudText>
                        @if (context.DaysToExpiry <= 30 && context.DaysToExpiry > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning">@context.DaysToExpiry days left</MudText>
                        }
                        else if (context.DaysToExpiry <= 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error">Expired</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Quantity">
                    <div>
                        <MudText Typo="Typo.body2">@context.CurrentQuantity / @context.InitialQuantity</MudText>
                        @if (context.ReservedQuantity > 0)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Info">(@context.ReservedQuantity reserved)</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Cost Price">KES @context.CostPrice.ToString("N2")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Href="@($"/batches/{context.Id}/edit")"
                                   Title="Edit" />
                    @if (context.Status == "Active" && context.DaysToExpiry <= 0)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                       Size="Size.Small"
                                       Color="Color.Warning"
                                       OnClick="@(() => QuarantineBatch(context.Id))"
                                       Title="Quarantine" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

@code {
    private List<BatchListItem> _batches = new();
    private string _searchString = string.Empty;
    private string _selectedStatus = "All";

    protected override void OnInitialized()
    {
        LoadBatches();
    }

    private void LoadBatches()
    {
        // Sample data
        _batches = new List<BatchListItem>
