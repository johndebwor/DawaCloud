                InitialQuantity = 3000,
                CurrentQuantity = 1800,
                ReservedQuantity = 0,
                CostPrice = 5.75m,
                Status = "Active"
            },
            new()
            {
                Id = 3,
                BatchNumber = "BTH-2023-045",
                DrugName = "Ibuprofen 400mg",
                ManufactureDate = new DateTime(2023, 5, 20),
                ExpiryDate = new DateTime(2025, 5, 20),
                InitialQuantity = 4000,
                CurrentQuantity = 2500,
                ReservedQuantity = 200,
                CostPrice = 4.20m,
                Status = "Active"
            },
            new()
            {
                Id = 4,
                BatchNumber = "BTH-2023-012",
                DrugName = "Aspirin 100mg",
                ManufactureDate = new DateTime(2023, 1, 10),
                ExpiryDate = new DateTime(2024, 1, 10),
                InitialQuantity = 2000,
                CurrentQuantity = 500,
                ReservedQuantity = 0,
                CostPrice = 2.80m,
                Status = "Expired"
            },
            new()
            {
                Id = 5,
                BatchNumber = "BTH-2024-003",
                DrugName = "Ciprofloxacin 500mg",
                ManufactureDate = new DateTime(2024, 3, 15),
                ExpiryDate = DateTime.Now.AddDays(25),
                InitialQuantity = 1500,
                CurrentQuantity = 800,
                ReservedQuantity = 0,
                CostPrice = 12.50m,
                Status = "Active"
            },
            new()
            {
                Id = 6,
                BatchNumber = "BTH-2023-098",
                DrugName = "Metformin 500mg",
                ManufactureDate = new DateTime(2023, 8, 5),
                ExpiryDate = new DateTime(2024, 2, 5),
                InitialQuantity = 3000,
                CurrentQuantity = 1200,
                ReservedQuantity = 0,
                CostPrice = 3.20m,
                Status = "Quarantined"
            }
        };
    }

    private IEnumerable<BatchListItem> FilteredBatches =>
        _batches.Where(b =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             b.BatchNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             b.DrugName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedStatus == "All" ||
             (_selectedStatus == "Expiring Soon" && b.DaysToExpiry <= 30 && b.DaysToExpiry > 0) ||
             b.Status == _selectedStatus)
        );

    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Expired" => Color.Error,
        "Quarantined" => Color.Warning,
        "Depleted" => Color.Default,
        _ => Color.Default
    };

    private async Task QuarantineBatch(int id)
    {
        // TODO: Implement quarantine logic
        await Task.CompletedTask;
    }

    private class BatchListItem
    {
        public int Id { get; set; }
        public string BatchNumber { get; set; } = string.Empty;
        public string DrugName { get; set; } = string.Empty;
        public DateTime ManufactureDate { get; set; }
        public DateTime ExpiryDate { get; set; }
        public int InitialQuantity { get; set; }
        public int CurrentQuantity { get; set; }
        public int ReservedQuantity { get; set; }
        public decimal CostPrice { get; set; }
        public string Status { get; set; } = "Active";

        public int DaysToExpiry => (ExpiryDate - DateTime.Now).Days;
    }
}
