<!-- Report Viewer Dialog -->
<MudDialog @bind-Visible="_showReportDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Assessment" />
            <MudText Typo="Typo.h6">@_selectedReportTitle</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_startDate" Label="Start Date" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudDatePicker @bind-Date="_endDate" Label="End Date" Variant="Variant.Outlined" />
            </MudItem>
            @if (_showCategoryFilter)
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_selectedCategory" Label="Category" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("All")">All Categories</MudSelectItem>
                        <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                        <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
            @if (_showSupplierFilter)
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_selectedSupplier" Label="Supplier" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("All")">All Suppliers</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showReportDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="ExportPdf">
            Export PDF
        </MudButton>
        <MudButton Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.TableChart" OnClick="ExportExcel">
            Export Excel
        </MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="GenerateReport">
            Generate
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .report-list .mud-list-item {
        border-radius: 8px;
        margin-bottom: 4px;
    }

    .report-list .mud-list-item:hover {
        background: var(--df-primary-50);
    }

    .report-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }
</style>

@code {
    private bool _showReportDialog = false;
    private string _selectedReportTitle = string.Empty;
    private string _selectedReportType = string.Empty;
    private DateTime? _startDate = DateTime.Today.AddMonths(-1);
    private DateTime? _endDate = DateTime.Today;
    private string _selectedCategory = "All";
    private string _selectedSupplier = "All";
    private bool _showCategoryFilter = false;
    private bool _showSupplierFilter = false;

    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private void OpenReport(string reportType)
    {
        _selectedReportType = reportType;
        _selectedReportTitle = GetReportTitle(reportType);
        _showCategoryFilter = reportType.Contains("stock") || reportType.Contains("sales-by-product");
        _showSupplierFilter = reportType.Contains("supplier") || reportType.Contains("purchase");
        _showReportDialog = true;
    }

    private string GetReportTitle(string reportType) => reportType switch
    {
        "stock-levels" => "Stock Levels Report",
        "stock-valuation" => "Stock Valuation Report",
        "stock-movements" => "Stock Movements Report",
        "expiry" => "Expiry Report",
        "low-stock" => "Low Stock Alert Report",
        "daily-sales" => "Daily Sales Report",
        "monthly-sales" => "Monthly Sales Summary",
        "sales-by-product" => "Sales by Product Report",
        "sales-by-customer" => "Sales by Customer Report",
        "cashier-summary" => "Cashier Summary Report",
        "profit-loss" => "Profit & Loss Statement",
        "outstanding-payments" => "Outstanding Payments Report",
        "receivables-aging" => "Receivables Aging Report",
        "payment-history" => "Payment History Report",
        "tax-summary" => "Tax Summary Report",
        "purchase-summary" => "Purchase Summary Report",
        "supplier-performance" => "Supplier Performance Report",
        "goods-received" => "Goods Received Notes Report",
        "pending-orders" => "Pending Orders Report",
        "controlled-drugs" => "Controlled Drugs Log",
        "prescription-log" => "Prescription Log",
        "batch-traceability" => "Batch Traceability Report",
        "disposal-log" => "Disposal/Write-off Log",
        "user-activity" => "User Activity Log",
        "login-history" => "Login History Report",
        "data-changes" => "Data Change Log",
        "system-log" => "System Events Log",
        _ => "Report"
    };

    private async Task GenerateReport()
    {
        // TODO: Generate and display report
        await Task.Delay(500);
        _showReportDialog = false;
    }

    private async Task ExportPdf()
    {
        // TODO: Export report to PDF
        await Task.Delay(500);
    }

    private async Task ExportExcel()
    {
        // TODO: Export report to Excel
        await Task.Delay(500);
    }
}
