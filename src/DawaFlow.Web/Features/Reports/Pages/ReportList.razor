@page "/reports"
@using MudBlazor

<PageTitle>Reports - DawaBes</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Reports & Analytics</h1>
