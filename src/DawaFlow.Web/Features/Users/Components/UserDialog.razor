@using MudBlazor
@using MudBlazor.Services
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.FirstName"
                                  Label="First Name"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="First name is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.LastName"
                                  Label="Last Name"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Last name is required" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email"
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Email is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Phone"
                                  Label="Phone Number"
                                  Variant="Variant.Outlined"
                                  Placeholder="+211912345678" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect @bind-Value="_model.Role"
                               Label="Role"
                               Variant="Variant.Outlined"
                               Required="true">
                        <MudSelectItem Value="@("SuperAdmin")">Super Admin</MudSelectItem>
                        <MudSelectItem Value="@("InventoryManager")">Inventory Manager</MudSelectItem>
                        <MudSelectItem Value="@("Pharmacist")">Pharmacist</MudSelectItem>
                        <MudSelectItem Value="@("Cashier")">Cashier</MudSelectItem>
                        <MudSelectItem Value="@("Accountant")">Accountant</MudSelectItem>
                        <MudSelectItem Value="@("Auditor")">Auditor</MudSelectItem>
                        <MudSelectItem Value="@("Supplier")">Supplier</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @if (!!string.IsNullOrEmpty(UserId))
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Initial Password</MudText>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Password"
                                      Label="Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Password is required" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.ConfirmPassword"
                                      Label="Confirm Password"
                                      InputType="InputType.Password"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Please confirm password" />
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Permissions</MudText>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanManageDrugs"
                               Label="Manage Drugs"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanManageInventory"
                               Label="Manage Inventory"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanProcessSales"
                               Label="Process Sales"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanViewReports"
                               Label="View Reports"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanManageUsers"
                               Label="Manage Users"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_permissions.CanApproveOrders"
                               Label="Approve Orders"
                               Color="Color.Primary" />
                </MudItem>

                @if (!string.IsNullOrEmpty(UserId))
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_model.IsActive"
                                   Label="Active Account"
                                   Color="Color.Primary" />
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        @if (!string.IsNullOrEmpty(UserId))
        {
            <MudButton Color="Color.Warning"
                       Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.Lock"
                       OnClick="ResetPassword">
                Reset Password
            </MudButton>
        }
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!_isValid || _isProcessing)">
            @if (_isProcessing)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Saving...</MudText>
            }
            else
            {
                <MudText>@(!string.IsNullOrEmpty(UserId) ? "Update" : "Create")</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public string? UserId { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _isProcessing = false;
    private UserFormModel _model = new();
    private UserPermissions _permissions = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(UserId))
        {
            LoadUser();
        }
        else
        {
            _model.IsActive = true;
            // Set default permissions based on role
            SetDefaultPermissions();
        }
    }

    private void LoadUser()
    {
        // Sample data - TODO: Load from database
        _model = new UserFormModel
        {
            FirstName = "John",
            LastName = "Deng",
            Email = "john.deng@DawaBes.com",
            Phone = "+211921234567",
            Role = "Pharmacist",
            IsActive = true
        };

        _permissions = new UserPermissions
        {
            CanManageDrugs = true,
            CanManageInventory = true,
            CanProcessSales = true,
            CanViewReports = true
        };
    }

    private void SetDefaultPermissions()
    {
        // Can be expanded based on role selection
        _permissions = new UserPermissions
        {
            CanManageDrugs = false,
            CanManageInventory = false,
            CanProcessSales = false,
            CanViewReports = false,
            CanManageUsers = false,
            CanApproveOrders = false
        };
    }

    private async Task Submit()
    {
        if (!_isValid)
        {
            Snackbar.Add("Please fix validation errors", Severity.Error);
            return;
        }

        if (!!string.IsNullOrEmpty(UserId) && _model.Password != _model.ConfirmPassword)
        {
            Snackbar.Add("Passwords do not match", Severity.Error);
            return;
        }

        _isProcessing = true;

        try
        {
            // Simulate save
            await Task.Delay(500);

            // TODO: Implement actual MediatR command
            // if (UserId != null)
            // {
            //     var command = new UpdateUserCommand(...);
            //     await Mediator.Send(command);
            // }
            // else
            // {
            //     var command = new CreateUserCommand(...);
            //     await Mediator.Send(command);
            // }

            Snackbar.Add(
                UserId != null ? "User updated successfully" : "User created successfully",
                Severity.Success
            );

            MudDialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task ResetPassword()
    {
        // TODO: Implement password reset
        await Task.CompletedTask;
        Snackbar.Add("Password reset email sent", Severity.Info);
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private class UserFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public string Role { get; set; } = "Cashier";
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }

    private class UserPermissions
    {
        public bool CanManageDrugs { get; set; }
        public bool CanManageInventory { get; set; }
        public bool CanProcessSales { get; set; }
        public bool CanViewReports { get; set; }
        public bool CanManageUsers { get; set; }
        public bool CanApproveOrders { get; set; }
    }
}
