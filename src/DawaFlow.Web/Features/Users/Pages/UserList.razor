@page "/users"
@using MudBlazor
@using Microsoft.AspNetCore.Identity
@using DawaFlow.Web.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<ApplicationRole> RoleManager
@inject ISnackbar Snackbar

<PageTitle>User Management - DawaBes</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>User Management</h1>
            <p>Manage system users, roles, and permissions</p>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="@(() => _showCreateDialog = true)">
            Add User
        </MudButton>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.People" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Users</div>
            <div class="df-kpi-value">@_users.Count</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Active Users</div>
            <div class="df-kpi-value">@_users.Count(u => u.IsActive)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon info">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Administrators</div>
            <div class="df-kpi-value">@_users.Count(u => u.Role == "Admin")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Schedule" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Online Now</div>
            <div class="df-kpi-value">@_users.Count(u => u.IsOnline)</div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search users..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      Style="max-width: 400px;" />
        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedRole" Label="Role" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Roles</MudSelectItem>
                <MudSelectItem Value="@("Admin")">Administrator</MudSelectItem>
                <MudSelectItem Value="@("Manager")">Inventory Manager</MudSelectItem>
                <MudSelectItem Value="@("Pharmacist")">Pharmacist</MudSelectItem>
                <MudSelectItem Value="@("Cashier")">Cashier</MudSelectItem>
                <MudSelectItem Value="@("Accountant")">Accountant</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Inactive")">Inactive</MudSelectItem>
                <MudSelectItem Value="@("Locked")">Locked</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="UserDto" Items="@FilteredUsers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
        <HeaderContent>
            <MudTh>User</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Last Login</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="User">
                <div class="d-flex align-center gap-3">
                    <MudAvatar Color="@GetAvatarColor(context.Role)" Size="Size.Small">
                        @context.Name.Substring(0, 1).ToUpper()
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Username</MudText>
                    </div>
                    @if (context.IsOnline)
                    {
                        <MudTooltip Text="Online">
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small" Color="Color.Success" />
                        </MudTooltip>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Role">
                <MudChip T="string" Size="Size.Small" Color="@GetRoleColor(context.Role)">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="Last Login">
                @if (context.LastLogin.HasValue)
                {
                    <MudText Typo="Typo.body2">@context.LastLogin.Value.ToString("dd MMM yyyy HH:mm")</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Never</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context)">@GetStatusText(context)</MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudTooltip Text="Edit User"><MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info" OnClick="@(() => EditUser(context))" /></MudTooltip>
                <MudTooltip Text="Reset Password"><MudIconButton Icon="@Icons.Material.Filled.Key" Size="Size.Small" Color="Color.Default" OnClick="@(() => ResetPassword(context))" /></MudTooltip>
                @if (context.IsLocked)
                {
                    <MudTooltip Text="Unlock User"><MudIconButton Icon="@Icons.Material.Filled.LockOpen" Size="Size.Small" Color="Color.Success" OnClick="@(() => UnlockUser(context))" /></MudTooltip>
                }
                else if (context.IsActive)
                {
                    <MudTooltip Text="Deactivate User"><MudIconButton Icon="@Icons.Material.Filled.Block" Size="Size.Small" Color="Color.Warning" OnClick="@(() => DeactivateUser(context))" /></MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
        </PagerContent>
    </MudTable>
</div>

<!-- Create/Edit User Dialog -->
<MudDialog @bind-Visible="_showCreateDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingUser == null ? "Add New User" : "Edit User")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Full Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Username" Label="Username" Required="true" Variant="Variant.Outlined" Disabled="@(_editingUser != null)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Email" Label="Email" Required="true" InputType="InputType.Email" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Phone" Label="Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_model.Role" Label="Role" Required="true" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Admin")">Administrator</MudSelectItem>
                        <MudSelectItem Value="@("Manager")">Inventory Manager</MudSelectItem>
                        <MudSelectItem Value="@("Pharmacist")">Pharmacist</MudSelectItem>
                        <MudSelectItem Value="@("Cashier")">Cashier</MudSelectItem>
                        <MudSelectItem Value="@("Accountant")">Accountant</MudSelectItem>
                        <MudSelectItem Value="@("Auditor")">Auditor</MudSelectItem>
                    </MudSelect>
                </MudItem>
                @if (_editingUser == null)
                {
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Password" Label="Initial Password" Required="true" InputType="InputType.Password" Variant="Variant.Outlined" />
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_model.IsActive" Label="Account Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.subtitle2" Class="mb-2">Permissions</MudText>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanManageDrugs" Label="Manage Drugs" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanManageInventory" Label="Manage Inventory" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanProcessSales" Label="Process Sales" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanViewReports" Label="View Reports" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanManageUsers" Label="Manage Users" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudCheckBox @bind-Value="_model.CanManageSettings" Label="Manage Settings" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveUser">
            @(_editingUser == null ? "Create User" : "Save Changes")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Password Reset Dialog -->
<MudDialog @bind-Visible="_showPasswordDialog" Options="_smallDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Reset Password</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">Reset password for <strong>@_selectedUser?.Name</strong>?</MudText>
        <MudTextField @bind-Value="_newPassword" Label="New Password" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" />
        <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" Class="mt-4" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPasswordDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmPasswordReset">Reset Password</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<UserDto> _users = new();
    private string _searchString = string.Empty;
    private string _selectedRole = "All";
    private string _selectedStatus = "All";
    private bool _showCreateDialog = false;
    private bool _showPasswordDialog = false;
    private MudForm? _form;
    private UserDto? _editingUser = null;
    private UserDto? _selectedUser = null;
    private UserFormModel _model = new();
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };
    private DialogOptions _smallDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    private IEnumerable<UserDto> FilteredUsers =>
        _users.Where(u =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             u.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             u.Username.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedRole == "All" || u.Role == _selectedRole) &&
            (_selectedStatus == "All" ||
             (_selectedStatus == "Active" && u.IsActive && !u.IsLocked) ||
             (_selectedStatus == "Inactive" && !u.IsActive) ||
             (_selectedStatus == "Locked" && u.IsLocked))
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            var appUsers = UserManager.Users.OrderBy(u => u.UserName).ToList();
            var userDtos = new List<UserDto>();
            foreach (var u in appUsers)
            {
                var roles = await UserManager.GetRolesAsync(u);
                var isLocked = await UserManager.IsLockedOutAsync(u);
                userDtos.Add(new UserDto
                {
                    Id = u.Id,
                    Name = $"{u.FirstName} {u.LastName}".Trim(),
                    Username = u.UserName ?? string.Empty,
                    Email = u.Email ?? string.Empty,
                    Phone = u.PhoneNumber,
                    Role = roles.FirstOrDefault() ?? "User",
                    IsActive = u.IsActive,
                    IsLocked = isLocked,
                    LastLogin = u.LastLoginAt
                });
            }
            _users = userDtos;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading users: {ex.Message}", Severity.Error);
        }
    }

    private Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Primary,
        "Manager" => Color.Info,
        "Pharmacist" => Color.Success,
        "Cashier" => Color.Warning,
        "Accountant" => Color.Secondary,
        _ => Color.Default
    };

    private Color GetAvatarColor(string role) => role switch
    {
        "Admin" => Color.Primary,
        "Manager" => Color.Info,
        "Pharmacist" => Color.Success,
        "Cashier" => Color.Warning,
        "Accountant" => Color.Secondary,
        _ => Color.Default
    };

    private Color GetStatusColor(UserDto user)
    {
        if (user.IsLocked) return Color.Error;
        if (!user.IsActive) return Color.Default;
        return Color.Success;
    }

    private string GetStatusText(UserDto user)
    {
        if (user.IsLocked) return "Locked";
        if (!user.IsActive) return "Inactive";
        return "Active";
    }

    private void EditUser(UserDto user)
    {
        _editingUser = user;
        _model = new UserFormModel
        {
            Name = user.Name,
            Username = user.Username,
            Email = user.Email,
            Phone = user.Phone,
            Role = user.Role,
            IsActive = user.IsActive,
            CanManageDrugs = user.Role == "Admin" || user.Role == "Manager" || user.Role == "Pharmacist",
            CanManageInventory = user.Role == "Admin" || user.Role == "Manager",
            CanProcessSales = user.Role == "Admin" || user.Role == "Cashier" || user.Role == "Pharmacist",
            CanViewReports = user.Role == "Admin" || user.Role == "Manager" || user.Role == "Accountant",
            CanManageUsers = user.Role == "Admin",
            CanManageSettings = user.Role == "Admin"
        };
        _showCreateDialog = true;
    }

    private void ResetPassword(UserDto user)
    {
        _selectedUser = user;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;
        _showPasswordDialog = true;
    }

    private async Task ConfirmPasswordReset()
    {
        if (_selectedUser == null || string.IsNullOrWhiteSpace(_newPassword) || _newPassword != _confirmPassword)
        {
            Snackbar.Add("Passwords do not match", Severity.Warning);
            return;
        }
        var appUser = await UserManager.FindByIdAsync(_selectedUser.Id);
        if (appUser == null) return;
        var token = await UserManager.GeneratePasswordResetTokenAsync(appUser);
        var result = await UserManager.ResetPasswordAsync(appUser, token, _newPassword);
        if (result.Succeeded)
            Snackbar.Add("Password reset successfully", Severity.Success);
        else
            Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
        _showPasswordDialog = false;
    }

    private async Task UnlockUser(UserDto user)
    {
        var appUser = await UserManager.FindByIdAsync(user.Id);
        if (appUser == null) return;
        await UserManager.SetLockoutEndDateAsync(appUser, null);
        Snackbar.Add($"{user.Name} unlocked", Severity.Success);
        user.IsLocked = false;
    }

    private async Task DeactivateUser(UserDto user)
    {
        var appUser = await UserManager.FindByIdAsync(user.Id);
        if (appUser == null) return;
        appUser.IsActive = false;
        await UserManager.UpdateAsync(appUser);
        Snackbar.Add($"{user.Name} deactivated", Severity.Success);
        user.IsActive = false;
    }

    private void CloseDialog()
    {
        _showCreateDialog = false;
        _editingUser = null;
        _model = new();
    }

    private async Task SaveUser()
    {
        try
        {
            if (_editingUser != null)
            {
                // Edit existing user
                var appUser = await UserManager.FindByIdAsync(_editingUser.Id);
                if (appUser == null) return;
                var parts = _model.Name.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
                appUser.FirstName = parts.Length > 0 ? parts[0] : _model.Name;
                appUser.LastName = parts.Length > 1 ? parts[1] : string.Empty;
                appUser.PhoneNumber = _model.Phone;
                appUser.IsActive = _model.IsActive;
                await UserManager.UpdateAsync(appUser);
                // Update role
                var currentRoles = await UserManager.GetRolesAsync(appUser);
                await UserManager.RemoveFromRolesAsync(appUser, currentRoles);
                if (!string.IsNullOrEmpty(_model.Role))
                    await UserManager.AddToRoleAsync(appUser, _model.Role);
                Snackbar.Add("User updated successfully", Severity.Success);
            }
            else
            {
                // Create new user
                var newUser = new ApplicationUser
                {
                    UserName = _model.Username,
                    Email = _model.Email,
                    FirstName = _model.Name.Split(' ', 2)[0],
                    LastName = _model.Name.Contains(' ') ? _model.Name.Split(' ', 2)[1] : string.Empty,
                    PhoneNumber = _model.Phone,
                    IsActive = _model.IsActive
                };
                var result = await UserManager.CreateAsync(newUser, _model.Password ?? "TempPass@123!");
                if (result.Succeeded)
                {
                    if (!string.IsNullOrEmpty(_model.Role))
                        await UserManager.AddToRoleAsync(newUser, _model.Role);
                    Snackbar.Add("User created successfully", Severity.Success);
                }
                else
                {
                    Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
                    return;
                }
            }
            CloseDialog();
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving user: {ex.Message}", Severity.Error);
        }
    }

    private class UserDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public string Role { get; set; } = string.Empty;
        public bool IsActive { get; set; }
        public bool IsOnline { get; set; }
        public bool IsLocked { get; set; }
        public DateTime? LastLogin { get; set; }
    }

    private class UserFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string? Phone { get; set; }
        public string Role { get; set; } = string.Empty;
        public string? Password { get; set; }
        public bool IsActive { get; set; } = true;
        public bool CanManageDrugs { get; set; }
        public bool CanManageInventory { get; set; }
        public bool CanProcessSales { get; set; }
        public bool CanViewReports { get; set; }
        public bool CanManageUsers { get; set; }
        public bool CanManageSettings { get; set; }
    }
}
