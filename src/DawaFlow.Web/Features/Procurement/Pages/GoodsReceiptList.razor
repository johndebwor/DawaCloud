@page "/procurement/goods-receipts"
@using MudBlazor
@inject NavigationManager Navigation

<PageTitle>Goods Receipts - DawaBes</PageTitle>

<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Goods Receipts</h1>
            <p>Receive and verify supplier deliveries</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/procurement/goods-receipts/new">
            New Receipt
        </MudButton>
    </div>
</div>

<div class="df-alert-card animate-fade-in-up animate-delay-1 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by GRN number, supplier..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 300px;" />

        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedStatus" Label="Status" Variant="Variant.Outlined" Dense="true">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Draft")">Draft</MudSelectItem>
                <MudSelectItem Value="@("Verified")">Verified</MudSelectItem>
                <MudSelectItem Value="@("Posted")">Posted</MudSelectItem>
                <MudSelectItem Value="@("Cancelled")">Cancelled</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="GoodsReceiptDto" Items="@FilteredReceipts" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>GRN Number</MudTh>
            <MudTh>Date</MudTh>
            <MudTh>Supplier</MudTh>
            <MudTh>Request</MudTh>
            <MudTh>Total Items</MudTh>
            <MudTh>Total Value</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="GRN Number">
                <MudText Typo="Typo.body2" Class="fw-bold">@context.GRNNumber</MudText>
            </MudTd>
            <MudTd DataLabel="Date">
                <MudText Typo="Typo.body2">@context.ReceiptDate.ToString("dd MMM yyyy")</MudText>
            </MudTd>
            <MudTd DataLabel="Supplier">
                <MudText Typo="Typo.body2">@context.SupplierName</MudText>
            </MudTd>
            <MudTd DataLabel="Request">
                <MudText Typo="Typo.body2">@context.RequestNumber</MudText>
            </MudTd>
            <MudTd DataLabel="Total Items">
                <MudText Typo="Typo.body2">@context.TotalItems</MudText>
            </MudTd>
            <MudTd DataLabel="Total Value">
                <MudText Typo="Typo.body2">SSP @context.TotalValue.ToString("N2")</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudButtonGroup Variant="Variant.Text" Size="Size.Small">
                    <MudTooltip Text="View Details"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Href="@($"/procurement/goods-receipts/{context.Id}")" /></MudTooltip>
                    @if (context.Status == "Draft")
                    {
                        <MudTooltip Text="Edit"><MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Href="@($"/procurement/goods-receipts/{context.Id}/edit")" /></MudTooltip>
                    }
                    @if (context.Status == "Verified")
                    {
                        <MudTooltip Text="Post to Inventory"><MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" OnClick="@(() => PostToInventory(context.Id))" /></MudTooltip>
                    }
                </MudButtonGroup>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</div>

@code {
    private List<GoodsReceiptDto> _receipts = new();
    private string _searchString = string.Empty;
    private string _selectedStatus = "All";

    private IEnumerable<GoodsReceiptDto> FilteredReceipts =>
        _receipts.Where(r =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             r.GRNNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             r.SupplierName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedStatus == "All" || r.Status == _selectedStatus)
        );

    protected override void OnInitialized()
    {
        LoadReceipts();
    }

    private void LoadReceipts()
    {
        // Sample data
        _receipts = new List<GoodsReceiptDto>
        {
            new() { Id = 1, GRNNumber = "GRN-2024-0001", ReceiptDate = DateTime.Now.AddDays(-2), SupplierName = "ABC Pharmaceuticals Ltd", RequestNumber = "REQ-2024-0015", TotalItems = 5, TotalValue = 125000, Status = "Posted" },
            new() { Id = 2, GRNNumber = "GRN-2024-0002", ReceiptDate = DateTime.Now.AddDays(-1), SupplierName = "XYZ Medical Supplies", RequestNumber = "REQ-2024-0016", TotalItems = 3, TotalValue = 75000, Status = "Verified" },
            new() { Id = 3, GRNNumber = "GRN-2024-0003", ReceiptDate = DateTime.Now, SupplierName = "South Sudan Pharma Distributors", RequestNumber = "REQ-2024-0017", TotalItems = 8, TotalValue = 200000, Status = "Draft" }
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Verified" => Color.Warning,
        "Posted" => Color.Success,
        "Cancelled" => Color.Error,
        _ => Color.Default
    };

    private async Task PostToInventory(int id)
    {
        // TODO: Implement post to inventory command
        await Task.CompletedTask;
    }

    private class GoodsReceiptDto
    {
        public int Id { get; set; }
        public string GRNNumber { get; set; } = string.Empty;
        public DateTime ReceiptDate { get; set; }
        public string SupplierName { get; set; } = string.Empty;
        public string RequestNumber { get; set; } = string.Empty;
        public int TotalItems { get; set; }
        public decimal TotalValue { get; set; }
        public string Status { get; set; } = string.Empty;
    }
}
