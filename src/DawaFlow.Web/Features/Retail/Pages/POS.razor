@page "/pos"
@using MudBlazor
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Microsoft.EntityFrameworkCore
@using MediatR
@using System.Security.Claims
@using System.Text.Json
@using DawaFlow.Web.Features.Retail.Commands
@using DawaFlow.Web.Features.Retail.Queries
@using DawaFlow.Web.Features.Currency.Services
@using DawaFlow.Web.Data.Enums
@inject IJSRuntime JSRuntime
@inject IRoundingService RoundingService
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpContextAccessor
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Point of Sale - DawaBes</PageTitle>

<div class="pos-container">
    <!-- Left Panel - Product Search & Grid -->
    <div class="pos-left-panel">
        <!-- Search Bar -->
        <div class="pos-search-bar">
            <MudTextField @bind-Value="_searchQuery"
                          Placeholder="Scan barcode or search products... (F2)"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          FullWidth="true"
                          OnKeyDown="@HandleSearchKeyDown" />
        </div>

        <!-- Category Tabs -->
        <div class="pos-categories">
            <MudChipSet T="string" @bind-SelectedValue="_selectedCategory" SelectionMode="SelectionMode.SingleSelection" Class="pos-category-chips">
                <MudChip Value="@("All")" Color="Color.Primary" Variant="Variant.Text">All</MudChip>
                <MudChip Value="@("Analgesics")" Color="Color.Default" Variant="Variant.Text">Analgesics</MudChip>
                <MudChip Value="@("Antibiotics")" Color="Color.Default" Variant="Variant.Text">Antibiotics</MudChip>
                <MudChip Value="@("Antacids")" Color="Color.Default" Variant="Variant.Text">Antacids</MudChip>
                <MudChip Value="@("Vitamins")" Color="Color.Default" Variant="Variant.Text">Vitamins</MudChip>
            </MudChipSet>
        </div>

        <!-- Product Display -->
        @if (_displayStyle == "list")
        {
            <!-- List View -->
            <div class="pos-product-list">
                @foreach (var product in FilteredProducts)
                {
                    <div class="pos-product-list-item @(product.Stock == 0 ? "out-of-stock" : "")" @onclick="@(() => AddToCart(product))">
                        <div class="pos-product-list-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Medication" Size="Size.Large" Color="Color.Primary" />
                        </div>
                        <div class="pos-product-list-info">
                            <div class="pos-product-list-name">
                                @product.Name
                                @if (product.RequiresPrescription)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.MedicalServices" Size="Size.Small" Color="Color.Warning" />
                                }
                            </div>
                            <div class="pos-product-list-code">@product.Code</div>
                        </div>
                        <div class="pos-product-list-details">
                            <div class="pos-product-list-price">SSP @product.Price.ToString("N0")</div>
                            <div class="pos-product-list-stock @(product.Stock <= 10 ? "warning" : "")">
                                Stock: @product.Stock
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Grid View (Default) -->
            <div class="pos-product-grid">
                @foreach (var product in FilteredProducts)
                {
                    <div class="pos-product-card @(product.Stock == 0 ? "out-of-stock" : "")" @onclick="@(() => AddToCart(product))">
                        <div class="pos-product-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Medication" Size="Size.Large" />
                        </div>
                        <div class="pos-product-name">@product.Name</div>
                        <div class="pos-product-price">SSP @product.Price.ToString("N0")</div>
                        @if (product.Stock <= 10)
                        {
                            <div class="pos-product-stock warning">@product.Stock left</div>
                        }
                        @if (product.RequiresPrescription)
                        {
                            <div class="pos-product-rx">
                                <MudIcon Icon="@Icons.Material.Filled.MedicalServices" Size="Size.Small" />
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <!-- Quick Actions -->
        <div class="pos-quick-actions">
            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Pause" OnClick="HoldSale">
                Hold (F4)
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Replay" OnClick="RecallSale">
                Recall (F5)
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.History" OnClick="ShowLastReceipt">
                Last Receipt
            </MudButton>
        </div>
    </div>

    <!-- Right Panel - Cart -->
    <div class="pos-right-panel">
        <!-- Customer Info -->
        <div class="pos-customer-bar">
            <MudTextField @bind-Value="_customerName"
                          Placeholder="Customer Name (Optional)"
                          Variant="Variant.Text"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Dense="true" />
        </div>

        <!-- Cart Items -->
        <div class="pos-cart">
            @if (_cartItems.Count == 0)
            {
                <div class="pos-cart-empty">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Color="Color.Secondary">Cart is empty</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Scan or search to add items</MudText>
                </div>
            }
            else
            {
                @foreach (var item in _cartItems)
                {
                    <div class="pos-cart-item">
                        <div class="pos-cart-item-info">
                            <div class="pos-cart-item-name">@item.Name</div>
                            <div class="pos-cart-item-price">SSP @item.UnitPrice.ToString("N0") × @item.Quantity</div>
                        </div>
                        <div class="pos-cart-item-controls">
                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="@(() => DecreaseQuantity(item))" />
                            <span class="pos-cart-item-qty">@item.Quantity</span>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="@(() => IncreaseQuantity(item))" />
                        </div>
                        <div class="pos-cart-item-total">
                            SSP @item.LineTotal.ToString("N0")
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveFromCart(item))" />
                    </div>
                }
            }
        </div>

        <!-- Cart Totals -->
        <div class="pos-totals">
            <div class="pos-total-row">
                <span>Subtotal</span>
                <span>SSP @_subtotal.ToString("N2")</span>
            </div>
            <div class="pos-total-row">
                <span>Tax (16%)</span>
                <span>SSP @_taxAmount.ToString("N2")</span>
            </div>
            @if (_discountAmount > 0)
            {
                <div class="pos-total-row discount">
                    <span>Discount</span>
                    <span>- SSP @_discountAmount.ToString("N2")</span>
                </div>
            }
            @if (_isRoundingEnabled && _grandTotal != _grandTotalBeforeRounding)
            {
                <div class="pos-total-row" style="color: var(--df-text-secondary); font-size: 0.8em;">
                    <span>Before Rounding</span>
                    <span>SSP @_grandTotalBeforeRounding.ToString("N2")</span>
                </div>
            }
            <div class="pos-total-row grand-total">
                <span>TOTAL</span>
                <span>SSP @_grandTotal.ToString("N2")</span>
            </div>
        </div>

        <!-- Payment Buttons -->
        <div class="pos-payment-buttons">
            <div class="pos-payment-row">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" StartIcon="@Icons.Material.Filled.Percent" OnClick="ApplyDiscount">
                    Discount
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearCart">
                    Clear
                </MudButton>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Payment" OnClick="ProcessPayment"
                       Disabled="@(_cartItems.Count == 0)">
                PAY SSP @_grandTotal.ToString("N0") (F12)
            </MudButton>
        </div>
    </div>
</div>

<!-- Payment Dialog -->
<MudDialog @bind-Visible="_showPaymentDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Payment" />
            <MudText Typo="Typo.h6">Complete Payment</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="payment-dialog-total">
            <MudText Typo="Typo.h4" Color="Color.Primary">SSP @_grandTotal.ToString("N2")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Amount Due</MudText>
        </div>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-2">Select Payment Method</MudText>
        <div class="payment-methods">
            <div class="payment-method @(_selectedPaymentMethod == "Cash" ? "selected" : "")" @onclick="@(() => _selectedPaymentMethod = "Cash")">
                <MudIcon Icon="@Icons.Material.Filled.Money" />
                <span>Cash</span>
            </div>
            <div class="payment-method @(_selectedPaymentMethod == "MoMo" ? "selected" : "")" @onclick="@(() => _selectedPaymentMethod = "MoMo")">
                <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" />
                <span>MoMo</span>
            </div>
            <div class="payment-method @(_selectedPaymentMethod == "Card" ? "selected" : "")" @onclick="@(() => _selectedPaymentMethod = "Card")">
                <MudIcon Icon="@Icons.Material.Filled.CreditCard" />
                <span>Card</span>
            </div>
        </div>

        @if (_selectedPaymentMethod == "Cash")
        {
            <MudNumericField @bind-Value="_amountTendered" Label="Amount Tendered (SSP)" Variant="Variant.Outlined"
                            Class="mt-4" Min="0m" />
            @if (_amountTendered >= _grandTotal)
            {
                <MudAlert Severity="Severity.Success" Class="mt-2">
                    Change: <strong>SSP @((_amountTendered - _grandTotal).ToString("N2"))</strong>
                </MudAlert>
            }
        }
        else if (_selectedPaymentMethod == "MoMo")
        {
            <MudTextField @bind-Value="_momoRef" Label="MoMo Transaction Code" Variant="Variant.Outlined" Class="mt-4" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showPaymentDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CompleteSale" 
                   Disabled="@(!CanCompleteSale)">
            Complete Sale
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Success Dialog -->
<MudDialog @bind-Visible="_showSuccessDialog" Options="_successDialogOptions">
    <DialogContent>
        <div class="text-center py-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-3" />
            <MudText Typo="Typo.h5" Color="Color.Success">Payment Successful!</MudText>
            <MudText Typo="Typo.body1" Class="mt-2">Receipt #: @_lastReceiptNumber</MudText>
            @if (_changeAmount > 0)
            {
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mt-2">Change: SSP @_changeAmount.ToString("N2")</MudText>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showSuccessDialog = false)">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintReceipt">
            Print Receipt
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Recall Sale Dialog -->
<MudDialog @bind-Visible="_showRecallDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Replay" />
            <MudText Typo="Typo.h6">Recall Held Sale</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_heldSales.Count == 0)
        {
            <div class="text-center py-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No held sales found</MudText>
            </div>
        }
        else
        {
            <MudList T="string" Clickable="true">
                @foreach (var held in _heldSales)
                {
                    <MudListItem T="string" OnClick="@(() => RecallSelectedSale(held.Id))">
                        <div>
                            <MudText Typo="Typo.body1" Class="fw-bold">@held.Reference</MudText>
                            @if (!string.IsNullOrEmpty(held.CustomerName))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Customer: @held.CustomerName
                                </MudText>
                            }
                            <MudText Typo="Typo.body2">
                                Total: SSP @held.TotalAmount.ToString("N2")
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Held: @held.HeldAt.ToString("dd MMM yyyy HH:mm")
                            </MudText>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showRecallDialog = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

<!-- Discount Dialog -->
<MudDialog @bind-Visible="_showDiscountDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Percent" />
            <MudText Typo="Typo.h6">Apply Discount</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Subtotal: SSP @_subtotal.ToString("N2")</MudText>
        <MudRadioGroup @bind-Value="_discountType" T="string" Class="mb-3">
            <MudRadio Value="@("Percentage")" Color="Color.Primary">Percentage (%)</MudRadio>
            <MudRadio Value="@("Fixed")" Color="Color.Primary">Fixed Amount (SSP)</MudRadio>
        </MudRadioGroup>
        @if (_discountType == "Percentage")
        {
            <MudNumericField @bind-Value="_discountInput" Label="Discount %" Variant="Variant.Outlined"
                             Min="0m" Max="100m" Adornment="Adornment.End" AdornmentText="%" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                Discount: SSP @((_subtotal * _discountInput / 100).ToString("N2"))
            </MudText>
        }
        else
        {
            <MudNumericField @bind-Value="_discountInput" Label="Discount Amount (SSP)" Variant="Variant.Outlined"
                             Min="0m" Max="@_subtotal" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showDiscountDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmDiscount">Apply</MudButton>
    </DialogActions>
</MudDialog>

<!-- Last Receipt Dialog -->
<MudDialog @bind-Visible="_showLastReceiptDialog" Options="_dialogOptions">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" />
            <MudText Typo="Typo.h6">Last Receipt</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_lastReceipt != null)
        {
            <div class="mb-4">
                <MudText Typo="Typo.h6">@_lastReceipt.ReceiptNumber</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_lastReceipt.SaleDate.ToString("dd MMM yyyy HH:mm")
                </MudText>
                @if (!string.IsNullOrEmpty(_lastReceipt.CustomerName))
                {
                    <MudText Typo="Typo.body2">Customer: @_lastReceipt.CustomerName</MudText>
                }
            </div>

            <MudTable Items="@_lastReceipt.Items" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh>Qty</MudTh>
                    <MudTh>Price</MudTh>
                    <MudTh>Total</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.DrugName</MudTd>
                    <MudTd>@context.Quantity</MudTd>
                    <MudTd>SSP @context.UnitPrice.ToString("N2")</MudTd>
                    <MudTd>SSP @context.LineTotal.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>

            <MudDivider Class="my-4" />

            <div class="d-flex flex-column gap-2">
                <div class="d-flex justify-space-between">
                    <MudText>Subtotal:</MudText>
                    <MudText>SSP @_lastReceipt.SubTotal.ToString("N2")</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText>Tax (16%):</MudText>
                    <MudText>SSP @_lastReceipt.TaxAmount.ToString("N2")</MudText>
                </div>
                @if (_lastReceipt.DiscountAmount > 0)
                {
                    <div class="d-flex justify-space-between" style="color: var(--df-success);">
                        <MudText>Discount:</MudText>
                        <MudText>- SSP @_lastReceipt.DiscountAmount.ToString("N2")</MudText>
                    </div>
                }
                <MudDivider />
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.h6" Color="Color.Primary">Total Paid:</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Primary">SSP @_lastReceipt.TotalAmount.ToString("N2")</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText>Payment Method:</MudText>
                    <MudText>@_lastReceipt.PaymentMethod</MudText>
                </div>
                @if (_lastReceipt.ChangeAmount > 0)
                {
                    <div class="d-flex justify-space-between">
                        <MudText>Change:</MudText>
                        <MudText>SSP @_lastReceipt.ChangeAmount.ToString("N2")</MudText>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Secondary" Size="Size.Large" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">No recent receipts found</MudText>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showLastReceiptDialog = false)">Close</MudButton>
        @if (_lastReceipt != null)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintLastReceipt">
                Print Again
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<style>
    .pos-container {
        display: flex;
        gap: 24px;
        height: calc(100vh - 100px);
        margin: -24px;
    }

    .pos-left-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: white;
        border-radius: 16px;
        padding: 20px;
        overflow: hidden;
    }

    .pos-right-panel {
        width: 400px;
        display: flex;
        flex-direction: column;
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: var(--df-shadow-lg);
    }

    .pos-search-bar {
        margin-bottom: 16px;
    }

    .pos-categories {
        margin-bottom: 16px;
        overflow-x: auto;
    }

    .pos-product-grid {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 12px;
        overflow-y: auto;
        padding: 4px;
    }

    .pos-product-card {
        background: var(--df-surface-variant);
        border: 1px solid var(--df-border);
        border-radius: 12px;
        padding: 16px 12px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
    }

    .pos-product-card:hover {
        border-color: var(--df-primary-500);
        transform: translateY(-2px);
        box-shadow: var(--df-shadow-md);
    }

    .pos-product-card.out-of-stock {
        opacity: 0.5;
        pointer-events: none;
    }

    .pos-product-icon {
        color: var(--df-primary-500);
        margin-bottom: 8px;
    }

    .pos-product-name {
        font-size: 0.75rem;
        font-weight: 500;
        margin-bottom: 4px;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pos-product-price {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--df-primary-700);
    }

    .pos-product-stock {
        font-size: 0.65rem;
        margin-top: 4px;
    }

    .pos-product-stock.warning {
        color: var(--df-warning);
    }

    .pos-product-rx {
        position: absolute;
        top: 4px;
        right: 4px;
        color: var(--df-danger);
    }

    /* List View Styles */
    .pos-product-list {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
        overflow-y: auto;
        padding: 4px;
    }

    .pos-product-list-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--df-surface-variant);
        border: 1px solid var(--df-border);
        border-radius: 8px;
        padding: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .pos-product-list-item:hover {
        border-color: var(--df-primary-500);
        background: #f5f7fa;
        box-shadow: var(--df-shadow-sm);
    }

    .pos-product-list-item.out-of-stock {
        opacity: 0.5;
        pointer-events: none;
    }

    .pos-product-list-icon {
        flex-shrink: 0;
    }

    .pos-product-list-info {
        flex: 1;
        min-width: 0;
    }

    .pos-product-list-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--df-text-primary);
        margin-bottom: 4px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .pos-product-list-code {
        font-size: 0.75rem;
        color: var(--df-text-secondary);
    }

    .pos-product-list-details {
        flex-shrink: 0;
        text-align: right;
    }

    .pos-product-list-price {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--df-primary-700);
        margin-bottom: 4px;
    }

    .pos-product-list-stock {
        font-size: 0.75rem;
        color: var(--df-text-secondary);
    }

    .pos-product-list-stock.warning {
        color: var(--df-warning);
        font-weight: 600;
    }

    .pos-quick-actions {
        display: flex;
        gap: 8px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--df-border);
    }

    .pos-customer-bar {
        padding-bottom: 12px;
        border-bottom: 1px solid var(--df-border);
        margin-bottom: 12px;
    }

    .pos-cart {
        flex: 1;
        overflow-y: auto;
    }

    .pos-cart-empty {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .pos-cart-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px;
        background: var(--df-surface-variant);
        border-radius: 8px;
        margin-bottom: 8px;
    }

    .pos-cart-item-info {
        flex: 1;
    }

    .pos-cart-item-name {
        font-weight: 600;
