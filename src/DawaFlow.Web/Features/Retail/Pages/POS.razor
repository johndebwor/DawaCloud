@code {
    private string _searchQuery = string.Empty;
    private string _selectedCategory = "All";
    private string _customerName = string.Empty;
    private List<CartItem> _cartItems = new();
    private List<ProductDto> _products = new();
    
    private decimal _subtotal => _cartItems.Sum(i => i.LineTotal);
    private decimal _taxAmount => _subtotal * 0.16m;
    private decimal _discountAmount = 0;
    private decimal _grandTotalBeforeRounding => _subtotal + _taxAmount - _discountAmount;
    private decimal _grandTotal => _isRoundingEnabled
        ? RoundingService.ApplyRounding(_grandTotalBeforeRounding, _roundingMode, _roundingValue)
        : _grandTotalBeforeRounding;

    // Discount dialog
    private bool _showDiscountDialog = false;
    private string _discountType = "Percentage";
    private decimal _discountInput = 0;

    // Rounding settings (loaded from DB)
    private bool _isRoundingEnabled = false;
    private RoundingMode _roundingMode = RoundingMode.Nearest;
    private int _roundingValue = 10;

    // Display style setting (loaded from DB)
    private string _displayStyle = "grid";

    private bool _showPaymentDialog = false;
    private bool _showSuccessDialog = false;
    private string _selectedPaymentMethod = "Cash";
    private decimal _amountTendered = 0;
    private string _momoRef = string.Empty;
    private decimal _changeAmount = 0;
    private string _lastReceiptNumber = string.Empty;
    
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private DialogOptions _successDialogOptions = new() { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };

    private bool _showRecallDialog = false;
    private bool _showLastReceiptDialog = false;
    private List<HeldSaleListDto> _heldSales = new();
    private RetailReceiptDto? _lastReceipt = null;
    private string _currentUserId = string.Empty;

    private bool CanCompleteSale => _selectedPaymentMethod switch
    {
        "Cash" => _amountTendered >= _grandTotal,
        "MoMo" => !string.IsNullOrWhiteSpace(_momoRef),
        "Card" => true,
        _ => false
    };

    private IEnumerable<ProductDto> FilteredProducts =>
        _products.Where(p =>
            (string.IsNullOrWhiteSpace(_searchQuery) ||
             p.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) ||
             p.Code.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedCategory == "All" || p.Category == _selectedCategory)
        );

    protected override async Task OnInitializedAsync()
    {
        LoadProducts();
        _currentUserId = HttpContextAccessor.HttpContext?.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        await LoadRoundingSettingsAsync();
        await LoadDisplayStyleAsync();
    }

    private async Task LoadRoundingSettingsAsync()
    {
        try
        {
            var settings = await RoundingService.GetRoundingSettingsAsync(CancellationToken.None);
            _isRoundingEnabled = settings.IsEnabled && settings.ApplyToRetail;
            _roundingMode = settings.Mode;
            _roundingValue = settings.RoundingValue;
        }
        catch { /* use defaults */ }
    }

    private async Task LoadDisplayStyleAsync()
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var dbContext = scope.ServiceProvider.GetRequiredService<Data.AppDbContext>();
            var settings = await dbContext.CompanySettings.FirstOrDefaultAsync();
            if (settings != null)
            {
                _displayStyle = settings.PosProductDisplayStyle;
            }
        }
        catch { /* use default grid style */ }
    }

    private void LoadProducts()
    {
        _products = new List<ProductDto>
        {
            new() { Id = 1, Code = "PARA500", Name = "Paracetamol 500mg", Category = "Analgesics", Price = 50, Stock = 450 },
            new() { Id = 2, Code = "IBU400", Name = "Ibuprofen 400mg", Category = "Analgesics", Price = 80, Stock = 200 },
            new() { Id = 3, Code = "AMOX250", Name = "Amoxicillin 250mg", Category = "Antibiotics", Price = 150, Stock = 30, RequiresPrescription = true },
            new() { Id = 4, Code = "OMEP20", Name = "Omeprazole 20mg", Category = "Antacids", Price = 120, Stock = 180 },
            new() { Id = 5, Code = "CIPR500", Name = "Ciprofloxacin 500mg", Category = "Antibiotics", Price = 180, Stock = 85, RequiresPrescription = true },
            new() { Id = 6, Code = "VITC500", Name = "Vitamin C 500mg", Category = "Vitamins", Price = 35, Stock = 320 },
            new() { Id = 7, Code = "CETR10", Name = "Cetirizine 10mg", Category = "Antihistamines", Price = 35, Stock = 0 },
            new() { Id = 8, Code = "METRO400", Name = "Metronidazole 400mg", Category = "Antibiotics", Price = 60, Stock = 150, RequiresPrescription = true },
            new() { Id = 9, Code = "PANA500", Name = "Panadol Extra", Category = "Analgesics", Price = 70, Stock = 280 },
            new() { Id = 10, Code = "DOLO650", Name = "Doliprane 650mg", Category = "Analgesics", Price = 65, Stock = 195 },
            new() { Id = 11, Code = "VITB12", Name = "Vitamin B12", Category = "Vitamins", Price = 45, Stock = 150 },
            new() { Id = 12, Code = "ANTACID", Name = "ENO Antacid", Category = "Antacids", Price = 55, Stock = 220 },
        };
    }

    private void AddToCart(ProductDto product)
    {
        if (product.Stock == 0) return;

        var existing = _cartItems.FirstOrDefault(i => i.ProductId == product.Id);
        if (existing != null)
        {
            existing.Quantity++;
        }
        else
        {
            _cartItems.Add(new CartItem
            {
                ProductId = product.Id,
                Name = product.Name,
                UnitPrice = product.Price,
                Quantity = 1
            });
        }
    }

    private void IncreaseQuantity(CartItem item)
    {
        item.Quantity++;
    }

    private void DecreaseQuantity(CartItem item)
    {
        if (item.Quantity > 1)
            item.Quantity--;
        else
            RemoveFromCart(item);
    }

    private void RemoveFromCart(CartItem item)
    {
        _cartItems.Remove(item);
    }

    private void ClearCart()
    {
        _cartItems.Clear();
        _discountAmount = 0;
        _customerName = string.Empty;
    }

    private void ApplyDiscount()
    {
        if (_cartItems.Count == 0)
        {
            Snackbar.Add("Add items to cart first", Severity.Warning);
            return;
        }
        _discountType = "Percentage";
        _discountInput = 0;
        _showDiscountDialog = true;
    }

    private void ConfirmDiscount()
    {
        _discountAmount = _discountType == "Percentage"
            ? _subtotal * _discountInput / 100
            : Math.Min(_discountInput, _subtotal);
        _showDiscountDialog = false;
    }

    private void ProcessPayment()
    {
        _amountTendered = _grandTotal;
        _showPaymentDialog = true;
    }

    private async Task CompleteSale()
    {
        _changeAmount = _amountTendered - _grandTotal;
        _lastReceiptNumber = $"RCP-{DateTime.Now:yyyyMMddHHmmss}";

        // TODO: Save sale to database
        await Task.Delay(500);

        _showPaymentDialog = false;
        _showSuccessDialog = true;

        // Clear cart after successful sale
        ClearCart();
    }

    private async Task PrintReceipt()
    {
        // Load company settings
        using var scope = ScopeFactory.CreateScope();
        var dbContext = scope.ServiceProvider.GetRequiredService<Data.AppDbContext>();
        var companySettings = await dbContext.CompanySettings.FirstOrDefaultAsync();

        // Get cashier name from claims
        var user = HttpContextAccessor.HttpContext?.User;
        var cashierName = user?.FindFirst("FirstName")?.Value ?? user?.Identity?.Name ?? "Cashier";

        // Build logo HTML if available
        var logoHtml = "";
        if (!string.IsNullOrEmpty(companySettings?.LogoUrl))
        {
            logoHtml = $"<img src='{companySettings.LogoUrl}' alt='Logo' style='max-width: 120px; margin-bottom: 10px; display: block; margin-left: auto; margin-right: auto;' />";
        }

        var receiptHtml = $@"
            <div class='receipt-header'>
                {logoHtml}
                <h2>{companySettings?.CompanyName ?? "Pharmacy"}</h2>
                <p>{companySettings?.Address ?? "Address"}</p>
                <p>{companySettings?.City}, {companySettings?.Country}</p>
                <p>Tel: {companySettings?.Phone ?? "N/A"}</p>
                <p>Email: {companySettings?.Email ?? "N/A"}</p>
            </div>
            <div class='receipt-divider'></div>
            <p><strong>Receipt: {_lastReceiptNumber}</strong></p>
            <p>Date: {DateTime.Now:dd/MM/yyyy HH:mm}</p>
            <p>Cashier: {cashierName}</p>
            {(!string.IsNullOrEmpty(_customerName) ? $"<p>Customer: {_customerName}</p>" : "")}
            <div class='receipt-divider'></div>";

        // Add actual cart items
        foreach (var item in _cartItems)
        {
            receiptHtml += $@"
            <div class='receipt-item'>
                <span>{item.Name} x{item.Quantity} @ SSP {item.UnitPrice:N2}</span>
                <span>SSP {item.LineTotal:N2}</span>
            </div>";
        }

        receiptHtml += @"
            <div class='receipt-divider'></div>
            <div class='receipt-item'>
                <span>Subtotal:</span>
                <span>SSP " + _subtotal.ToString("N2") + @"</span>
            </div>";

        // Show discount BEFORE tax
        if (_discountAmount > 0)
        {
            receiptHtml += @"
            <div class='receipt-item'>
                <span>Discount:</span>
                <span>-SSP " + _discountAmount.ToString("N2") + @"</span>
            </div>";
        }

        receiptHtml += @"
            <div class='receipt-item'>
                <span>Tax (16%):</span>
                <span>SSP " + _taxAmount.ToString("N2") + @"</span>
            </div>
            <div class='receipt-divider'></div>
            <div class='receipt-item receipt-total'>
                <span>TOTAL:</span>
                <span>SSP " + _grandTotal.ToString("N2") + @"</span>
            </div>
            <div class='receipt-item'>
                <span>Paid (" + _selectedPaymentMethod + @"):</span>
                <span>SSP " + _amountTendered.ToString("N2") + @"</span>
            </div>";

        if (_changeAmount > 0)
        {
            receiptHtml += @"
            <div class='receipt-item'>
                <span>Change:</span>
                <span>SSP " + _changeAmount.ToString("N2") + @"</span>
            </div>";
        }

        receiptHtml += $@"
            <div class='receipt-divider'></div>
            <div class='receipt-header'>
                <p>Thank you for your business!</p>
                <p>{companySettings?.Website ?? ""}</p>
            </div>";

        await JSRuntime.InvokeVoidAsync("printFunctions.printReceipt", receiptHtml);
    }

    private async Task HoldSale()
    {
        if (_cartItems.Count == 0)
        {
            Snackbar.Add("Cart is empty", Severity.Warning);
            return;
        }

        var cartDto = _cartItems.Select(i => new CartItemDto(
            i.ProductId,
            i.Name,
            i.Quantity,
            i.UnitPrice
        )).ToList();

        var command = new HoldSaleCommand(
            _customerName,
            cartDto,
            _grandTotal,
            _subtotal,
            _taxAmount,
            _discountAmount,
            _currentUserId
        );

        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            Snackbar.Add($"Sale held as {result.Value}", Severity.Success);
            ClearCart();
        }
        else
        {
            Snackbar.Add(result.Error, Severity.Error);
        }
    }

    private async Task RecallSale()
    {
        var query = new GetHeldSalesQuery(_currentUserId);
        _heldSales = await Mediator.Send(query);

        if (_heldSales.Count == 0)
        {
            Snackbar.Add("No held sales found", Severity.Info);
            return;
        }

        _showRecallDialog = true;
    }

    private async Task RecallSelectedSale(int heldSaleId)
    {
        var command = new RecallSaleCommand(heldSaleId);
        var result = await Mediator.Send(command);

        if (result.IsSuccess)
        {
            var heldSale = result.Value;

            // Deserialize cart items
            var items = JsonSerializer.Deserialize<List<CartItemDto>>(heldSale.ItemsJson);
            if (items != null)
            {
                _cartItems = items.Select(i => new CartItem
                {
                    ProductId = i.ProductId,
                    Name = i.Name,
                    Quantity = i.Quantity,
                    UnitPrice = i.UnitPrice
                }).ToList();

                _customerName = heldSale.CustomerName ?? string.Empty;
                Snackbar.Add($"Sale {heldSale.Reference} recalled", Severity.Success);
            }
        }
        else
        {
            Snackbar.Add(result.Error ?? "Failed to recall sale", Severity.Error);
        }

        _showRecallDialog = false;
    }

    private async Task ShowLastReceipt()
    {
        var query = new GetLastReceiptQuery(_currentUserId);
        var result = await Mediator.Send(query);

        if (result.IsSuccess)
        {
            _lastReceipt = result.Value;
            _showLastReceiptDialog = true;
        }
        else
        {
            Snackbar.Add("No recent receipts found", Severity.Info);
        }
    }

