@page "/inventory"
@page "/inventory/stock-levels"
@using MudBlazor
@using DawaFlow.Web.Features.Inventory.Queries
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar

<PageTitle>Stock Levels - DawaFlow</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Stock Levels</h1>
            <p>Real-time inventory quantities across all batches</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.FileDownload">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/inventory/adjustments/new">
                Stock Adjustment
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.Inventory" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total SKUs</div>
            <div class="df-kpi-value">@_stockItems.Count</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Low Stock</div>
            <div class="df-kpi-value">@_stockItems.Count(s => s.StockLevel == "Low")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon danger">
                <MudIcon Icon="@Icons.Material.Filled.Error" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Out of Stock</div>
            <div class="df-kpi-value">@_stockItems.Count(s => s.StockLevel == "Out")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Stock Value</div>
            <div class="df-kpi-value">KES @_stockItems.Sum(s => s.TotalValue).ToString("N0")</div>
        </div>
    </div>
</div>

<!-- Filters and Table -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by drug name or code..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 400px;" />

        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedCategory" Label="Category" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Categories</MudSelectItem>
                <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                <MudSelectItem Value="@("Cardiovascular")">Cardiovascular</MudSelectItem>
            </MudSelect>

            <MudSelect T="string" @bind-Value="_selectedStockLevel" Label="Stock Level" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Levels</MudSelectItem>
                <MudSelectItem Value="@("Good")">Good Stock</MudSelectItem>
                <MudSelectItem Value="@("Low")">Low Stock</MudSelectItem>
                <MudSelectItem Value="@("Out")">Out of Stock</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <!-- Stock Table -->
    <MudTable T="StockLevelDto" Items="@FilteredItems" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" Class="mt-4">
            <HeaderContent>
                <MudTh>Drug</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Available</MudTh>
                <MudTh>Reserved</MudTh>
                <MudTh>Reorder Level</MudTh>
                <MudTh>Total Value</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Drug">
                    <div>
                        <MudText Typo="Typo.body2" Class="fw-bold">@context.DrugName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DrugCode</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Category">@context.Category</MudTd>
                <MudTd DataLabel="Available">
                    <MudText Typo="Typo.body2">@context.AvailableQuantity @context.Unit</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.BatchCount batches</MudText>
                </MudTd>
                <MudTd DataLabel="Reserved">@context.ReservedQuantity @context.Unit</MudTd>
                <MudTd DataLabel="Reorder Level">@context.ReorderLevel</MudTd>
                <MudTd DataLabel="Total Value">KES @context.TotalValue.ToString("N2")</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@GetStockLevelColor(context.StockLevel)">@context.StockLevel</MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.History"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Href="@($"/inventory/movements?drugId={context.DrugId}")"
                                   Title="View Movements" />
                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                   Size="Size.Small"
                                   Color="Color.Default"
                                   Href="@($"/inventory/adjustments/new?drugId={context.DrugId}")"
                                   Title="Adjust Stock" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

@code {
    private List<StockLevelDto> _stockItems = new();
    private string _searchString = string.Empty;
    private string _selectedCategory = "All";
    private string _selectedStockLevel = "All";
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStockLevels();
    }

    private async Task LoadStockLevels()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _stockItems = await Mediator.Send(new GetStockLevelsQuery());
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading stock levels: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<StockLevelDto> FilteredItems =>
        _stockItems.Where(s =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             s.DrugName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             s.DrugCode.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedCategory == "All" || s.Category == _selectedCategory) &&
            (_selectedStockLevel == "All" || s.StockLevel == _selectedStockLevel)
        );

    private Color GetStockLevelColor(string level) => level switch
    {
        "Good" => Color.Success,
        "Low" => Color.Warning,
        "Out" => Color.Error,
        _ => Color.Default
    };
}
