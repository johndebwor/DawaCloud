@page "/auth/forgot-password"
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@layout Shared.Layout.AuthLayout
@attribute [AllowAnonymous]

<PageTitle>Forgot Password - DawaFlow</PageTitle>

<div class="auth-container">
    <div class="auth-card">
        @if (!_emailSent)
        {
            <div class="text-center mb-6">
                <div class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Style="font-size: 64px;" />
                </div>
                <MudText Typo="Typo.h4" Class="mb-2">
                    Forgot Password?
                </MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    No worries! Enter your email and we'll send you reset instructions
                </MudText>
            </div>

            <form method="post" action="/api/auth/forgot-password-form" id="forgotPasswordForm">
                <MudTextField Label="Email Address"
                              @bind-Value="_email"
                              name="email"
                              Variant="Variant.Outlined"
                              Margin="Margin.Normal"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new EmailAddressAttribute())"
                              HelperText="Enter your registered email address"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Class="mt-3 mb-3"
                           ButtonType="ButtonType.Submit"
                           Disabled="@string.IsNullOrEmpty(_email)">
                    <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" />
                    <span>Send Reset Link</span>
                </MudButton>
            </form>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-4" Dense="true" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
                    @_errorMessage
                </MudAlert>
            }

            <div class="text-center">
                <MudLink Href="/auth/login" Color="Color.Primary" Typo="Typo.body2">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1" />
                    Back to Sign In
                </MudLink>
            </div>
        }
        else
        {
            <div class="text-center">
                <div class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Success" Style="font-size: 80px;" />
                </div>
                <MudText Typo="Typo.h5" Class="mb-2">Check Your Email</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                    We've sent password reset instructions to
                </MudText>
                <MudChip T="string" Color="Color.Primary" Size="Size.Medium">@_email</MudChip>

                <MudAlert Severity="Severity.Info" Class="mt-4 text-left">
                    <MudText Typo="Typo.body2">
                        <strong>Didn't receive the email?</strong>
                        <ul class="mt-2 ml-4">
                            <li>Check your spam/junk folder</li>
                            <li>Verify the email address is correct</li>
                            <li>Wait a few minutes and try again</li>
                        </ul>
                    </MudText>
                </MudAlert>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="mt-4"
                           OnClick="HandleResend"
                           Disabled="@(_resendCountdown > 0)">
                    @if (_resendCountdown > 0)
                    {
                        <span>Resend in @_resendCountdown seconds</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Class="mr-2" />
                        <span>Resend Email</span>
                    }
                </MudButton>

                <MudDivider Class="my-4" />

                <div class="text-center">
                    <MudLink Href="/auth/login" Color="Color.Primary" Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" Class="mr-1" />
                        Back to Sign In
                    </MudLink>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private bool _emailSent;
    private string _email = string.Empty;
    private string? _errorMessage;
    private int _resendCountdown;
    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Error))
        {
            _errorMessage = Uri.UnescapeDataString(Error);
        }

        if (Success == "true" && !string.IsNullOrEmpty(Email))
        {
            _email = Uri.UnescapeDataString(Email);
            _emailSent = true;
            StartResendCountdown();
        }
    }

    private void StartResendCountdown()
    {
        _resendCountdown = 60;
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) =>
        {
            _resendCountdown--;
            if (_resendCountdown <= 0)
            {
                _timer?.Stop();
                _timer?.Dispose();
            }
            InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    private void HandleResend()
    {
        _emailSent = false;
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
