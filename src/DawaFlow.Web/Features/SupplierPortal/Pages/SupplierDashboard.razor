@page "/supplier/dashboard"
@using MudBlazor

<PageTitle>Supplier Dashboard - DawaFlow</PageTitle>

<!-- Welcome Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Welcome, MedSupply Ltd</h1>
            <p>Supplier Portal Dashboard</p>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card featured animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Pending Requests</div>
            <div class="df-kpi-value">5</div>
            <div class="df-kpi-subtitle">Awaiting your response</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.LocalShipping" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">In Transit</div>
            <div class="df-kpi-value">3</div>
            <div class="df-kpi-subtitle">Deliveries pending</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Delivered This Month</div>
            <div class="df-kpi-value">12</div>
            <div class="df-kpi-subtitle">Orders completed</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon info">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">This Month's Value</div>
            <div class="df-kpi-value">SSP 850K</div>
            <div class="df-kpi-subtitle">Total order value</div>
        </div>
    </div>
</div>

<!-- Pending Requests -->
<MudGrid Class="mt-4">
    <MudItem xs="12" lg="8">
        <div class="df-alert-card animate-fade-in-up animate-delay-2">
            <div class="df-alert-header">
                <div class="df-alert-title">
                    <div class="df-alert-title-icon warning">
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" />
                    </div>
                    <span>Pending Drug Requests</span>
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/supplier/requests">
                    View All
                </MudButton>
            </div>
            <div class="df-alert-body">
                <MudTable T="RequestDto" Items="@_pendingRequests" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Request #</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Items</MudTh>
                        <MudTh>Est. Value</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.RequestNumber</MudTd>
                        <MudTd>@context.RequestDate.ToString("dd MMM yyyy")</MudTd>
                        <MudTd>@context.ItemCount items</MudTd>
                        <MudTd>SSP @context.EstimatedValue.ToString("N0")</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary" Href="@($"/supplier/requests/{context.Id}")">
                                Respond
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        </div>
    </MudItem>

    <MudItem xs="12" lg="4">
        <!-- Recent Activity -->
        <div class="df-alert-card animate-fade-in-up animate-delay-3">
            <div class="df-alert-header">
                <div class="df-alert-title">
                    <div class="df-alert-title-icon info">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" />
                    </div>
                    <span>Recent Activity</span>
                </div>
            </div>
            <div class="df-alert-body">
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var activity in _recentActivity)
                    {
                        <MudTimelineItem Color="@activity.Color" Size="Size.Small">
                            <MudText Typo="Typo.body2">@activity.Description</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@activity.Time</MudText>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            </div>
        </div>

        <!-- Contact Info -->
        <div class="df-alert-card animate-fade-in-up animate-delay-4 mt-4">
            <div class="df-alert-header">
                <div class="df-alert-title">
                    <div class="df-alert-title-icon primary">
                        <MudIcon Icon="@Icons.Material.Filled.ContactSupport" />
                    </div>
                    <span>Need Help?</span>
                </div>
            </div>
            <div class="df-alert-body">
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Email">
                        <MudText Typo="Typo.body2">procurement@dawaflow.co.ke</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Phone">
                        <MudText Typo="Typo.body2">+254 720 123 456</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Chat">
                        <MudText Typo="Typo.body2">+254 720 123 456</MudText>
                    </MudListItem>
                </MudList>
            </div>
        </div>
    </MudItem>
</MudGrid>

@code {
    private List<RequestDto> _pendingRequests = new();
    private List<ActivityItem> _recentActivity = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        _pendingRequests = new List<RequestDto>
        {
            new() { Id = 1, RequestNumber = "REQ-2024-0045", RequestDate = DateTime.Now.AddDays(-1), ItemCount = 8, EstimatedValue = 125000, Status = "Pending" },
            new() { Id = 2, RequestNumber = "REQ-2024-0044", RequestDate = DateTime.Now.AddDays(-2), ItemCount = 5, EstimatedValue = 85000, Status = "Pending" },
            new() { Id = 3, RequestNumber = "REQ-2024-0043", RequestDate = DateTime.Now.AddDays(-3), ItemCount = 12, EstimatedValue = 230000, Status = "Awaiting Confirmation" },
            new() { Id = 4, RequestNumber = "REQ-2024-0042", RequestDate = DateTime.Now.AddDays(-4), ItemCount = 3, EstimatedValue = 45000, Status = "Pending" },
            new() { Id = 5, RequestNumber = "REQ-2024-0041", RequestDate = DateTime.Now.AddDays(-5), ItemCount = 6, EstimatedValue = 95000, Status = "Pending" },
        };

        _recentActivity = new List<ActivityItem>
        {
            new() { Description = "Delivery confirmed for REQ-2024-0038", Time = "2 hours ago", Color = Color.Success },
            new() { Description = "New request received REQ-2024-0045", Time = "1 day ago", Color = Color.Info },
            new() { Description = "Payment received for INV-2024-0125", Time = "2 days ago", Color = Color.Primary },
            new() { Description = "Delivery note uploaded for REQ-2024-0039", Time = "3 days ago", Color = Color.Success },
            new() { Description = "Request accepted REQ-2024-0040", Time = "4 days ago", Color = Color.Warning },
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Awaiting Confirmation" => Color.Info,
        "Confirmed" => Color.Success,
        "In Transit" => Color.Primary,
        _ => Color.Default
    };

    private class RequestDto
    {
        public int Id { get; set; }
        public string RequestNumber { get; set; } = string.Empty;
        public DateTime RequestDate { get; set; }
        public int ItemCount { get; set; }
        public decimal EstimatedValue { get; set; }
        public string Status { get; set; } = string.Empty;
    }

    private class ActivityItem
    {
        public string Description { get; set; } = string.Empty;
        public string Time { get; set; } = string.Empty;
        public Color Color { get; set; }
    }
}
