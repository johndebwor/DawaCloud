@using MudBlazor
@using DawaFlow.Web.Data.Entities
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Template Name" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Code" Label="Template Code" Variant="Variant.Outlined" Required="true"
                                  HelperText="Unique identifier for the template" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="NotificationType" @bind-Value="_model.Type" Label="Type" Variant="Variant.Outlined" Required="true">
                        @foreach (NotificationType type in Enum.GetValues(typeof(NotificationType)))
                        {
                            <MudSelectItem Value="@type">@type.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="NotificationChannel" @bind-Value="_model.Channel" Label="Channel" Variant="Variant.Outlined" Required="true">
                        @foreach (NotificationChannel channel in Enum.GetValues(typeof(NotificationChannel)))
                        {
                            <MudSelectItem Value="@channel">@channel.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Subject" Label="Subject" Variant="Variant.Outlined" Required="true"
                                  HelperText="Email subject or notification title" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Body" Label="Message Body" Variant="Variant.Outlined" Required="true"
                                  Lines="8" HelperText="Use {{variable}} for placeholders like {{drugName}}, {{quantity}}, etc." />
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch @bind-Value="_model.IsActive" Label="Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            @(_isEditMode ? "Update Template" : "Create Template")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public int? TemplateId { get; set; }

    [Parameter]
    public NotificationTemplate? Template { get; set; }

    [Parameter]
    public bool IsCopyMode { get; set; }

    private MudForm? _form;
    private bool _isEditMode => TemplateId.HasValue && !IsCopyMode;
    private TemplateModel _model = new();

    protected override void OnInitialized()
    {
        if (Template != null)
        {
            _model = new TemplateModel
            {
                Name = IsCopyMode ? $"{Template.Name} (Copy)" : Template.Name,
                Code = IsCopyMode ? $"{Template.Code}_copy" : Template.Code,
                Type = Template.Type,
                Channel = Template.Channel,
                Subject = Template.Subject,
                Body = Template.Body,
                IsActive = IsCopyMode ? true : Template.IsActive
            };
        }
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private async Task Submit()
    {
        if (_form != null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                Snackbar.Add("Please fill all required fields", Severity.Warning);
                return;
            }
        }

        MudDialog?.Close(DialogResult.Ok(_model));
    }

    private class TemplateModel
    {
        public string Name { get; set; } = string.Empty;
        public string Code { get; set; } = string.Empty;
        public NotificationType Type { get; set; }
        public NotificationChannel Channel { get; set; }
        public string Subject { get; set; } = string.Empty;
        public string Body { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }
}
