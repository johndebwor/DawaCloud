@page "/settings/exchange-rates"
@using MudBlazor
@using DawaFlow.Web.Features.Currency.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject ICurrencyService CurrencyService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Exchange Rates - DawaBes</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Exchange Rates</h1>
            <p>Manage currency exchange rates for your transactions</p>
        </div>
        <div class="df-hero-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenAddRateDialog">
                Add Exchange Rate
            </MudButton>
        </div>
    </div>
</div>

<!-- Current Rates Section -->
<MudPaper Elevation="0" Class="pa-4 mt-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Current Exchange Rates</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadDataAsync">
            Refresh
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudTable Items="@_exchangeRates" Dense="true" Hover="true" Striped="true"
                  Loading="@_isLoading" LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh>From</MudTh>
                <MudTh>To</MudTh>
                <MudTh Style="text-align: right;">Rate</MudTh>
                <MudTh>Effective Date</MudTh>
                <MudTh>Expiry Date</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Notes</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.FromCurrencyCode</MudChip>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@context.ToCurrencyCode</MudChip>
                </MudTd>
                <MudTd Style="text-align: right;">
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@context.Rate.ToString("N4")</MudText>
                </MudTd>
                <MudTd>@context.EffectiveDate.ToString("MMM d, yyyy")</MudTd>
                <MudTd>@(context.ExpiryDate?.ToString("MMM d, yyyy") ?? "-")</MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd>@(string.IsNullOrEmpty(context.Notes) ? "-" : context.Notes)</MudTd>
                <MudTd>
                    <MudTooltip Text="Edit Rate">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Info"
                                       OnClick="@(() => OpenEditRateDialog(context))" />
                    </MudTooltip>
                    <MudTooltip Text="View History">
                        <MudIconButton Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Warning"
                                       OnClick="@(() => ViewRateHistory(context.Id))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudAlert Severity="Severity.Info">
                    No exchange rates configured. Click "Add Exchange Rate" to create one.
                </MudAlert>
            </NoRecordsContent>
        </MudTable>
    }
</MudPaper>

<!-- Rate History Section -->
@if (_showHistory)
{
    <MudPaper Elevation="0" Class="pa-4 mt-4">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudText Typo="Typo.h6">Rate Change History - @_selectedRateForHistory</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseHistory" />
        </div>

        <MudTable Items="@_rateHistory" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Changed At</MudTh>
                <MudTh>Changed By</MudTh>
                <MudTh Style="text-align: right;">Previous Rate</MudTh>
                <MudTh Style="text-align: right;">New Rate</MudTh>
                <MudTh Style="text-align: right;">Change %</MudTh>
                <MudTh>Reason</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ChangedAt.ToString("MMM d, yyyy HH:mm")</MudTd>
                <MudTd>@context.ChangedBy</MudTd>
                <MudTd Style="text-align: right;">@context.PreviousRate.ToString("N4")</MudTd>
                <MudTd Style="text-align: right;">@context.NewRate.ToString("N4")</MudTd>
                <MudTd Style="text-align: right;">
                    @{
                        var changePercent = ((context.NewRate - context.PreviousRate) / context.PreviousRate) * 100;
                        var color = changePercent >= 0 ? "color: green;" : "color: red;";
                        var sign = changePercent >= 0 ? "+" : "";
                    }
                    <span style="@color">@sign@changePercent.ToString("N2")%</span>
                </MudTd>
                <MudTd>@(context.ChangeReason ?? "-")</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No rate changes recorded yet.</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}

<!-- Add/Edit Rate Dialog -->
<MudDialog @bind-Visible="_showRateDialog" Options="@_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CurrencyExchange" Class="mr-2" />
            @(_isEditMode ? "Edit Exchange Rate" : "Add Exchange Rate")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isFormValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_rateModel.FromCurrencyId" Label="From Currency"
                               Variant="Variant.Outlined" Required="true" Disabled="_isEditMode"
                               RequiredError="From currency is required">
                        @foreach (var currency in _currencies)
                        {
                            <MudSelectItem T="int" Value="@currency.Id">@currency.Code - @currency.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="int" @bind-Value="_rateModel.ToCurrencyId" Label="To Currency"
                               Variant="Variant.Outlined" Required="true" Disabled="_isEditMode"
                               RequiredError="To currency is required">
                        @foreach (var currency in _currencies)
                        {
                            <MudSelectItem T="int" Value="@currency.Id">@currency.Code - @currency.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal" @bind-Value="_rateModel.Rate" Label="Exchange Rate"
                                     Variant="Variant.Outlined" Required="true" Min="0.000001m" Format="N6"
                                     Adornment="Adornment.Start" AdornmentText="1 ="
                                     RequiredError="Rate is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_rateModel.EffectiveDate" Label="Effective Date"
                                   Variant="Variant.Outlined" Required="true"
                                   RequiredError="Effective date is required" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker @bind-Date="_rateModel.ExpiryDate" Label="Expiry Date (Optional)"
                                   Variant="Variant.Outlined" Clearable="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_rateModel.IsActive" Label="Active" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_rateModel.Notes" Label="Notes (Optional)"
                                  Variant="Variant.Outlined" Lines="2" />
                </MudItem>
                @if (_isEditMode)
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_rateModel.ChangeReason" Label="Reason for Change"
                                      Variant="Variant.Outlined" Lines="2"
                                      HelperText="Describe why the rate is being changed" />
                    </MudItem>
                }
            </MudGrid>

            @if (_rateModel.FromCurrencyId > 0 && _rateModel.ToCurrencyId > 0 && _rateModel.Rate > 0)
            {
                <MudAlert Severity="Severity.Info" Class="mt-4">
                    @{
                        var fromCode = _currencies.FirstOrDefault(c => c.Id == _rateModel.FromCurrencyId)?.Code ?? "?";
                        var toCode = _currencies.FirstOrDefault(c => c.Id == _rateModel.ToCurrencyId)?.Code ?? "?";
                    }
                    <strong>Preview:</strong> 1 @fromCode = @_rateModel.Rate.ToString("N4") @toCode
                </MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseRateDialog">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!_isFormValid || _isSaving)"
                   OnClick="SaveRate">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(_isEditMode ? "Update Rate" : "Add Rate")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _isLoading = true;
    private bool _showRateDialog;
    private bool _showHistory;
    private bool _isEditMode;
    private bool _isFormValid;
    private bool _isSaving;
    private MudForm? _form;
    private string _selectedRateForHistory = "";

    private List<CurrencyDto> _currencies = new();
    private List<ExchangeRateDto> _exchangeRates = new();
    private List<ExchangeRateHistoryDto> _rateHistory = new();
    private ExchangeRateModel _rateModel = new();

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _currencies = await CurrencyService.GetAllCurrenciesAsync();
            _exchangeRates = await CurrencyService.GetAllExchangeRatesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenAddRateDialog()
    {
        _isEditMode = false;
        _rateModel = new ExchangeRateModel
        {
            EffectiveDate = DateTime.Today,
            IsActive = true,
            Rate = 1
        };
        _showRateDialog = true;
    }

    private void OpenEditRateDialog(ExchangeRateDto rate)
    {
        _isEditMode = true;
        _rateModel = new ExchangeRateModel
        {
            Id = rate.Id,
            FromCurrencyId = rate.FromCurrencyId,
            ToCurrencyId = rate.ToCurrencyId,
            Rate = rate.Rate,
            EffectiveDate = rate.EffectiveDate,
            ExpiryDate = rate.ExpiryDate,
            IsActive = rate.IsActive,
            Notes = rate.Notes
        };
        _showRateDialog = true;
    }

    private void CloseRateDialog()
    {
        _showRateDialog = false;
        _rateModel = new();
    }

    private async Task SaveRate()
    {
        if (_form is null) return;

        await _form.Validate();
        if (!_isFormValid) return;

        if (_rateModel.FromCurrencyId == _rateModel.ToCurrencyId)
        {
            Snackbar.Add("From and To currencies must be different", Severity.Warning);
            return;
        }

        try
        {
            _isSaving = true;

            // Get current user for audit trail
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User?.Identity?.Name ?? "System";

            // Combine notes with change reason for the notes field
            var notes = _rateModel.Notes;
            if (_isEditMode && !string.IsNullOrWhiteSpace(_rateModel.ChangeReason))
            {
                notes = string.IsNullOrWhiteSpace(notes)
                    ? $"Change reason: {_rateModel.ChangeReason}"
                    : $"{notes} | Change reason: {_rateModel.ChangeReason}";
            }

            var result = await CurrencyService.SetExchangeRateAsync(
                _rateModel.FromCurrencyId,
                _rateModel.ToCurrencyId,
                _rateModel.Rate,
                notes,
                userName);

            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                CloseRateDialog();
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving rate: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ViewRateHistory(int rateId)
    {
        try
        {
            _rateHistory = await CurrencyService.GetExchangeRateHistoryAsync(rateId);
            var rate = _exchangeRates.FirstOrDefault(r => r.Id == rateId);
            _selectedRateForHistory = rate != null ? $"{rate.FromCurrencyCode} to {rate.ToCurrencyCode}" : "";
            _showHistory = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading history: {ex.Message}", Severity.Error);
        }
    }

    private void CloseHistory()
    {
        _showHistory = false;
        _rateHistory = new();
    }

    private class ExchangeRateModel
    {
        public int Id { get; set; }
        public int FromCurrencyId { get; set; }
        public int ToCurrencyId { get; set; }
        public decimal Rate { get; set; } = 1;
        public DateTime? EffectiveDate { get; set; }
        public DateTime? ExpiryDate { get; set; }
        public bool IsActive { get; set; } = true;
        public string? Notes { get; set; }
        public string? ChangeReason { get; set; }
    }
}
