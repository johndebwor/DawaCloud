@using MudBlazor
@using MediatR
@using DawaFlow.Web.Features.Drugs.Queries
@using DawaFlow.Web.Features.Batches.Queries
@using DawaFlow.Web.Features.Wholesale.DTOs
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudAutocomplete T="DrugListDto"
                                 Value="_selectedDrug"
                                 ValueChanged="OnDrugSelected"
                                 Label="Select Drug"
                                 Variant="Variant.Outlined"
                                 Required="true"
                                 SearchFunc="SearchDrugs"
                                 ToStringFunc="@(d => d?.Name ?? string.Empty)"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="true">
                    <ItemTemplate Context="drug">
                        <div>
                            <MudText Typo="Typo.body2">@drug.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @drug.Code | Stock: @drug.CurrentStock units
                            </MudText>
                        </div>
                    </ItemTemplate>
                </MudAutocomplete>
            </MudItem>

            @if (_selectedDrug != null && _availableBatches.Any())
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Available Batches (FEFO - First Expiry, First Out)</MudText>
                    <MudSelect T="BatchDto"
                               @bind-Value="_selectedBatch"
                               Label="Select Batch"
                               Variant="Variant.Outlined"
                               Required="true"
                               ToStringFunc="@(b => b?.BatchNumber ?? string.Empty)">
                        @foreach (var batch in _availableBatches)
                        {
                            <MudSelectItem Value="@batch">
                                <div class="d-flex justify-space-between align-center">
                                    <div>
                                        <MudText Typo="Typo.body2">@batch.BatchNumber</MudText>
                                        <MudText Typo="Typo.caption" Color="@GetExpiryColor(batch.ExpiryDate)">
                                            Expires: @batch.ExpiryDate.ToString("dd MMM yyyy") | Available: @batch.CurrentQuantity units
                                        </MudText>
                                    </div>
                                    @if (batch.ExpiryDate <= DateTime.Now.AddDays(90))
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Expiring Soon</MudChip>
                                    }
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_quantity"
                                     Label="Quantity"
                                     Variant="Variant.Outlined"
                                     Required="true"
                                     Min="1"
                                     Max="@(_selectedBatch?.CurrentQuantity ?? 0)"
                                     HelperText="@($"Max available: {_selectedBatch?.CurrentQuantity ?? 0}")" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_unitPrice"
                                     Label="Unit Price (SSP)"
                                     Variant="Variant.Outlined"
                                     Required="true"
                                     Min="0"
                                     Format="N2"
                                     Adornment="Adornment.Start"
                                     AdornmentText="SSP" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_discountPercent"
                                     Label="Discount %"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Max="100"
                                     Format="N2" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField Value="@GetLineTotal()"
                                  Label="Line Total"
                                  Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  Adornment="Adornment.Start"
                                  AdornmentText="SSP" />
                </MudItem>
            }
            else if (_selectedDrug != null && !_availableBatches.Any())
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Warning">
                        No available batches for this drug. Please check inventory.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!CanSubmit())">
            Add Item
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public List<Drugs.Queries.DrugListDto> AvailableDrugs { get; set; } = new();

    private Drugs.Queries.DrugListDto? _selectedDrug;
    private Batches.Queries.BatchDto? _selectedBatch;
    private List<Batches.Queries.BatchDto> _availableBatches = new();
    private int _quantity = 1;
    private decimal _unitPrice = 0;
    private decimal _discountPercent = 0;

    private async Task<IEnumerable<Drugs.Queries.DrugListDto>> SearchDrugs(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return AvailableDrugs;

        return AvailableDrugs.Where(d =>
            d.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            d.Code.Contains(value, StringComparison.OrdinalIgnoreCase)
        );
    }

    private async Task OnDrugSelected(Drugs.Queries.DrugListDto? drug)
    {
        _selectedDrug = drug;
        _selectedBatch = null;
        _availableBatches.Clear();

        if (drug != null)
        {
            try
            {
                // Load batches for the selected drug, ordered by expiry date (FEFO)
                var query = new GetBatchesByDrugQuery(drug.Id, true); // true = activeOnly
                _availableBatches = await Mediator.Send(query);

                if (_availableBatches.Any())
                {
                    // Auto-select first batch (earliest expiry with stock)
                    _selectedBatch = _availableBatches.First();

                    // Set default unit price to wholesale price
                    _unitPrice = drug.WholesalePrice;
                }

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error loading batches: {ex.Message}", Severity.Error);
            }
        }
    }

    private string GetLineTotal()
    {
        if (_selectedBatch == null || _quantity == 0)
            return "0.00";

        var subtotal = _quantity * _unitPrice;
        var discount = subtotal * (_discountPercent / 100);
        var total = subtotal - discount;

        return total.ToString("N2");
    }

    private bool CanSubmit()
    {
        return _selectedDrug != null
            && _selectedBatch != null
            && _quantity > 0
            && _quantity <= _selectedBatch.CurrentQuantity
            && _unitPrice > 0;
    }

    private void Submit()
    {
        if (!CanSubmit())
        {
            Snackbar.Add("Please fill all required fields", Severity.Warning);
            return;
        }

        var saleItem = new DTOs.SaleItemDto
        {
            DrugId = _selectedDrug!.Id,
            DrugCode = _selectedDrug.Code,
            DrugName = _selectedDrug.Name,
            BatchId = _selectedBatch!.Id,
            BatchNumber = _selectedBatch.BatchNumber,
            Quantity = _quantity,
            UnitPrice = _unitPrice,
            DiscountPercent = _discountPercent
        };

        MudDialog.Close(DialogResult.Ok(saleItem));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private Color GetExpiryColor(DateTime expiryDate)
    {
        var daysToExpiry = (expiryDate - DateTime.Now).Days;

        if (daysToExpiry < 0)
            return Color.Error;
        else if (daysToExpiry <= 30)
            return Color.Error;
        else if (daysToExpiry <= 90)
            return Color.Warning;
        else
            return Color.Success;
    }
}
