@page "/wholesale/sales/new"
@page "/wholesale/sales/{Id:int}"
@using MudBlazor
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_isViewMode ? "Invoice Details" : "New Wholesale Sale") - DawaFlow</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="mb-4" />

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="mb-1">@(_isViewMode ? $"Invoice #{_sale.InvoiceNumber}" : "New Wholesale Sale")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_isViewMode ? $"Customer: {_sale.CustomerName}" : "Create a new wholesale invoice")
            </MudText>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/wholesale/sales">
                Back to List
            </MudButton>
            @if (_isViewMode)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="PrintInvoice">
                    Print Invoice
                </MudButton>
                @if (_sale.BalanceAmount > 0)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Payment"
                               OnClick="RecordPayment">
                        Record Payment
                    </MudButton>
                }
            }
        </div>
    </div>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6">
                @if (_isViewMode)
                {
                    <!-- View Mode -->
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Invoice Number</MudText>
                            <MudText Typo="Typo.h6" Class="mb-4">@_sale.InvoiceNumber</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Invoice Date</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_sale.SaleDate.ToString("dd MMM yyyy")</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Customer</MudText>
                            <MudText Typo="Typo.body1" Class="mb-4">@_sale.CustomerName</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Status</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_sale.Status)">@_sale.Status</MudChip>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Payment</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetPaymentColor(_sale.PaymentStatus)">@_sale.PaymentStatus</MudChip>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <!-- Create Mode -->
                    <MudForm @ref="_form">
                        <MudText Typo="Typo.h6" Class="mb-4">Customer & Details</MudText>
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" @bind-Value="_selectedCustomerId" Label="Customer" Variant="Variant.Outlined" Required="true">
                                    @foreach (var customer in _customers)
                                    {
                                        <MudSelectItem T="int?" Value="@customer.Id">@customer.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudDatePicker @bind-Date="_deliveryDate" Label="Delivery Date" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_deliveryAddress" Label="Delivery Address" Variant="Variant.Outlined" />
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                }

                <MudDivider Class="my-4" />

                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">Line Items</MudText>
                    @if (!_isViewMode)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="AddItem">
                            Add Item
                        </MudButton>
                    }
                </div>

                <MudTable T="SaleItemDto" Items="_items" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Drug</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Unit Price</MudTh>
                        <MudTh>Discount</MudTh>
                        <MudTh>Total</MudTh>
                        @if (!_isViewMode)
                        {
                            <MudTh>Actions</MudTh>
                        }
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Drug">
                            <div>
                                <MudText Typo="Typo.body2">@context.DrugName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DrugCode</MudText>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Quantity">@context.Quantity</MudTd>
                        <MudTd DataLabel="Unit Price">SSP @context.UnitPrice.ToString("N2")</MudTd>
                        <MudTd DataLabel="Discount">@context.DiscountPercent%</MudTd>
                        <MudTd DataLabel="Total">SSP @context.LineTotal.ToString("N2")</MudTd>
                        @if (!_isViewMode)
                        {
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               OnClick="@(() => RemoveItem(context))" />
                            </MudTd>
                        }
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <!-- Summary Card -->
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Invoice Summary</MudText>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Subtotal</MudText>
                        <MudText Typo="Typo.body2">SSP @_subtotal.ToString("N2")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Discount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Success">- SSP @_totalDiscount.ToString("N2")</MudText>
                    </div>
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.body2">Tax (16%)</MudText>
                        <MudText Typo="Typo.body2">SSP @_taxAmount.ToString("N2")</MudText>
                    </div>
                    <MudDivider Class="my-2" />
                    <div class="d-flex justify-space-between">
                        <MudText Typo="Typo.subtitle1">Total</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">SSP @_grandTotal.ToString("N2")</MudText>
                    </div>
                    
                    @if (_isViewMode)
                    {
                        <MudDivider Class="my-2" />
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.body2">Amount Paid</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Success">SSP @_sale.PaidAmount.ToString("N2")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText Typo="Typo.subtitle1">Balance Due</MudText>
                            <MudText Typo="Typo.h6" Color="@(_sale.BalanceAmount > 0 ? Color.Error : Color.Success)">
                                SSP @_sale.BalanceAmount.ToString("N2")
                            </MudText>
                        </div>
                    }
                </div>
            </MudPaper>

            @if (!_isViewMode)
            {
                <div class="d-flex flex-column gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="SaveAsDraft"
                               Disabled="@(_items.Count == 0)">
                        Save as Draft
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="ConfirmSale"
                               Disabled="@(_items.Count == 0)">
                        Confirm Sale
                    </MudButton>
                </div>
            }
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool _isViewMode => Id.HasValue;
    private MudForm? _form;
    private SaleDto _sale = new();
    private List<SaleItemDto> _items = new();
    private List<CustomerDto> _customers = new();
    
    private int? _selectedCustomerId;
    private DateTime? _deliveryDate;
    private string _deliveryAddress = string.Empty;
    
    private decimal _subtotal => _items.Sum(i => i.Quantity * i.UnitPrice);
    private decimal _totalDiscount => _items.Sum(i => i.Quantity * i.UnitPrice * i.DiscountPercent / 100);
    private decimal _taxAmount => (_subtotal - _totalDiscount) * 0.16m;
    private decimal _grandTotal => _subtotal - _totalDiscount + _taxAmount;
    
    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override void OnInitialized()
    {
        LoadCustomers();
        
        if (_isViewMode)
        {
            LoadSale();
        }
        
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new("Home", href: "/"),
            new("Wholesale", href: "/wholesale/sales"),
            new(_isViewMode ? _sale.InvoiceNumber : "New Sale", href: null, disabled: true)
        };
    }

    private void LoadCustomers()
    {
        _customers = new List<CustomerDto>
        {
            new() { Id = 1, Name = "Nairobi Pharmacy Ltd" },
            new() { Id = 2, Name = "Mombasa Medicals" },
            new() { Id = 3, Name = "Kisumu Healthcare" },
            new() { Id = 4, Name = "Eldoret Pharmacy Group" }
        };
    }

    private void LoadSale()
    {
        // Sample data
        _sale = new SaleDto
        {
            Id = Id ?? 0,
            InvoiceNumber = "INV-2024-0032",
            SaleDate = DateTime.Now.AddDays(-2),
            CustomerName = "Nairobi Pharmacy Ltd",
            Status = "Delivered",
            PaymentStatus = "Partial",
            TotalAmount = 125000,
            PaidAmount = 75000
        };
        
        _items = new List<SaleItemDto>
        {
            new() { DrugCode = "PARA500", DrugName = "Paracetamol 500mg", Quantity = 1000, UnitPrice = 35.00m, DiscountPercent = 10 },
            new() { DrugCode = "AMOX250", DrugName = "Amoxicillin 250mg", Quantity = 500, UnitPrice = 120.00m, DiscountPercent = 15 },
            new() { DrugCode = "IBU400", DrugName = "Ibuprofen 400mg", Quantity = 800, UnitPrice = 42.00m, DiscountPercent = 10 }
        };
    }

    private void AddItem()
    {
        Snackbar.Add("Add item dialog coming soon", Severity.Info);
    }

    private void RemoveItem(SaleItemDto item)
    {
        _items.Remove(item);
    }

    private async Task SaveAsDraft()
    {
        await Task.Delay(500);
        Snackbar.Add("Sale saved as draft", Severity.Info);
        Navigation.NavigateTo("/wholesale/sales");
    }

    private async Task ConfirmSale()
    {
        await Task.Delay(500);
        Snackbar.Add("Sale confirmed", Severity.Success);
        Navigation.NavigateTo("/wholesale/sales");
    }

    private void PrintInvoice()
    {
        Snackbar.Add("Print invoice coming soon", Severity.Info);
    }

    private void RecordPayment()
    {
        Snackbar.Add("Record payment dialog coming soon", Severity.Info);
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Confirmed" => Color.Info,
        "Delivered" => Color.Success,
        "Cancelled" => Color.Error,
        _ => Color.Default
    };

    private Color GetPaymentColor(string status) => status switch
    {
        "Paid" => Color.Success,
        "Partial" => Color.Warning,
        "Pending" => Color.Info,
        "Overdue" => Color.Error,
        _ => Color.Default
    };

    private class SaleDto
    {
        public int Id { get; set; }
        public string InvoiceNumber { get; set; } = string.Empty;
        public DateTime SaleDate { get; set; }
        public string CustomerName { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string PaymentStatus { get; set; } = string.Empty;
        public decimal TotalAmount { get; set; }
        public decimal PaidAmount { get; set; }
        public decimal BalanceAmount => TotalAmount - PaidAmount;
    }

    private class SaleItemDto
    {
        public string DrugCode { get; set; } = string.Empty;
        public string DrugName { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal DiscountPercent { get; set; }
        public decimal LineTotal => Quantity * UnitPrice * (1 - DiscountPercent / 100);
    }

    private class CustomerDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
