@page "/wholesale"
@page "/wholesale/customers"
@using MudBlazor

<PageTitle>Wholesale Customers - DawaFlow</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Wholesale Customers</h1>
            <p>Manage B2B customers, credit limits, and pricing tiers</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => _showCreateDialog = true)">
                Add Customer
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.Groups" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Customers</div>
            <div class="df-kpi-value">@_customers.Count</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Active Customers</div>
            <div class="df-kpi-value">@_customers.Count(c => c.IsActive)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Outstanding</div>
            <div class="df-kpi-value">SSP @_customers.Sum(c => c.CurrentBalance).ToString("N0")</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon danger">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Over Credit Limit</div>
            <div class="df-kpi-value">@_customers.Count(c => c.CurrentBalance > c.CreditLimit)</div>
        </div>
    </div>
</div>

<!-- Customers Table -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search customers..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      IconSize="Size.Medium"
                      Immediate="true"
                      Style="max-width: 400px;" />
        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedTier" Label="Pricing Tier" Variant="Variant.Outlined" Dense="true" Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Tiers</MudSelectItem>
                <MudSelectItem Value="@("Standard")">Standard</MudSelectItem>
                <MudSelectItem Value="@("Silver")">Silver</MudSelectItem>
                <MudSelectItem Value="@("Gold")">Gold</MudSelectItem>
                <MudSelectItem Value="@("Platinum")">Platinum</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <MudTable T="CustomerDto" Items="@FilteredCustomers" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-4">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Customer</MudTh>
            <MudTh>Contact</MudTh>
            <MudTh>Tier</MudTh>
            <MudTh>Credit Limit</MudTh>
            <MudTh>Balance</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">
                <MudText Typo="Typo.body2" Class="fw-bold">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel="Customer">
                <div>
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.City</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Contact">
                <div>
                    <MudText Typo="Typo.body2">@context.ContactPerson</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Phone</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Tier">
                <MudChip T="string" Size="Size.Small" Color="@GetTierColor(context.PricingTier)">@context.PricingTier</MudChip>
            </MudTd>
            <MudTd DataLabel="Credit Limit">SSP @context.CreditLimit.ToString("N0")</MudTd>
            <MudTd DataLabel="Balance">
                <MudText Color="@(context.CurrentBalance > context.CreditLimit ? Color.Error : Color.Default)">
                    SSP @context.CurrentBalance.ToString("N0")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                    @(context.IsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info" OnClick="@(() => ViewCustomer(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" OnClick="@(() => EditCustomer(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Color="Color.Primary" Href="@($"/wholesale/sales?customerId={context.Id}")" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</div>

<!-- Create/Edit Dialog -->
<MudDialog @bind-Visible="_showCreateDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingCustomer == null ? "Add New Customer" : "Edit Customer")</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name" Label="Company Name" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.ContactPerson" Label="Contact Person" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Email" Label="Email" InputType="InputType.Email" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Phone" Label="Phone" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Address" Label="Address" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.City" Label="City" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.TaxId" Label="Tax ID / KRA PIN" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_model.CreditLimit" Label="Credit Limit (SSP)" Variant="Variant.Outlined" Min="0m" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" @bind-Value="_model.PricingTier" Label="Pricing Tier" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Standard")">Standard</MudSelectItem>
                        <MudSelectItem Value="@("Silver")">Silver</MudSelectItem>
                        <MudSelectItem Value="@("Gold")">Gold</MudSelectItem>
                        <MudSelectItem Value="@("Platinum")">Platinum</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_model.PaymentTerms" Label="Payment Terms (Days)" Variant="Variant.Outlined" Min="0" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="_model.IsActive" Label="Active" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveCustomer">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CustomerDto> _customers = new();
    private string _searchString = string.Empty;
    private string _selectedTier = "All";
    private bool _showCreateDialog = false;
    private MudForm? _form;
    private CustomerDto? _editingCustomer = null;
    private CustomerFormModel _model = new();
    
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    private IEnumerable<CustomerDto> FilteredCustomers =>
        _customers.Where(c =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             c.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             c.Code.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedTier == "All" || c.PricingTier == _selectedTier)
        );

    protected override void OnInitialized()
    {
        LoadCustomers();
    }

    private void LoadCustomers()
    {
        _customers = new List<CustomerDto>
        {
            new() { Id = 1, Code = "WC-001", Name = "Nairobi Pharmacy Ltd", ContactPerson = "John Kamau", Phone = "+254 722 123456", Email = "info@nairobipharmacy.co.ke", City = "Nairobi", CreditLimit = 500000, CurrentBalance = 125000, PricingTier = "Gold", PaymentTerms = 30, IsActive = true },
            new() { Id = 2, Code = "WC-002", Name = "Mombasa Medicals", ContactPerson = "Sarah Omondi", Phone = "+254 733 234567", Email = "orders@mombasamedicals.co.ke", City = "Mombasa", CreditLimit = 300000, CurrentBalance = 280000, PricingTier = "Silver", PaymentTerms = 14, IsActive = true },
            new() { Id = 3, Code = "WC-003", Name = "Kisumu Healthcare", ContactPerson = "Peter Otieno", Phone = "+254 711 345678", Email = "purchase@kisumuhealthcare.co.ke", City = "Kisumu", CreditLimit = 200000, CurrentBalance = 45000, PricingTier = "Standard", PaymentTerms = 7, IsActive = true },
            new() { Id = 4, Code = "WC-004", Name = "Eldoret Pharmacy Group", ContactPerson = "Grace Chebet", Phone = "+254 720 456789", Email = "procurement@eldoretpg.co.ke", City = "Eldoret", CreditLimit = 750000, CurrentBalance = 320000, PricingTier = "Platinum", PaymentTerms = 45, IsActive = true },
            new() { Id = 5, Code = "WC-005", Name = "Coast General Supplies", ContactPerson = "Ahmed Hassan", Phone = "+254 734 567890", Email = "admin@coastgeneral.co.ke", City = "Malindi", CreditLimit = 150000, CurrentBalance = 180000, PricingTier = "Standard", PaymentTerms = 7, IsActive = false },
        };
    }

    private Color GetTierColor(string tier) => tier switch
    {
        "Platinum" => Color.Primary,
        "Gold" => Color.Warning,
        "Silver" => Color.Info,
        _ => Color.Default
    };

    private void ViewCustomer(CustomerDto customer)
    {
        // TODO: Navigate to customer details
    }

    private void EditCustomer(CustomerDto customer)
    {
        _editingCustomer = customer;
        _model = new CustomerFormModel
        {
            Name = customer.Name,
            ContactPerson = customer.ContactPerson,
            Email = customer.Email,
            Phone = customer.Phone,
            Address = customer.Address,
            City = customer.City,
            TaxId = customer.TaxId,
            CreditLimit = customer.CreditLimit,
            PaymentTerms = customer.PaymentTerms,
            PricingTier = customer.PricingTier,
            IsActive = customer.IsActive
        };
        _showCreateDialog = true;
    }

    private async Task SaveCustomer()
    {
        // TODO: Implement save logic
        await Task.Delay(500);
        _showCreateDialog = false;
        _editingCustomer = null;
        _model = new();
    }

    private class CustomerDto
    {
        public int Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? ContactPerson { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? TaxId { get; set; }
        public decimal CreditLimit { get; set; }
        public decimal CurrentBalance { get; set; }
        public int PaymentTerms { get; set; }
        public string PricingTier { get; set; } = "Standard";
        public bool IsActive { get; set; }
    }

    private class CustomerFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? ContactPerson { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? TaxId { get; set; }
        public decimal CreditLimit { get; set; }
        public int PaymentTerms { get; set; } = 30;
        public string PricingTier { get; set; } = "Standard";
        public bool IsActive { get; set; } = true;
    }
}
