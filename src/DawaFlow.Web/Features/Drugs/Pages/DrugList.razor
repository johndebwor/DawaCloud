@page "/drugs"
@using MudBlazor

<PageTitle>Drugs - DawaFlow</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Drug Inventory</h1>
            <p>Manage your pharmaceutical products</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/drugs/new">
                Add New Drug
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.Medication" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Drugs</div>
            <div class="df-kpi-value">@_drugs.Count</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">In Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock > d.ReorderLevel)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Low Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock <= d.ReorderLevel && d.CurrentStock > 0)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon danger">
                <MudIcon Icon="@Icons.Material.Filled.Error" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Out of Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock == 0)</div>
        </div>
    </div>
</div>

<!-- Search and Filters -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by name, code, or manufacturer..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Style="max-width: 400px;" />
        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedCategory"
                       Label="Category"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Categories</MudSelectItem>
                <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                <MudSelectItem Value="@("Antihistamines")">Antihistamines</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_selectedStatus"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Low Stock")">Low Stock</MudSelectItem>
                <MudSelectItem Value="@("Out of Stock")">Out of Stock</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <!-- Data Table -->
    <MudTable Items="@FilteredDrugs"
              Hover="true"
              Breakpoint="Breakpoint.Sm"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              Dense="true"
              Class="mt-4">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Drug Name</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Retail Price</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align: right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">
                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel="Drug Name">
                <div>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Manufacturer</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Category">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Category</MudChip>
            </MudTd>
            <MudTd DataLabel="Stock">
                <div>
                    <MudText Typo="Typo.body2">@context.CurrentStock units</MudText>
                    @if (context.CurrentStock <= context.ReorderLevel)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">Below reorder level</MudText>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Retail Price">
                <MudText Typo="Typo.body2">KES @context.RetailPrice.ToString("N2")</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.CurrentStock == 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Out of Stock</MudChip>
                }
                else if (context.CurrentStock <= context.ReorderLevel)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Low Stock</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">In Stock</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/drugs/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Info"
                               Size="Size.Small"
                               Href="@($"/drugs/{context.Id}/edit")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteDrug(context.Id))" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</div>

@code {
    private bool _loading = false;
    private string _searchString = string.Empty;
    private string _selectedCategory = "All";
    private string _selectedStatus = "All";

    private List<DrugListItem> _drugs = new();

    private IEnumerable<DrugListItem> FilteredDrugs =>
        _drugs.Where(d =>
            (string.IsNullOrWhiteSpace(_searchString) ||
             d.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             d.Code.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
             d.Manufacturer.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) &&
            (_selectedCategory == "All" || d.Category == _selectedCategory) &&
            (_selectedStatus == "All" || GetStatus(d) == _selectedStatus)
        );

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        await Task.Delay(500); // Simulate API call
        LoadSampleData();
        _loading = false;
    }

    private void LoadSampleData()
    {
        _drugs = new List<DrugListItem>
        {
            new() { Id = 1, Code = "PARA500", Name = "Paracetamol 500mg", Category = "Analgesics", Manufacturer = "GSK", CurrentStock = 450, ReorderLevel = 100, RetailPrice = 5.00m },
            new() { Id = 2, Code = "AMOX250", Name = "Amoxicillin 250mg", Category = "Antibiotics", Manufacturer = "Pfizer", CurrentStock = 30, ReorderLevel = 120, RetailPrice = 15.00m },
            new() { Id = 3, Code = "IBU400", Name = "Ibuprofen 400mg", Category = "Analgesics", Manufacturer = "Novartis", CurrentStock = 200, ReorderLevel = 100, RetailPrice = 8.00m },
            new() { Id = 4, Code = "CETR10", Name = "Cetirizine 10mg", Category = "Antihistamines", Manufacturer = "Cipla", CurrentStock = 0, ReorderLevel = 80, RetailPrice = 3.50m },
            new() { Id = 5, Code = "METRO400", Name = "Metronidazole 400mg", Category = "Antibiotics", Manufacturer = "Unichem", CurrentStock = 150, ReorderLevel = 100, RetailPrice = 6.00m },
            new() { Id = 6, Code = "OMEP20", Name = "Omeprazole 20mg", Category = "Antacids", Manufacturer = "AstraZeneca", CurrentStock = 180, ReorderLevel = 100, RetailPrice = 12.00m },
            new() { Id = 7, Code = "CIPR500", Name = "Ciprofloxacin 500mg", Category = "Antibiotics", Manufacturer = "Ranbaxy", CurrentStock = 85, ReorderLevel = 100, RetailPrice = 18.00m },
            new() { Id = 8, Code = "METF500", Name = "Metformin 500mg", Category = "Antidiabetics", Manufacturer = "Bristol-Myers", CurrentStock = 300, ReorderLevel = 150, RetailPrice = 7.50m },
        };
    }

    private string GetStatus(DrugListItem drug)
    {
        if (drug.CurrentStock == 0) return "Out of Stock";
        if (drug.CurrentStock <= drug.ReorderLevel) return "Low Stock";
        return "Active";
    }

    private async Task DeleteDrug(int id)
    {
        // TODO: Implement delete confirmation dialog and actual deletion
        await Task.CompletedTask;
    }

    private class DrugListItem
    {
        public int Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Manufacturer { get; set; } = string.Empty;
        public int CurrentStock { get; set; }
        public int ReorderLevel { get; set; }
        public decimal RetailPrice { get; set; }
    }
}
