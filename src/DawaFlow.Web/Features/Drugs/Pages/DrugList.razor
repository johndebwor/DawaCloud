@page "/drugs"
@using MudBlazor
@using MediatR
@using Microsoft.JSInterop
@using ClosedXML.Excel
@using DawaFlow.Web.Features.Drugs.Queries
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<PageTitle>Drugs - DawaBes</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Drug Inventory</h1>
            <p>Manage your pharmaceutical products</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.FileDownload" OnClick="ExportToExcel">
                Export
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       Href="/drugs/new">
                Add New Drug
            </MudButton>
        </div>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.Medication" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Drugs</div>
            <div class="df-kpi-value">@_totalCount</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">In Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock > d.ReorderLevel)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Low Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock <= d.ReorderLevel && d.CurrentStock > 0)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon danger">
                <MudIcon Icon="@Icons.Material.Filled.Error" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Out of Stock</div>
            <div class="df-kpi-value">@_drugs.Count(d => d.CurrentStock == 0)</div>
        </div>
    </div>
</div>

<!-- Search and Filters -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchString"
                      Placeholder="Search by name, code, or manufacturer..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      DebounceInterval="300"
                      OnDebounceIntervalElapsed="OnSearchChanged"
                      Style="max-width: 400px;" />
        <div class="d-flex gap-2">
            <MudSelect T="string" @bind-Value="_selectedCategory"
                       Label="Category"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Categories</MudSelectItem>
                <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                <MudSelectItem Value="@("Antihistamines")">Antihistamines</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" Value="_selectedStatus"
                       Label="Status"
                       Variant="Variant.Outlined"
                       Dense="true"
                       ValueChanged="@((string value) => OnStatusChanged(value))"
                       Style="min-width: 150px;">
                <MudSelectItem Value="@("All")">All Status</MudSelectItem>
                <MudSelectItem Value="@("In Stock")">In Stock</MudSelectItem>
                <MudSelectItem Value="@("Low Stock")">Low Stock</MudSelectItem>
                <MudSelectItem Value="@("Out of Stock")">Out of Stock</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    <!-- Data Table -->
    <MudTable Items="@FilteredDrugs"
              Hover="true"
              Breakpoint="Breakpoint.Sm"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              Dense="true"
              Class="mt-4">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Drug Name</MudTh>
            <MudTh>Category</MudTh>
            <MudTh>Stock</MudTh>
            <MudTh>Retail Price</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align: right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Code">
                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Code</MudText>
            </MudTd>
            <MudTd DataLabel="Drug Name">
                <div>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Name</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Manufacturer</MudText>
                </div>
            </MudTd>
            <MudTd DataLabel="Category">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@(context.Category ?? "Uncategorized")</MudChip>
            </MudTd>
            <MudTd DataLabel="Stock">
                <div>
                    <MudText Typo="Typo.body2">@context.CurrentStock units</MudText>
                    @if (context.CurrentStock <= context.ReorderLevel)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">Below reorder level</MudText>
                    }
                </div>
            </MudTd>
            <MudTd DataLabel="Retail Price">
                <MudText Typo="Typo.body2">SSP @context.RetailPrice.ToString("N2")</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.CurrentStock == 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Out of Stock</MudChip>
                }
                else if (context.CurrentStock <= context.ReorderLevel)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Low Stock</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">In Stock</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right;">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Href="@($"/drugs/{context.Id}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Info"
                               Size="Size.Small"
                               Href="@($"/drugs/{context.Id}/edit")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => DeleteDrug(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No drugs found. Click "Add New Drug" to create one.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</div>

@code {
    private bool _loading = false;
    private string _searchString = string.Empty;
    private string _selectedCategory = "All";
    private string _selectedStatus = "All";
    private int _totalCount = 0;

    private List<DrugListDto> _drugs = new();

    private IEnumerable<DrugListDto> FilteredDrugs =>
        _drugs.Where(d =>
            (_selectedCategory == "All" || d.Category == _selectedCategory) &&
            (_selectedStatus == "All" || GetStatus(d) == _selectedStatus)
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadDrugs();
    }

    private async Task LoadDrugs()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var result = await Mediator.Send(new GetDrugsQuery(
                SearchTerm: string.IsNullOrWhiteSpace(_searchString) ? null : _searchString,
                Status: _selectedStatus == "All" ? null : _selectedStatus
            ));

            if (result.Success)
            {
                _drugs = result.Drugs;
                _totalCount = result.TotalCount;
            }
            else
            {
                Snackbar.Add(result.ErrorMessage ?? "Failed to load drugs", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading drugs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnSearchChanged(string value)
    {
        _searchString = value;
        await LoadDrugs();
    }

    private async Task OnStatusChanged(string value)
    {
        _selectedStatus = value;
        await LoadDrugs();
    }

    private string GetStatus(DrugListDto drug)
    {
        if (drug.CurrentStock == 0) return "Out of Stock";
        if (drug.CurrentStock <= drug.ReorderLevel) return "Low Stock";
        return "In Stock";
    }

    private async Task DeleteDrug(DrugListDto drug)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Drug",
            $"Are you sure you want to delete '{drug.Name}'? This action will deactivate the drug.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var deleteResult = await Mediator.Send(new DeleteDrugCommand(drug.Id));

                if (deleteResult.Success)
                {
                    Snackbar.Add(deleteResult.Message, Severity.Success);
                    await LoadDrugs();
                }
                else
                {
                    Snackbar.Add(deleteResult.Message, Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting drug: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            using var workbook = new XLWorkbook();
            var worksheet = workbook.Worksheets.Add("Drugs");

            // Add headers
            worksheet.Cell(1, 1).Value = "Code";
            worksheet.Cell(1, 2).Value = "Name";
            worksheet.Cell(1, 3).Value = "Generic Name";
            worksheet.Cell(1, 4).Value = "Category";
            worksheet.Cell(1, 5).Value = "Retail Price";
            worksheet.Cell(1, 6).Value = "Wholesale Price";
            worksheet.Cell(1, 7).Value = "Current Stock";
            worksheet.Cell(1, 8).Value = "Reorder Level";
            worksheet.Cell(1, 9).Value = "Status";

            // Style headers
            var headerRange = worksheet.Range(1, 1, 1, 9);
            headerRange.Style.Font.Bold = true;
            headerRange.Style.Fill.BackgroundColor = XLColor.LightBlue;
            headerRange.Style.Alignment.Horizontal = XLAlignmentHorizontalValues.Center;

            // Add data rows
            int row = 2;
            foreach (var drug in FilteredDrugs)
            {
                worksheet.Cell(row, 1).Value = drug.Code;
                worksheet.Cell(row, 2).Value = drug.Name;
                worksheet.Cell(row, 3).Value = drug.GenericName;
                worksheet.Cell(row, 4).Value = drug.Category;
                worksheet.Cell(row, 5).Value = drug.RetailPrice;
                worksheet.Cell(row, 6).Value = drug.WholesalePrice;
                worksheet.Cell(row, 7).Value = drug.CurrentStock;
                worksheet.Cell(row, 8).Value = drug.ReorderLevel;
                worksheet.Cell(row, 9).Value = GetStatus(drug);
                row++;
            }

            // Auto-fit columns
            worksheet.Columns().AdjustToContents();

            // Convert to base64
            using var stream = new MemoryStream();
            workbook.SaveAs(stream);
            var base64 = Convert.ToBase64String(stream.ToArray());

            // Download via JavaScript
            await JSRuntime.InvokeVoidAsync("downloadFile",
                $"drugs-export-{DateTime.Now:yyyyMMdd-HHmmss}.xlsx",
                base64,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            Snackbar.Add($"Exported {FilteredDrugs.Count()} drugs successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error exporting: {ex.Message}", Severity.Error);
        }
    }
}
