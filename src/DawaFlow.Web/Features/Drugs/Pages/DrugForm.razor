@page "/drugs/new"
@page "/drugs/{id:int}/edit"
@using MudBlazor

<PageTitle>@(_isEditMode ? "Edit Drug" : "New Drug") - DawaFlow</PageTitle>

<div class="mb-4">
    <MudBreadcrumbs Items="_breadcrumbItems" Class="mb-4" />

    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="mb-1">@(_isEditMode ? "Edit Drug" : "Add New Drug")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_isEditMode ? "Update drug information" : "Add a new pharmaceutical product")
            </MudText>
        </div>
    </div>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Elevation="2" Class="pa-6">
                <MudForm @ref="_form" @bind-IsValid="@_isValid">
                    <MudText Typo="Typo.h6" Class="mb-4">Basic Information</MudText>

                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Code"
                                          Label="Drug Code"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Code is required"
                                          HelperText="Unique identifier for the drug" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Name"
                                          Label="Drug Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Name is required"
                                          HelperText="Generic or brand name" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_model.Description"
                                          Label="Description"
                                          Variant="Variant.Outlined"
                                          Lines="3"
                                          HelperText="Brief description of the drug" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_model.Category"
                                       Label="Category"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       AnchorOrigin="Origin.BottomCenter">
                                <MudSelectItem Value="@("Analgesics")">Analgesics</MudSelectItem>
                                <MudSelectItem Value="@("Antibiotics")">Antibiotics</MudSelectItem>
                                <MudSelectItem Value="@("Antihistamines")">Antihistamines</MudSelectItem>
                                <MudSelectItem Value="@("Antiacids")">Antiacids</MudSelectItem>
                                <MudSelectItem Value="@("Antidiabetics")">Antidiabetics</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Manufacturer"
                                          Label="Manufacturer"
                                          Variant="Variant.Outlined"
                                          HelperText="Drug manufacturer name" />
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />
                    <MudText Typo="Typo.h6" Class="mb-4">Pricing Information</MudText>

                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="_model.CostPrice"
                                             Label="Cost Price (KES)"
                                             Variant="Variant.Outlined"
                                             Min="0m"
                                             Step="0.01m"
                                             Required="true"
                                             HelperText="Purchase cost per unit" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="_model.WholesalePrice"
                                             Label="Wholesale Price (KES)"
                                             Variant="Variant.Outlined"
                                             Min="0m"
                                             Step="0.01m"
                                             HelperText="Price for bulk buyers" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="_model.RetailPrice"
                                             Label="Retail Price (KES)"
                                             Variant="Variant.Outlined"
                                             Min="0m"
                                             Step="0.01m"
                                             Required="true"
                                             HelperText="Selling price per unit" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudNumericField @bind-Value="_model.TaxRate"
                                             Label="Tax Rate (%)"
                                             Variant="Variant.Outlined"
                                             Min="0m"
                                             Max="100m"
                                             Step="0.1m"
                                             HelperText="VAT or tax percentage" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <div class="pa-4" style="background: #f5f7fa; border-radius: 8px;">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Profit Margin</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Success">
                                    @CalculateProfitMargin()%
                                </MudText>
                            </div>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />
                    <MudText Typo="Typo.h6" Class="mb-4">Stock Management</MudText>

                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudNumericField @bind-Value="_model.ReorderLevel"
                                             Label="Reorder Level"
                                             Variant="Variant.Outlined"
                                             Min="0"
                                             Required="true"
                                             HelperText="Minimum stock before reordering" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_model.Unit"
                                          Label="Unit of Measure"
                                          Variant="Variant.Outlined"
                                          HelperText="e.g., tablets, capsules, ml" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudCheckBox @bind-Value="_model.RequiresPrescription"
                                         Color="Color.Primary">
                                Requires Prescription
                            </MudCheckBox>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-6" />

                    <div class="d-flex justify-space-between">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Href="/drugs"
                                   StartIcon="@Icons.Material.Filled.ArrowBack">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@(!_isValid || _isSaving)"
                                   OnClick="HandleSubmit"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <span class="ml-2">Saving...</span>
                            }
                            else
                            {
                                <span>@(_isEditMode ? "Update Drug" : "Save Drug")</span>
                            }
                        </MudButton>
                    </div>
                </MudForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Quick Stats</MudText>
                <div class="mb-3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Profit Per Unit</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Success">
                        KES @((_model.RetailPrice - _model.CostPrice).ToString("N2"))
                    </MudText>
                </div>
                <div class="mb-3">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Price with Tax</MudText>
                    <MudText Typo="Typo.h6">
                        KES @((_model.RetailPrice * (1 + _model.TaxRate / 100)).ToString("N2"))
                    </MudText>
                </div>
            </MudPaper>

            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Guidelines</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        <MudText Typo="Typo.body2">Use unique drug codes</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        <MudText Typo="Typo.body2">Set appropriate reorder levels</MudText>
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                        <MudText Typo="Typo.body2">Verify pricing before saving</MudText>
                    </MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _isSaving;
    private bool _isEditMode => Id.HasValue;

    private DrugFormModel _model = new();

    private List<BreadcrumbItem> _breadcrumbItems = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Drugs", href: "/drugs"),
            new BreadcrumbItem(_isEditMode ? "Edit" : "New", href: null, disabled: true)
        };

        if (_isEditMode)
        {
            await LoadDrug(Id!.Value);
        }
    }

    private async Task LoadDrug(int id)
    {
        // Simulate API call
        await Task.Delay(300);
        // TODO: Load actual drug data
        _model = new DrugFormModel
        {
            Code = "PARA500",
            Name = "Paracetamol 500mg",
            Description = "Pain relief and fever reduction",
            Category = "Analgesics",
            Manufacturer = "GSK",
            CostPrice = 3.50m,
            WholesalePrice = 4.50m,
            RetailPrice = 5.00m,
            TaxRate = 16m,
            ReorderLevel = 100,
            Unit = "Tablets",
            RequiresPrescription = false
        };
    }

    private async Task HandleSubmit()
    {
        _isSaving = true;
        StateHasChanged();

        // Simulate API call
        await Task.Delay(1000);

        // TODO: Implement actual save logic
        // NavigationManager.NavigateTo("/drugs");

        _isSaving = false;
        StateHasChanged();
    }

    private string CalculateProfitMargin()
    {
        if (_model.CostPrice == 0) return "0.00";
        var margin = ((_model.RetailPrice - _model.CostPrice) / _model.CostPrice) * 100;
        return margin.ToString("N2");
    }

    private class DrugFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Category { get; set; } = "Analgesics";
        public string Manufacturer { get; set; } = string.Empty;
        public decimal CostPrice { get; set; }
        public decimal WholesalePrice { get; set; }
        public decimal RetailPrice { get; set; }
        public decimal TaxRate { get; set; } = 16m;
        public int ReorderLevel { get; set; } = 50;
        public string Unit { get; set; } = "Tablets";
        public bool RequiresPrescription { get; set; }
    }
}
