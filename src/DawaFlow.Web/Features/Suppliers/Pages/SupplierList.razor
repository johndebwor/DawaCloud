@page "/suppliers"
@using MudBlazor
@using DawaFlow.Web.Features.Suppliers.Queries
@using MediatR
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Suppliers - DawaFlow</PageTitle>

<!-- Hero Section -->
<div class="df-hero animate-fade-in-up">
    <div class="df-hero-content">
        <div class="df-hero-text">
            <h1>Suppliers</h1>
            <p>Manage supplier information and contacts</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/suppliers/new">
            Add Supplier
        </MudButton>
    </div>
</div>

<!-- KPI Cards -->
<div class="df-kpi-grid">
    <div class="df-kpi-card animate-fade-in-up animate-delay-1">
        <div class="df-kpi-header">
            <div class="df-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Filled.Store" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Total Suppliers</div>
            <div class="df-kpi-value">@_suppliers.Count</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-2">
        <div class="df-kpi-header">
            <div class="df-kpi-icon primary">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Active</div>
            <div class="df-kpi-value">@_suppliers.Count(s => s.IsActive)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-3">
        <div class="df-kpi-header">
            <div class="df-kpi-icon info">
                <MudIcon Icon="@Icons.Material.Filled.Email" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">Email Enabled</div>
            <div class="df-kpi-value">@_suppliers.Count(s => s.EmailNotificationsEnabled)</div>
        </div>
    </div>
    <div class="df-kpi-card animate-fade-in-up animate-delay-4">
        <div class="df-kpi-header">
            <div class="df-kpi-icon warning">
                <MudIcon Icon="@Icons.Material.Filled.Chat" />
            </div>
        </div>
        <div class="df-kpi-body">
            <div class="df-kpi-label">WhatsApp Enabled</div>
            <div class="df-kpi-value">@_suppliers.Count(s => s.WhatsAppNotificationsEnabled)</div>
        </div>
    </div>
</div>

<!-- Suppliers Table -->
<div class="df-alert-card animate-fade-in-up animate-delay-2 mt-4">
    <div class="df-alert-header">
        <MudTextField @bind-Value="_searchTerm"
                      Placeholder="Search suppliers..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      OnDebounceIntervalElapsed="LoadSuppliers"
                      DebounceInterval="300"
                      Style="max-width: 400px;" />

        <MudSwitch @bind-Value="_showActiveOnly" Color="Color.Primary" Label="Active Only" OnChanged="@((bool _) => LoadSuppliers())" />
    </div>

    <MudTable T="SupplierDto" Items="@FilteredSuppliers" Dense="true" Hover="true" Loading="@_loading" Class="mt-4">
            <HeaderContent>
                <MudTh>Code</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Contact Info</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Notifications</MudTh>
                <MudTh>Contacts</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Code">@context.Code</MudTd>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2" Class="fw-bold">@context.Name</MudText>
                </MudTd>
                <MudTd DataLabel="Contact Info">
                    <div>
                        @if (!string.IsNullOrEmpty(context.Email))
                        {
                            <MudText Typo="Typo.body2">@context.Email</MudText>
                        }
                        @if (!string.IsNullOrEmpty(context.Phone))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Phone</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Location">
                    @if (!string.IsNullOrEmpty(context.City))
                    {
                        <span>@context.City, @context.Country</span>
                    }
                    else
                    {
                        <span>@context.Country</span>
                    }
                </MudTd>
                <MudTd DataLabel="Notifications">
                    <div class="d-flex gap-1">
                        @if (context.EmailNotificationsEnabled)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Email">Email</MudChip>
                        }
                        @if (context.WhatsAppNotificationsEnabled)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Chat">WhatsApp</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Contacts">@context.ContactCount</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   Href="@($"/suppliers/{context.Id}")"
                                   Title="View Details" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Href="@($"/procurement/requests/new?supplierId={context.Id}")"
                                   Title="Create Request" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

@code {
    private List<SupplierDto> _suppliers = new();
    private string _searchTerm = string.Empty;
    private bool _showActiveOnly = false;
    private bool _loading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSuppliers();
    }

    private async Task LoadSuppliers()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _suppliers = await Mediator.Send(new GetSuppliersQuery(
                SearchTerm: string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
                IsActive: _showActiveOnly ? true : null
            ));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading suppliers: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<SupplierDto> FilteredSuppliers => _suppliers;
}
